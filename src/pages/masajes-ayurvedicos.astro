---
// src/pages/masajes-ayurvedicos.astro
import Layout from '../layouts/Layout.astro';
import ReviewsSection from '../components/cards/ReviewsSection.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import masajeBioImg from '../assets/marmaterapia/puntos-marma-terapia-energetica-espalda.png';
import masajeCertImg from '../assets/marmaterapia/masaje-ayurvedico-aceites-medicinales.png';
import masajeMeditacionImg from '../assets/marmaterapia/meditacion-ayurveda-bienestar-holistico.png';

// --- DATOS DEL SERVICIO ---
const serviceInfo = {
  title: "Masajes Ayurvédicos y Puntos Marma",
  subtitle: "En Envigado - La Frontera con El Poblado, vive una terapia milenaria que desintoxica tu cuerpo y restaura el flujo de tu energía vital desde las raíces de la medicina Ayurvédica.",
  priceFrom: "$180.000 COP",
  duration: "60 - 90 Min",
  whatsappMessage: "Hola Marce Anahata, me interesa el Masaje Ayurvédico y Puntos Marma. Quisiera agendar una sesión para restaurar mi energía vital."
};

// --- LOS 4 MASAJES AYURVÉDICOS ---
const subservicios = [
  {
    nombre: "Masaje Abhyangam Completo",
    tagline: "El masaje ayurvédico clásico de cuerpo completo",
    descripcion: "Masaje tradicional de cuerpo entero con abundante aceite medicinal tibio, trabajando de la cabeza a los pies en el sentido de los canales energéticos. Desintoxica los tejidos profundos, nutre la piel y el sistema nervioso, y reequilibra tus doshas. La experiencia más profunda y completa.",
    duracion: "90 min",
    duracionISO: "PT90M",
    precio: "$250.000",
    precioNum: "250000",
    icono: "🌿",
    destacado: true
  },
  {
    nombre: "Masaje de Relajación con Terapia de Sonido",
    tagline: "Masaje con aceites + baño sonoro de cuencos y gong",
    descripcion: "Une el masaje con aceites tibios a un baño de sonido con cuencos de cristal de cuarzo y gong. Mientras el cuerpo se libera con el contacto terapéutico, las vibraciones llevan al sistema nervioso a una calma profunda. Ideal para estrés, ansiedad e insomnio.",
    duracion: "90 min",
    duracionISO: "PT90M",
    precio: "$250.000",
    precioNum: "250000",
    icono: "🔔",
    destacado: true
  },
  {
    nombre: "Masaje Champi y Marmaterapia",
    tagline: "Cabeza, cuello y hombros + Puntos Marma",
    descripcion: "Masaje de cabeza, cuello y hombros (Champi) combinado con la activación de los Puntos Marma de la zona alta. Libera la tensión craneal acumulada, alivia dolores de cabeza y fatiga mental, y devuelve la claridad. Una caricia para la mente que piensa de más.",
    duracion: "60 min",
    duracionISO: "PT60M",
    precio: "$180.000",
    precioNum: "180000",
    icono: "🪷",
    destacado: false
  },
  {
    nombre: "Masaje Padabyanga",
    tagline: "Masaje terapéutico de pies y piernas con Puntos Marma",
    descripcion: "Masaje de pies y piernas con aceites medicinales y estimulación de los Puntos Marma de la zona. Los pies y las piernas concentran terminaciones que conectan con todo el cuerpo: trabajarlos induce descanso profundo, mejora el sueño y genera una sensación de enraizamiento y serenidad.",
    duracion: "60 min",
    duracionISO: "PT60M",
    precio: "$180.000",
    precioNum: "180000",
    icono: "🦶",
    destacado: false
  }
];

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent(serviceInfo.whatsappMessage)}`;
const waSub = (nombre: string) =>
  `https://wa.me/573207329921?text=${encodeURIComponent(`Hola Marce Anahata, me interesa el ${nombre}. Quisiera agendar una sesión.`)}`;
const serviceUrl = 'https://www.marceanahata.com/masajes-ayurvedicos';

const faqItems = [
  {
    question: '¿Qué es el Masaje Ayurvédico con Puntos Marma?',
    answer:
      'Es una terapia manual milenaria de la medicina Ayurvédica que trabaja con aceites medicinales calientes y la activación de los Puntos Marma —los centros de energía vital del cuerpo— para desintoxicar tejidos, liberar tensión acumulada y restablecer el flujo de Prana (energía vital).'
  },
  {
    question: '¿Dónde se realiza el masaje?',
    answer:
      'Las sesiones se realizan en Marce Anahata Centro de Bienestar, en Envigado, zona La Frontera con El Poblado (Cl. 23 Sur #42B-60). La ubicación exacta se comparte al confirmar la reserva por WhatsApp.'
  },
  {
    question: '¿Qué tipos de masaje ayurvédico ofrecen?',
    answer:
      'Ofrecemos 4 experiencias: (1) Masaje Abhyangam Completo de cuerpo entero (90 min · $250.000 COP); (2) Masaje de Relajación con Terapia de Sonido, que une el masaje a un baño de cuencos y gong (90 min · $250.000 COP); (3) Masaje Champi y Marmaterapia, de cabeza, cuello y hombros (60 min · $180.000 COP); y (4) Masaje Padabyanga, masaje terapéutico de pies y piernas (60 min · $180.000 COP).'
  },
  {
    question: '¿Cuánto dura la sesión y cuál es la inversión?',
    answer:
      'Según el masaje elegido, las sesiones duran 60 o 90 minutos. Los masajes de 60 minutos (Champi y Marmaterapia, y Padabyanga) tienen una inversión de $180.000 COP, y los de 90 minutos (Abhyangam Completo y Relajación con Terapia de Sonido) de $250.000 COP. Contáctanos por WhatsApp para reservar tu fecha.'
  },
  {
    question: '¿Qué son los Puntos Marma?',
    answer:
      'Los Puntos Marma son 107 puntos vitales del cuerpo según el Ayurveda —similar a los meridianos de la acupuntura— donde se concentra la energía vital (Prana). Su activación a través del masaje desbloquea estancamientos energéticos y favorece la salud orgánica y emocional.'
  },
  {
    question: '¿Necesito preparación previa para el masaje?',
    answer:
      'Se recomienda llegar con ropa cómoda, evitar comidas pesadas 2 horas antes y estar bien hidratado/a. No se requiere experiencia previa en ninguna práctica de bienestar.'
  },
  {
    question: '¿Cómo agendo mi sesión?',
    answer:
      'Puedes agendar directamente por WhatsApp desde esta página. La reserva se confirma con un abono previo para separar la fecha.'
  },
  {
    question: '¿Cuál es la diferencia entre el masaje Ayurvédico y un masaje relajante convencional?',
    answer:
      'El masaje relajante convencional trabaja principalmente el tejido muscular superficial para aliviar tensión física. El masaje Ayurvédico va más profundo: usa aceites medicinales calientes adaptados a tu constitución (Dosha), activa los 107 Puntos Marma del cuerpo y trabaja simultáneamente el cuerpo físico y el campo energético. El resultado es una desintoxicación más profunda y un reequilibrio que va más allá del músculo.'
  },
  {
    question: '¿Sirve el masaje Ayurvédico para el estrés y la ansiedad?',
    answer:
      'Sí. El masaje Ayurvédico es especialmente efectivo para el sistema nervioso. Los aceites medicinales calientes tienen un efecto directo sobre el sistema nervioso periférico, y la activación de Puntos Marma libera bloqueos emocionales almacenados en el cuerpo. Muchas personas lo combinan con nuestras clases de yoga y terapia de sonido para potenciar el trabajo con el sistema nervioso.'
  },
  {
    question: '¿Debo hacer algo especial antes o después del masaje?',
    answer:
      'Antes: evita comidas pesadas 2 horas antes, llega bien hidratado/a y con ropa cómoda. Después: se recomienda descansar, beber agua y evitar actividad intensa ese día para permitir que el cuerpo integre el proceso de desintoxicación. Los aceites medicinales siguen actuando horas después de la sesión.'
  }
];

// Posts relacionados con tag "ayurveda" o "masajes"
const masajePosts = (await getCollection('blog', ({ data, slug }) =>
  !data.draft && !slug.startsWith('en/') &&
  ((data.tags || []).includes('ayurveda') || (data.tags || []).includes('masajes') || (data.tags || []).includes('bienestar'))
))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout title="Masajes Ayurvédicos y Puntos Marma | Marce Anahata" description="Masaje Ayurvédico en Envigado, a 2 cuadras de El Poblado: Abhyangam completo, masaje con terapia de sonido, Champi y Marmaterapia, y Padabyanga. Aceites medicinales y Puntos Marma. Desde $180.000 COP." image="/images/masajes-ayurvedicos-poster.png">
  <Fragment slot="head">
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.marceanahata.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Masajes Ayurvédicos y Puntos Marma",
          "item": serviceUrl
        }
      ]
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Masaje Ayurvédico con Puntos Marma en Envigado — La Frontera con El Poblado",
      "description": "Terapia manual milenaria con aceites medicinales calientes y activación de los 107 Puntos Marma para desintoxicar el cuerpo, liberar tensión profunda y restaurar el flujo de energía vital (Prana). Sesiones de 60 a 90 minutos en Envigado, a 2 minutos de El Poblado.",
      "serviceType": "Masaje Ayurvédico",
      "provider": {
        "@type": "Person",
        "@id": "https://www.marceanahata.com/#person",
        "name": "Marce Anahata",
        "url": "https://www.marceanahata.com/sobre-mi",
        "telephone": "+573207329921",
        "email": "info@marceanahata.com",
        "sameAs": [
          "https://www.instagram.com/marce_anahata/",
          "https://www.youtube.com/@marce_anahata"
        ]
      },
      "areaServed": [
        { "@type": "City", "name": "Envigado" },
        { "@type": "Neighborhood", "name": "El Poblado" },
        { "@type": "Neighborhood", "name": "La Frontera" },
        { "@type": "City", "name": "Medellín" }
      ],
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "180000",
        "highPrice": "250000",
        "priceCurrency": "COP",
        "offerCount": "4",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Masajes Ayurvédicos",
        "itemListElement": subservicios.map((s) => ({
          "@type": "Offer",
          "price": s.precioNum,
          "priceCurrency": "COP",
          "availability": "https://schema.org/InStock",
          "url": serviceUrl,
          "itemOffered": {
            "@type": "Service",
            "name": s.nombre,
            "description": s.descripcion,
            "serviceType": "Masaje Ayurvédico"
          }
        }))
      },
      "url": serviceUrl,
      "keywords": "masaje ayurvédico Envigado, masaje ayurvédico El Poblado, puntos marma Envigado, terapia ayurveda Medellín, masaje con aceites medicinales, masaje relajante Envigado, masaje anti-estrés El Poblado, bienestar holístico, masaje Abhyanga, Abhyangam, masaje con terapia de sonido, masaje Champi, marmaterapia, masaje Padabyanga, masaje de pies y piernas ayurvédico, desintoxicación Ayurveda, masaje para ansiedad Medellín",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "SportsActivityLocation"],
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Centro de Bienestar",
      "description": "Centro de bienestar en Envigado (La Frontera con El Poblado) especializado en masajes ayurvédicos, Kundalini Yoga, terapia de sonido, círculos de mujeres y rituales sagrados.",
      "url": "https://www.marceanahata.com",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "image": "https://www.marceanahata.com/images/social-preview-wa.jpg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
        "addressLocality": "Envigado",
        "addressRegion": "Antioquia",
        "postalCode": "055420",
        "addressCountry": "CO"
      },
      "sameAs": [
        "https://www.instagram.com/marce_anahata/",
        "https://www.youtube.com/@marce_anahata",
        "https://www.tiktok.com/@marce_anahata"
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}</script>
    <meta property="og:locale" content="es_CO" />
  </Fragment>

  <!-- HERO -->
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">

    <video
      class="absolute inset-0 w-full h-full object-cover z-0 opacity-60"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster="/images/masajes-ayurvedicos-poster.png"
    >
      <source src="/videos/masajes-ayurvedicos.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-white opacity-30 z-10"></div>

    <div class="relative z-20 text-center text-[#243c5a] px-6 max-w-4xl mx-auto mt-20">
      <span class="uppercase tracking-[0.2em] text-sm md:text-base mb-4 block text-[#5d5a8c] font-bold">Medicina Ayurvédica</span>
      <h1 class="text-4xl md:text-6xl font-serif mb-6 leading-tight">
        {serviceInfo.title}
      </h1>
      <p class="text-lg md:text-xl font-light max-w-2xl mx-auto mb-8 opacity-90 text-[#243c5a]">
        {serviceInfo.subtitle}
      </p>
      <a
        href="#experiencias"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-8 py-4 rounded-full font-medium hover:bg-[#243c5a] hover:text-white transition-all duration-300 transform hover:-translate-y-1 shadow-lg"
      >
        Ver los 4 masajes
      </a>
    </div>
  </section>

  <!-- QUÉ ES -->
  <section class="py-20 bg-stone-50 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[#5d5a8c]/20 rounded-2xl z-0"></div>
        <Image
          src={masajeBioImg}
          alt="Puntos Marma activación energética espalda - terapia Ayurvédica en Medellín"
          class="rounded-2xl shadow-xl relative z-10 w-full h-[500px] object-cover"
          width={600}
          height={500}
          densities={[1.5, 2]}
          loading="eager"
          fetchpriority="high"
        />
      </div>
      <div>
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-6">Tu cuerpo recuerda cómo sanarse</h2>
        <p class="text-[#243c5a]/80 mb-6 leading-relaxed">
          El Ayurveda —la ciencia de la vida— entiende el cuerpo como un campo de energía inteligente. Cuando el Prana fluye libremente, tenemos salud; cuando se estanca, aparece el malestar. El masaje Ayurvédico con Puntos Marma es la herramienta más directa para restaurar ese flujo.
        </p>
        <p class="text-[#243c5a]/80 mb-8 leading-relaxed">
          A través de técnicas manuales precisas y aceites medicinales calientes adaptados a tu constitución (Dosha), esta terapia trabaja simultáneamente el cuerpo físico y el campo energético, liberando tensiones profundas que las terapias convencionales no alcanzan. Muchas personas combinan estas sesiones con nuestras <a href="/clases" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">prácticas de Kundalini Yoga</a> para potenciar el proceso de integración.
        </p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">🌿</span> Desintoxicación de tejidos profundos
          </li>
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">⚡</span> Activación de los 107 Puntos Marma
          </li>
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">🌸</span> Aceites medicinales adaptados a tu Dosha
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- LOS 4 MASAJES -->
  <section id="experiencias" class="py-20 bg-white px-6 scroll-mt-20">
    <div class="max-w-3xl mx-auto text-center mb-14">
      <span class="uppercase tracking-[0.2em] text-xs md:text-sm text-[#5d5a8c] font-bold block mb-3">Elige tu experiencia</span>
      <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Cuatro masajes ayurvédicos</h2>
      <p class="text-[#243c5a]/70 leading-relaxed">
        Cada masaje trabaja una necesidad distinta —desde la desintoxicación profunda de cuerpo completo hasta el descanso a través de los pies o la cabeza. Elige el que tu cuerpo te pide hoy.
      </p>
    </div>

    <div class="max-w-5xl mx-auto grid grid-cols-1 sm:grid-cols-2 gap-6">
      {subservicios.map((s) => (
        <article class="group relative bg-white rounded-2xl border border-stone-200 shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-300 overflow-hidden flex flex-col">
          <div class="h-1.5 bg-gradient-to-r from-[#6ed8d9] to-[#5d5a8c]"></div>
          {s.destacado && (
            <span class="absolute top-5 right-5 text-[10px] font-bold uppercase tracking-widest text-[#243c5a] bg-[#6ed8d9] px-3 py-1 rounded-full shadow-sm">
              Experiencia completa
            </span>
          )}
          <div class="p-8 flex flex-col flex-grow">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-14 h-14 rounded-2xl bg-[#6ed8d9]/10 flex items-center justify-center text-3xl group-hover:scale-110 transition-transform duration-300">
                {s.icono}
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-[#5d5a8c] bg-[#5d5a8c]/10 px-3 py-1.5 rounded-full">
                ⏱ {s.duracion}
              </span>
            </div>
            <h3 class="text-xl font-serif text-[#243c5a] mb-1.5 leading-snug">{s.nombre}</h3>
            <p class="text-sm text-[#5d5a8c] font-medium mb-4">{s.tagline}</p>
            <p class="text-sm text-[#243c5a]/70 leading-relaxed mb-6 flex-grow">{s.descripcion}</p>
            <div class="flex items-center justify-between pt-5 border-t border-stone-100">
              <div class="leading-none">
                <span class="text-2xl font-serif text-[#243c5a]">{s.precio}</span>
                <span class="text-xs text-[#243c5a]/50 ml-1">COP</span>
              </div>
              <a
                href={waSub(s.nombre)}
                target="_blank"
                rel="noopener noreferrer"
                data-event="whatsapp_click"
                data-label={`Masaje Card - ${s.nombre}`}
                class="bg-[#6ed8d9] text-[#243c5a] px-6 py-2.5 rounded-full font-semibold text-sm hover:bg-[#243c5a] hover:text-white transition-all duration-300 shadow-sm"
              >
                Agendar
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

    <p class="text-center text-sm text-[#243c5a]/60 mt-10 max-w-2xl mx-auto">
      Todos los masajes inician con una breve evaluación de tu constitución (Dosha) para adaptar los aceites y la técnica. <a href="#faq-masajes" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">Resuelve tus dudas aquí</a>.
    </p>
  </section>

  <!-- CÓMO ACTÚA -->
  <section class="py-20 bg-[#243c5a] text-white px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-white/70">¿Cómo actúa el Masaje Ayurvédico?</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
        <div class="text-center">
          <div class="w-20 h-20 bg-[#6ed8d9]/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🌿</span>
          </div>
          <h3 class="text-lg font-bold text-[#6ed8d9] mb-3">A Nivel Físico</h3>
          <p class="text-white/70 text-sm">
            Los aceites medicinales calientes penetran en los tejidos, disuelven toxinas (Ama), alivian tensiones musculares crónicas y nutren articulaciones y sistema nervioso periférico.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-[#6ed8d9]/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">⚡</span>
          </div>
          <h3 class="text-lg font-bold text-[#6ed8d9] mb-3">A Nivel Energético</h3>
          <p class="text-white/70 text-sm">
            La estimulación de los Puntos Marma reactiva los centros de energía vital, equilibra los tres Doshas (Vata, Pitta, Kapha) y elimina bloqueos en los canales Nadis.
          </p>
        </div>

        <div class="text-center">
          <div class="w-20 h-20 bg-[#6ed8d9]/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <span class="text-3xl">🧠</span>
          </div>
          <h3 class="text-lg font-bold text-[#6ed8d9] mb-3">A Nivel Emocional</h3>
          <p class="text-white/70 text-sm">
            El contacto terapéutico consciente y la acción de los aceites sobre el sistema nervioso inducen un estado de calma profunda, facilitando la liberación de emociones almacenadas en el cuerpo.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- LO QUE INCLUYE -->
  <section class="py-20 bg-white px-6">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Tu Protocolo de Sanación</h2>
      <p class="text-[#243c5a]/80">Una sesión diseñada desde el diagnóstico Ayurvédico hasta el cierre energético.</p>
