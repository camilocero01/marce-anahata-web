---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import ReviewsSection from '../components/cards/ReviewsSection.astro';
import UpcomingEventsGrid from '../components/UpcomingEventsTimeline.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import terapiaSonidoImg from '../assets/terapia-sonido-2.webp';
import ritualesImg from '../assets/ritual/rituales.webp';
import circuloMujeresImg from '../assets/circulo-mujeres-conscientes-home.jpg';
import bienestarcorporativoImg from '../assets/corporativo/bienestar-corporativo-3.webp';
import homeYogaImg from '../assets/home-yoga.webp';
import masajesImg from '../assets/marmaterapia/terapeuta-puntos-marma-ayurveda.png';
import heroBgImg from '../assets/hero-bg.webp';
import marcePerfilImg from '../assets/marce-perfil.webp';

// Obtener últimos 3 posts del blog (solo español)
const allPosts = (await getCollection('blog', ({ data, slug }) => !data.draft && !slug.startsWith('en/')))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// Datos de servicios
const pageTitle = "Kundalini Yoga, Baño de Gong y Terapia de Sonido en Medellín";
const pageDescription = "Centro de bienestar en Envigado, a 2 cuadras de El Poblado. Baños de gong, terapia de sonido, Kundalini Yoga, rituales sagrados y bienestar corporativo.";

const serviciosHome = [
  {
    titulo: "Terapia de Sonido",
    descripcion: "Recupera tu armonía celular. A través de la vibración del Gong y cuencos, liberamos bloqueos energéticos y llevamos a tu sistema nervioso a un estado de paz profunda que el sueño profundo no siempre logra.",
    link: "/terapia-sonido",
    imagen: terapiaSonidoImg
  },
  {
    titulo: "Rituales Sagrados",
    descripcion: "En la vida, cada ciclo que comienza o termina merece ser honrado con presencia y consciencia. En nuestro centro, creamos altares vivos y atmósferas sagradas para que celebres la vida con sentido.",
    link: "/rituales", 
    imagen: ritualesImg
  },
  {
    titulo: "Círculo de Mujeres",
    descripcion: "Encuentros mensuales para sanar en tribu, activar tu voz interna y fortalecer tu sistema nervioso.",
    link: "/circulo-mujeres-conscientes", 
    imagen: circuloMujeresImg
  },
  {
    titulo: "Bienestar Empresarial",
    descripcion: "Lleva el equilibrio a tu equipo de trabajo con pausas conscientes y talleres de manejo de estrés.",
    link: "/bienestar-corporativo", 
    imagen: bienestarcorporativoImg
  },
  {
    titulo: "Clases de Yoga",
    descripcion: "Fortalece tu mente, habita tu cuerpo con consciencia. Kundalini, Yin, Restaurativo, Yogalates, Vinyasa y más — prácticas para todos los niveles que despiertan tu vitalidad y calman tu sistema nervioso.",
    link: "/clases",
    imagen: homeYogaImg
  },
  {
    titulo: "Masajes Ayurvédicos y Puntos Marma",
    descripcion: "Sana desde la raíz. Una terapia milenaria que desintoxica tu cuerpo y libera la tensión acumulada, restaurando el flujo de tu energía vital.",
    link: "/masajes-ayurvedicos",
    imagen: masajesImg
  }
];

const ogImage = '/images/social-preview-wa.jpg';

const homeFaqItems = [
  {
    question: '¿Qué es un baño de gong y para qué sirve?',
    answer: 'El baño de gong es una terapia de sonido en la que te recuestas y recibes las frecuencias del gong directamente en el cuerpo. Actúa sobre el sistema nervioso, reduce el estrés y la ansiedad, mejora el sueño y libera tensión acumulada. No requiere experiencia previa — solo llegar, acostarse y recibir.'
  },
  {
    question: '¿Dónde está ubicado el Centro de Bienestar Marce Anahata?',
    answer: 'Estamos en Envigado, zona La Frontera con El Poblado (Cl. 23 Sur #42B-60, Los Cristales). A 2 minutos de El Poblado, con fácil acceso desde Medellín.'
  },
  {
    question: '¿Necesito experiencia previa para las clases de yoga?',
    answer: 'No. Todas las clases se adaptan a tu nivel. Ofrecemos Kundalini Yoga, Yin, Restaurativo, Yogalates y Vinyasa — prácticas para principiantes y practicantes avanzados. Solo necesitas ropa cómoda y disposición.'
  },
  {
    question: '¿Qué tipos de rituales sagrados ofrecen?',
    answer: 'Ofrecemos rituales personalizados para distintos momentos de vida: Ritual de Cumpleaños (Vuelta al Sol), Ritual de Pareja, Baby Blessing, Despedida de Soltera Consciente y Ritual de Cierre y Apertura de Ciclo. Cada ceremonia incluye terapia de sonido y se diseña según tu intención.'
  },
  {
    question: '¿Cómo reservo una sesión o clase?',
    answer: 'Puedes reservar directamente por WhatsApp al +57 320 732 9921. También puedes escribir desde el formulario de contacto del sitio. Para rituales sagrados se requiere un anticipo del 50% para separar la fecha.'
  }
];
---

<Layout title={pageTitle} description={pageDescription} image={ogImage}>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "SportsActivityLocation"],
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Centro de Bienestar",
      "description": "Centro de bienestar en Envigado (La Frontera con El Poblado) especializado en terapia de sonido, baños de gong, Kundalini Yoga, rituales sagrados, círculos de mujeres conscientes y masajes ayurvédicos.",
      "url": "https://www.marceanahata.com",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "image": "https://www.marceanahata.com/images/social-preview-wa.jpg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
        "addressLocality": "Envigado",
        "addressRegion": "Antioquia",
        "postalCode": "055420",
        "addressCountry": "CO"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "14:00" }
      ],
      "sameAs": ["https://www.instagram.com/marce_anahata/", "https://www.youtube.com/@marce_anahata", "https://www.tiktok.com/@marce_anahata"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Servicios de Bienestar",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Terapia de Sonido", "url": "https://www.marceanahata.com/terapia-sonido" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Baño de Gong", "url": "https://www.marceanahata.com/bano-de-gong" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kundalini Yoga y Clases", "url": "https://www.marceanahata.com/clases" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Rituales Sagrados", "url": "https://www.marceanahata.com/rituales" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Círculo de Mujeres Conscientes", "url": "https://www.marceanahata.com/circulo-mujeres-conscientes" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Masajes Ayurvédicos y Puntos Marma", "url": "https://www.marceanahata.com/masajes-ayurvedicos" } }
        ]
      }
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://www.marceanahata.com/#person",
      "name": "Marce Anahata",
      "jobTitle": "Facilitadora de Bienestar Integral, Instructora de Kundalini Yoga",
      "url": "https://www.marceanahata.com/sobre-mi",
      "worksFor": { "@id": "https://www.marceanahata.com/#business" },
      "sameAs": ["https://www.instagram.com/marce_anahata/", "https://www.youtube.com/@marce_anahata", "https://www.tiktok.com/@marce_anahata"]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://www.marceanahata.com/#website",
      "name": "Marce Anahata",
      "url": "https://www.marceanahata.com",
      "description": "Sitio oficial de Marce Anahata — Centro de bienestar en Envigado, La Frontera con El Poblado, Medellín.",
      "publisher": { "@id": "https://www.marceanahata.com/#business" },
      "inLanguage": ["es", "en"]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": homeFaqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer }
      }))
    })}</script>
    <meta property="og:locale" content="es_CO" />
  </Fragment>

  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        preload="auto"
        poster="/images/hero-bg.webp"
        class="w-full h-full object-cover opacity-60"
      >
        <source src="/videos/hero-bg.webm" type="video/webm" />
        <source src="/videos/hero-bg.mp4" type="video/mp4" />
        <Image 
          src={heroBgImg} 
          alt="Fondo meditación" 
          class="w-full h-full object-cover"
          width={1920}
          height={1080}
          densities={[1.5, 2]}
          loading="eager"
          fetchpriority="high"
        />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-stone-100/30 to-stone-100/90 z-10"></div>
    </div>

    <div class="relative z-20 text-center px-6 max-w-4xl mx-auto mt-10">
      <span class="block text-marce-base-1 uppercase tracking-[0.3em] text-sm mb-4 animate-fade-in-up font-bold">Bienestar Integral</span>
      <h1 class="text-5xl md:text-7xl text-marce-base-3 mb-6 leading-tight font-serif">
        De la pausa <br/> <span class="italic text-marce-base-1">nace tu poder.</span>
      </h1>
      <p class="text-xl text-marce-base-3/80 mb-10 max-w-2xl mx-auto font-light">
        En un mundo lleno de ruido, te ofrecemos un refugio sagrado para silenciar la mente, sanar el cuerpo y elevar tu vibración. Acompañamos tu proceso de transformación integral a través de la tecnología del yoga, el sonido y el bienestar consciente.
      </p>
      
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <a href="/rituales" class="btn-claro">
          Ver Rituales
        </a>
        
        <a href="#servicios" class="px-8 py-3 rounded-lg border border-marce-base-1 text-marce-base-1 hover:bg-marce-base-2 hover:text-white hover:border-marce-base-2 transition duration-300 font-semibold">
          Explorar Servicios
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="md:w-1/2">
        <div class="aspect-[4/5] bg-stone-100 rounded-2xl overflow-hidden relative shadow-xl border border-marce-base-2/30">
           <Image 
             src={marcePerfilImg} 
             alt="Marce Anahata" 
             class="object-cover h-full w-full"
             width={634}
             height={1135}
             densities={[1.5, 2]}
           />
        </div>
      </div>
      <div class="md:w-1/2">
        <h2 class="text-4xl text-marce-base-3 mb-6 font-serif">Tu puente hacia la sabiduría interna.</h2>
        <p class="text-lg text-marce-base-3/80 mb-6 leading-relaxed">
          Hola, soy Marce Anahata. Mi camino no empezó como una profesión, sino como una búsqueda profunda de propósito. Hoy, entiendo el bienestar no como un lujo, sino como una necesidad fundamental.
        </p>
        <p class="text-lg text-marce-base-3/80 mb-8 leading-relaxed">
          No soy una gurú; soy una facilitadora que pone a tu disposición herramientas científicas y ancestrales para que tú mismo te conviertas en tu propio maestro. En nuestro centro, no hay etiquetas de edad, género o condición física: solo seres humanos buscando regresar a casa, a su propio corazón.
        </p>
        <div class="flex gap-8 text-marce-base-1 font-serif italic text-lg border-t border-marce-base-2/50 pt-6">
          <span>Kundalini Yoga</span>
          <span>•</span>
          <span>Sound Healing</span>
          <span>•</span>
          <span>Rituales</span>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="py-24 px-6 bg-stone-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl text-marce-base-1 mb-4 font-serif">Mis Servicios</h2>
        <p class="text-marce-base-3/70 max-w-xl mx-auto">Caminos diseñados para tu bienestar físico, mental y espiritual.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {serviciosHome.map((servicio) => (
          <a href={servicio.link} class="group block bg-white p-6 shadow-sm hover:shadow-xl transition-all duration-300 rounded-2xl border border-transparent hover:border-marce-base-2/30 flex flex-col">
            <div class="h-48 bg-stone-200 mb-6 overflow-hidden rounded-xl shrink-0">
              <Image 
                src={servicio.imagen} 
                alt={servicio.titulo} 
                class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                width={550}
                height={357}
                densities={[1.5, 2]}
                loading="lazy"
              />
            </div>
            <h3 class="text-xl text-marce-base-3 mb-3 font-serif group-hover:text-marce-base-1 transition-colors">{servicio.titulo}</h3>
            <p class="text-marce-base-3/70 leading-relaxed mb-4 font-light text-sm flex-grow">{servicio.descripcion}</p>
            <span class="text-sm font-semibold text-marce-base-1 group-hover:text-marce-base-2 transition-colors mt-auto block">Saber más &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════ VIAJE DE LAS 450 VIBRACIONES ══════════════════ -->
  <section class="relative py-24 px-6 bg-[#243c5a] overflow-hidden">
    <!-- Destellos de fondo -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#6ed8d9] rounded-full filter blur-[140px] opacity-10 pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#5d5a8c] rounded-full filter blur-[140px] opacity-15 pointer-events-none"></div>

    <div class="max-w-6xl mx-auto relative z-10">

      <!-- Cabecera -->
      <div class="text-center mb-14">
        <span class="uppercase tracking-[0.25em] text-xs text-[#6ed8d9] font-bold block mb-4">
          Baño de Gong Mensual · Medellín 2026
        </span>
        <h2 class="text-3xl md:text-5xl font-serif text-white mb-5 leading-tight">
          El Viaje de las<br class="md:hidden" /> <span class="text-[#6ed8d9]">450 Vibraciones</span>
        </h2>
        <p class="text-white/65 max-w-xl mx-auto leading-relaxed">
          9 sesiones de baño de gong distribuidas mes a mes a lo largo de 2026 — cada una con un elemento y una intención distinta. La profundidad de una Puja de Gong tradicional, vivida a tu ritmo.
        </p>

        <!-- Indicador de 9 meses -->
        <div class="flex justify-center gap-2 mt-8 flex-wrap">
          {['Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'].map((m, i) => (
            <div class="flex flex-col items-center gap-1">
              <div class={`w-3 h-3 rounded-full ${i < 3 ? 'bg-[#6ed8d9]' : 'bg-white/20'}`}></div>
              <span class={`text-[9px] uppercase tracking-wider ${i < 3 ? 'text-[#6ed8d9]' : 'text-white/30'}`}>{m}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Las 3 sesiones disponibles -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-10">
        {[
          { num: 1, mes: 'Abril · 24 abr', emoji: '🌱', nombre: 'La Semilla y el Silencio', elemento: 'Tierra', slug: '12-viaje-450-vibraciones-abril-2026' },
          { num: 2, mes: 'Mayo · 22 may',  emoji: '💧', nombre: 'Limpieza de Aguas',         elemento: 'Agua',  slug: '13-viaje-450-vibraciones-mayo-2026'  },
          { num: 3, mes: 'Junio · 26 jun', emoji: '🔥', nombre: 'El Solsticio y el Fuego Interno', elemento: 'Fuego', slug: '14-viaje-450-vibraciones-junio-2026' },
        ].map(s => (
          <a
            href={`/blog/${s.slug}`}
            class="group bg-white/5 border border-white/10 hover:border-[#6ed8d9]/50 hover:bg-white/10 rounded-2xl p-6 transition-all duration-300"
          >
            <div class="flex items-center gap-2 mb-3">
              <span class="w-6 h-6 rounded-full bg-[#6ed8d9]/20 text-[#6ed8d9] text-xs font-bold flex items-center justify-center flex-shrink-0">{s.num}</span>
              <span class="text-[#6ed8d9] text-xs font-bold uppercase tracking-widest">{s.mes}</span>
            </div>
            <div class="text-2xl mb-2">{s.emoji}</div>
            <h3 class="font-serif text-white text-lg leading-tight mb-1 group-hover:text-[#6ed8d9] transition-colors">{s.nombre}</h3>
            <p class="text-white/40 text-xs uppercase tracking-wider mb-4">{s.elemento}</p>
            <span class="text-xs font-semibold text-[#6ed8d9]/70 group-hover:text-[#6ed8d9] flex items-center gap-1 transition-colors">
              Ver detalles y reservar
              <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Precio + CTA -->
      <div class="flex flex-col md:flex-row items-center justify-between gap-6 bg-white/5 border border-white/10 rounded-2xl px-8 py-6">
        <div class="text-center md:text-left">
          <p class="text-white/50 text-xs uppercase tracking-widest mb-1">Inversión por sesión</p>
          <p class="text-white font-serif text-2xl">$120.000 <span class="text-base font-sans font-normal text-white/60">COP / persona</span></p>
          <p class="text-[#6ed8d9] text-sm mt-1">$90.000 COP por persona si vienes en dúo</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3">
          <a
            href="/viaje-450-vibraciones"
            class="bg-[#6ed8d9] text-[#243c5a] px-7 py-3 rounded-full font-bold hover:bg-white transition-all text-sm shadow-lg text-center"
          >
            Ver el viaje completo
          </a>
          <a
            href="https://wa.me/573207329921?text=Hola%20Marce%20Anahata%2C%20quiero%20reservar%20mi%20lugar%20en%20El%20Viaje%20de%20las%20450%20Vibraciones."
            target="_blank"
            class="border border-white/25 text-white px-7 py-3 rounded-full font-medium hover:border-[#6ed8d9] hover:text-[#6ed8d9] transition-all text-sm text-center"
          >
            Reservar por WhatsApp
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════ BAÑO DE GONG ════════════════════════ -->
  <section class="py-20 bg-stone-50 px-6">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
      <div class="md:w-2/5 flex-shrink-0">
        <img
          src="/images/blog/8/home-bano-de-gong-.jpg"
          alt="Baño de gong en Medellín — Marce Anahata"
          class="rounded-2xl shadow-lg w-full object-cover aspect-[4/3]"
          loading="lazy"
        />
      </div>
      <div class="md:w-3/5">
        <span class="uppercase tracking-widest text-xs text-[#5d5a8c] font-bold block mb-3">Servicio permanente</span>
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4 leading-tight">
          Baño de Gong en Medellín
        </h2>
        <p class="text-[#243c5a]/70 mb-5 leading-relaxed">
          Una experiencia de sonido terapéutico en la que te recuestas y recibes las frecuencias del gong directamente en el cuerpo. Sin esfuerzo. Sin técnica. El sistema nervioso descansa, la mente suelta y algo que no sabías que cargabas se libera.
        </p>
        <ul class="space-y-2 text-sm text-[#243c5a]/70 mb-7">
          <li class="flex gap-3 items-start"><span class="text-[#6ed8d9] mt-0.5">✓</span> Sesiones en Envigado, zona La Frontera con El Poblado — máximo 15 personas</li>
          <li class="flex gap-3 items-start"><span class="text-[#6ed8d9] mt-0.5">✓</span> $120.000 COP individual · $90.000 en dúo</li>
          <li class="flex gap-3 items-start"><span class="text-[#6ed8d9] mt-0.5">✓</span> Sin experiencia previa necesaria</li>
        </ul>
        <a
          href="/bano-de-gong"
          class="inline-block bg-[#243c5a] text-white px-7 py-3 rounded-full font-semibold hover:bg-[#5d5a8c] transition-colors text-sm"
        >
          Qué es un baño de gong →
        </a>
      </div>
    </div>
  </section>

  <!-- Sección de Próximos Eventos -->
  <section id="eventos" class="scroll-mt-24">
    <UpcomingEventsGrid />
  </section>

  <ReviewsSection />

  <!-- Sección Blog - Últimos Posts -->
  {allPosts.length > 0 && (
    <section class="py-24 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl text-marce-base-1 mb-4 font-serif">Artículos Recientes</h2>
          <p class="text-marce-base-3/70 max-w-xl mx-auto mb-8">Consejos y reflexiones sobre bienestar, yoga y transformación personal.</p>
          <a href="/blog" class="inline-flex items-center gap-2 text-marce-base-1 hover:text-marce-base-2 font-semibold transition-colors">
            Ver todos los artículos
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {allPosts.map(post => (
            <article class="bg-stone-50 rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-stone-200 hover:border-marce-base-2/30 flex flex-col group">
              {post.data.image && (
                <a href={`/blog/${post.slug}`} class="overflow-hidden h-48">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="p-6 flex flex-col flex-grow">
                <div class="text-sm text-marce-base-3/80 mb-3">
                  {new Date(post.data.pubDate).toLocaleDateString('es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
                <h3 class="text-xl text-marce-base-3 mb-3 font-serif group-hover:text-marce-base-1 transition-colors leading-tight">
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                </h3>
                <p class="text-marce-base-3/70 text-sm leading-relaxed mb-4 flex-grow">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="text-xs bg-marce-base-2/10 text-marce-base-1 px-2 py-1 rounded-full">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
                <a href={`/blog/${post.slug}`} class="text-marce-base-1 font-semibold text-sm group-hover:text-marce-base-2 transition-colors inline-flex items-center gap-1 mt-auto">
                  Leer más
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 text-center">
          <a href="/blog" class="inline-block px-6 py-3 border-2 border-marce-base-1 text-marce-base-1 rounded-lg hover:bg-marce-base-1 hover:text-white transition-all font-semibold">
            Explorar Todos los Artículos
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  <section class="py-20 px-6 bg-gradient-to-b from-stone-50 to-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#243c5a] mb-4">
          Preguntas frecuentes
        </h2>
        <p class="text-stone-600 max-w-2xl mx-auto">
          Todo lo que necesitas saber antes de tu primera sesión.
        </p>
      </div>

      <div class="space-y-3">
        {homeFaqItems.map((item) => (
          <details class="group bg-white rounded-xl border border-stone-100 shadow-sm hover:border-[#6ed8d9]/40 transition-colors">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
              <h3 class="text-base font-semibold text-[#243c5a]">{item.question}</h3>
              <svg class="w-5 h-5 text-[#5d5a8c] shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="px-6 pb-5 text-[#243c5a]/75 leading-relaxed text-sm border-t border-stone-100 pt-4">{item.answer}</p>
          </details>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/faq"
          class="inline-block px-8 py-3 border-2 border-[#243c5a] text-[#243c5a] rounded-full font-semibold hover:bg-[#243c5a] hover:text-white transition-all"
        >
          Ver todas las preguntas frecuentes
        </a>
      </div>
    </div>
  </section>

</Layout>