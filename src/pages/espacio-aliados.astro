            alt="Salón de yoga y movimiento — Espacio Anahata, Envigado"
            class="rounded-2xl shadow-xl relative z-10 w-full h-[480px] object-cover"
          />
        </div>
        <div>
          <span class="uppercase tracking-widest text-xs text-[#6ed8d9] font-bold block mb-3">Ambiente 1</span>
          <h3 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Salón de Movimiento</h3>
          <p class="text-[#243c5a]/75 mb-6 leading-relaxed">
            35 m² diseñados para el movimiento consciente. Todo lo que necesitas para tu clase, taller o evento ya está aquí — solo llegas y empiezas.
          </p>
