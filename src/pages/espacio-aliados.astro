      </div>

      <!-- Salón de movimiento -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center mb-24">
        <div class="relative">
          <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[#6ed8d9]/30 rounded-2xl z-0"></div>
