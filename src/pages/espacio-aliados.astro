          <div class="px-6 py-4 bg-stone-50 border-t border-stone-100">
            <p class="text-xs text-stone-500 leading-relaxed">Genera ingreso recurrente estable para el espacio y descuento garantizado para ti. Cupos limitados.</p>
          </div>
        </div>

      </div>

      <!-- Política de reserva -->
      <div class="mt-10 bg-[#243c5a]/5 rounded-2xl p-6 border border-[#243c5a]/10">
