---
import Layout from '../layouts/Layout.astro';

const wa = (msg: string) => `https://wa.me/573207329921?text=${encodeURIComponent(msg)}`;

const whatsappLink      = wa("Hola Marce Anahata, estoy interesado/a en el Espacio Anahata. ¿Me puedes dar información sobre disponibilidad y tarifas?");
const whatsappSalon     = wa("Hola Marce Anahata, me interesa reservar el Salón de Movimiento del Espacio Anahata. ¿Cuál es la disponibilidad y cómo confirmo la reserva?");
const whatsappConsultorio = wa("Hola Marce Anahata, me interesa reservar el Consultorio Holístico del Espacio Anahata. ¿Cuál es la disponibilidad y cómo confirmo la reserva?");
const whatsappVisita    = wa("Hola Marce Anahata, me gustaría agendar una visita sin costo al Espacio Anahata para conocerlo. ¿Cuándo tienen disponibilidad?");
const serviceUrl = 'https://www.marceanahata.com/espacio-aliados';

const stats = [
  { value: "67 m²", label: "Espacio total" },
  { value: "2", label: "Ambientes independientes" },
  { value: "20", label: "Personas — capacidad salón" },
  { value: "Privado", label: "Parqueadero cubierto y gratuito" },
  { value: "Estrato 6", label: "La Frontera · Envigado" },
];

const salonFeatures = [
  "20 mats de yoga · 12 zafus · 12 bolsters · 20 ladrillos",
  "10 balones y 10 aros de pilates",
  "8 pares de pesas encauchetadas de 1 lb",
  "Barra de barre de casi 5 metros",
  "3 espejos con retroiluminación",
  "Aire acondicionado",
  "Bose S1 Plus — sonido de alta fidelidad",
  "Luces LED inteligentes para ambientar eventos",
  "6 ventanales con vinilo esmerilado de diseño elegante",
];

const consulторioFeatures = [
  "Camilla de masajes profesional",
  "2 poltronas individuales para terapia",
  "Biblioteca decorativa con retroiluminación",
  "Mesa de centro con decoración de alto nivel",
  "Ambiente íntimo y privado",
];

const amenidades = [
  { icon: "🚗", label: "Parqueadero cubierto privado y gratuito", desc: "Un diferencial real en La Frontera — sin estrés de parqueo para ti ni tus clientes." },
  { icon: "🎵", label: "Bose S1 Plus", desc: "Sonido de alta fidelidad para clases, talleres, meditaciones y eventos." },
  { icon: "💡", label: "Luces LED inteligentes", desc: "Crea el ambiente exacto que tu sesión o evento necesita." },
  { icon: "🪟", label: "Ventanales con vinilo esmerilado", desc: "6 grandes ventanales con diseño elegante: luz natural difusa y privacidad total." },
  { icon: "💧", label: "Dispensador Agualogic", desc: "Agua fría y caliente siempre disponible para ti y tus participantes." },
  { icon: "☕", label: "Cocineta equipada", desc: "Calentador de agua, vasos y pocillos — ideal para infusiones en talleres." },
  { icon: "❄️", label: "Aire acondicionado", desc: "Temperatura óptima durante todo el año." },
  { icon: "🌿", label: "Decoración de interiores de alto nivel", desc: "Materas grandes de diseño y una estética cuidada que proyecta profesionalismo." },
];

const perfiles = [
  { icon: "🧘", titulo: "Instructoras de yoga, pilates y barre", desc: "Espacio completamente equipado para tus clases. Tus clientes llegan, tú enseñas." },
  { icon: "🤲", titulo: "Terapeutas y masajistas", desc: "Consultorio holístico privado con camilla y ambiente profesional de alto nivel." },
  { icon: "💬", titulo: "Psicólogos, coaches y nutricionistas", desc: "Espacio íntimo y cálido para sesiones de consulta y acompañamiento terapéutico." },
  { icon: "📚", titulo: "Facilitadores de talleres y formaciones", desc: "Salón amplio con sonido Bose, luces inteligentes y equipamiento completo." },
  { icon: "📸", titulo: "Fotógrafos y creadores de contenido", desc: "Espejos con retroiluminación, luces LED y estética de alto nivel para tu shoot de marca." },
  { icon: "✨", titulo: "Organizadores de eventos wellness", desc: "Capacidad para retiros urbanos, ceremonias, círculos y experiencias colectivas de hasta 20 personas." },
];

const tarifasSalon = [
  { desc: "Por hora", precio: "$85.000", nota: "Mínimo 2 horas" },
  { desc: "Medio día — 4 horas", precio: "$300.000", nota: "Ideal para talleres y clases", highlight: true },
  { desc: "Día completo — 8 horas", precio: "$520.000", nota: "Ideal para formaciones y eventos de jornada completa" },
  { desc: "Sesión de fotografía / contenido", precio: "$120.000/hora", nota: "Mínimo 2 horas" },
];

const tarifasConsultorio = [
  { desc: "Por hora", precio: "$55.000", nota: "Mínimo 2 horas · Sin compromiso" },
  { desc: "Franja fija semanal", precio: "$550.000/mes", nota: "Ej. todos los martes 10am–2pm · Tu horario reservado permanentemente", highlight: true },
  { desc: "Franja fija quincenal", precio: "$300.000/mes", nota: "2 días al mes en horario fijo · Prepago mensual" },
];

const tarifasAliado = [
  { desc: "Paquete 8 horas/mes", precio: "$580.000", nota: "En bloques de 2h · ~15% de descuento", highlight: true },
  { desc: "Paquete 16 horas/mes", precio: "$1.050.000", nota: "En bloques de 2h · ~18% de descuento" },
];

const faqItems = [
  {
    question: "¿Cuál es el tiempo mínimo de reserva?",
    answer: "El mínimo es de 2 horas continuas por reserva, tanto para el salón como para el consultorio."
  },
  {
    question: "¿Cómo se confirma la reserva?",
    answer: "La reserva se confirma con el 50% del valor total. El saldo restante debe pagarse 48 horas antes de la sesión."
  },
  {
    question: "¿Cuál es la política de cancelación?",
    answer: "Reembolso completo con 48 horas de anticipación. Con menos de 24 horas, no hay reembolso. Entre 24 y 48 horas, reembolso del 50%."
  },
  {
    question: "¿Puedo visitar el espacio antes de reservar?",
    answer: "Sí. Puedes agendar una visita de 30 minutos sin costo para conocer el espacio y decidir si es el lugar indicado para ti."
  },
  {
    question: "¿El equipamiento está incluido en la tarifa?",
    answer: "Sí. El uso de todo el equipamiento del salón está incluido: mats, zafus, bolsters, balones, aros, barre, pesas, ladrillos, sonido Bose y luces LED."
  },
  {
    question: "¿Puedo usar el espacio los fines de semana?",
    answer: "Sí. Los sábados y domingos tienen amplia disponibilidad y son especialmente ideales para talleres, formaciones y eventos de jornada completa."
  },
  {
    question: "¿Dónde puedo alquilar un espacio para clases de yoga o talleres en Medellín?",
    answer: "El Espacio Anahata está en La Frontera con El Poblado, Envigado (Cl. 23 Sur #42B-60). Es un salón holístico de 67 m² completamente equipado para yoga, pilates, barre, talleres y eventos wellness. Incluye parqueadero cubierto privado y gratuito, sonido Bose S1 Plus, luces LED inteligentes y un consultorio holístico independiente. Disponible de lunes a domingo previa reserva por WhatsApp."
  },
  {
    question: "¿Cuánto cuesta alquilar un espacio wellness en El Poblado o Envigado?",
    answer: "En el Espacio Anahata las tarifas son: salón de movimiento desde $85.000 COP por hora (mínimo 2 horas), medio día —4 horas— por $300.000 COP, y día completo —8 horas— por $520.000 COP. El consultorio holístico desde $55.000 COP por hora. Existen paquetes de aliado mensual con descuento de hasta el 18%."
  },
  {
    question: "¿El Espacio Anahata tiene parqueadero?",
    answer: "Sí. El espacio cuenta con parqueadero cubierto, privado y totalmente gratuito para el profesional y sus clientes. Está ubicado en Cl. 23 Sur #42B-60, Los Cristales, Envigado — zona La Frontera con El Poblado."
  },
  {
    question: "¿Cuántas personas caben en el salón de yoga?",
    answer: "El salón de movimiento del Espacio Anahata tiene capacidad para hasta 20 personas. Cuenta con 20 mats de yoga, 12 zafus, 12 bolsters, 10 balones de pilates, 10 aros, barra de barre de casi 5 metros y 3 espejos con retroiluminación."
  },
  {
    question: "¿Dónde está ubicado exactamente el Espacio Anahata?",
    answer: "El Espacio Anahata está en Cl. 23 Sur #42B-60, Los Cristales, Envigado, Antioquia — en la zona La Frontera, en el límite entre El Poblado (Medellín) y Envigado. Es una zona residencial estrato 6 con alto poder adquisitivo. La ubicación exacta y el acceso al parqueadero se comparten al confirmar la reserva por WhatsApp."
  },
];
---

