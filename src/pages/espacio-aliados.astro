    <div class="relative z-20 text-center text-white px-6 max-w-4xl mx-auto mt-16">
      <span class="uppercase tracking-[0.25em] text-sm md:text-base mb-5 block font-bold text-[#6ed8d9]">
        La Frontera con El Poblado · Envigado · Estrato 6
      </span>
