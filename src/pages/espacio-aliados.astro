        </div>
        <div class="bg-white rounded-xl border border-[#6ed8d9]/30 shadow-sm p-8 relative overflow-hidden">
          <div class="absolute top-0 right-0 bg-[#6ed8d9] text-[#243c5a] text-xs font-bold px-3 py-1 rounded-bl-lg">Más disponibilidad</div>
          <div class="flex items-center gap-3 mb-6">
            <span class="text-2xl">✨</span>
            <h3 class="text-xl font-serif text-[#243c5a]">Sábados y Domingos</h3>
          </div>
          <div class="space-y-3">
            <div class="flex justify-between items-center py-3 border-b border-stone-100">
              <span class="text-[#243c5a]/80 text-sm">Mañana</span>
              <span class="font-semibold text-[#5d5a8c]">8:00 AM – 1:00 PM</span>
            </div>
            <div class="flex justify-between items-center py-3">
              <span class="text-[#243c5a]/80 text-sm">Tarde</span>
              <span class="font-semibold text-[#5d5a8c]">2:00 PM – 8:00 PM</span>
            </div>
          </div>
          <p class="mt-4 text-xs text-stone-400">Ideal para talleres, formaciones y eventos de jornada completa</p>
        </div>
      </div>
    </div>
  </section>

  <!-- TARIFAS -->
  <section class="py-20 bg-white px-6" id="tarifas">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <span class="uppercase tracking-[0.2em] text-sm text-[#5d5a8c] font-bold block mb-3">Inversión</span>
