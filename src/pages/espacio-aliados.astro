  <!-- HERO -->
  <section class="relative h-[85vh] flex items-center justify-center overflow-hidden">
    <img
      src="https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=1800&q=80"
      alt="Espacio Anahata — salón holístico para profesionales wellness en Envigado"
      class="absolute inset-0 w-full h-full object-cover z-0"
    />
