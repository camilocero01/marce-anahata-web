        <p class="text-[#243c5a]/70 max-w-2xl mx-auto">Sin costos ocultos. El equipamiento completo está incluido en todas las tarifas.</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

        <!-- Salón -->
        <div class="rounded-2xl border border-stone-200 overflow-hidden shadow-sm">
          <div class="bg-[#243c5a] px-6 py-5">
            <h3 class="text-lg font-serif text-white">🧘 Salón de Movimiento</h3>
            <p class="text-white/60 text-sm mt-1">Con todo el equipamiento incluido</p>
