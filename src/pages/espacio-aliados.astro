                  <div>
                    <p class="font-semibold text-[#243c5a] text-sm">{t.desc}</p>
                    <p class="text-xs text-stone-400 mt-0.5">{t.nota}</p>
                  </div>
                  <p class="font-bold text-[#5d5a8c] shrink-0 text-sm">{t.precio}</p>
                </div>
                {t.highlight && <span class="mt-2 inline-block text-xs bg-[#6ed8d9]/20 text-[#243c5a] px-2 py-0.5 rounded-full font-semibold">Recomendado</span>}
