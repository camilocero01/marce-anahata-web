            {salonFeatures.map((f) => (
              <li class="flex items-start gap-3 text-[#243c5a]/80 text-sm">
                <span class="text-[#6ed8d9] mt-0.5 shrink-0">✓</span>
                {f}
              </li>
            ))}
          </ul>
          <a
            href={whatsappSalon}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-block bg-[#243c5a] text-white px-6 py-3 rounded-full font-semibold text-sm hover:bg-[#5d5a8c] transition-all"
