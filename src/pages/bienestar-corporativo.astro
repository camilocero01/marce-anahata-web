---
// src/pages/bienestar-corporativo.astro
import Layout from '../layouts/Layout.astro';
import ReviewsSection from '../components/cards/ReviewsSection.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import bienestarCorporativoImg from '../assets/corporativo/bienestar-corporativo-2.webp';

// --- DATOS DEL SERVICIO ---
const serviceInfo = {
  title: "Bienestar Corporativo: Equipos Conscientes",
  subtitle: "Transforma el clima laboral llevando herramientas de mindfulness, yoga y gestión emocional al corazón de tu empresa. ",
  whatsappMessage: "Hola Marce Anahata, me interesa cotizar un taller de bienestar para mi empresa. Quisiera conversar sobre las opciones personalizadas."
};

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent(serviceInfo.whatsappMessage)}`; // CAMBIA EL NÚMERO
const serviceUrl = 'https://www.marceanahata.com/bienestar-corporativo';

const faqItems = [
  {
    question: '¿Qué es un programa de bienestar corporativo?',
    answer:
      'Es una intervención para equipos que integra mindfulness, respiración consciente, yoga y herramientas emocionales para reducir estrés y mejorar clima laboral.'
  },
  {
    question: '¿Qué tipo de empresas pueden contratar estos talleres?',
    answer:
      'Trabajamos con empresas pequeñas, medianas y grandes en Medellín y área metropolitana, adaptando la metodología al contexto de cada equipo.'
  },
  {
    question: '¿Qué resultados pueden esperar los equipos?',
    answer:
      'Los equipos suelen reportar reducción de burnout, mejor comunicación empática, mayor foco mental y mayor cohesión en periodos de alta carga.'
  },
  {
    question: '¿Las sesiones son en la empresa o en el centro de bienestar?',
    answer:
      'Ambas opciones están disponibles: en tu empresa o en el centro de bienestar en El Poblado, según objetivo, logística y número de participantes.'
  },
  {
    question: '¿Cómo solicito una propuesta personalizada?',
    answer:
      'Puedes solicitar una propuesta por WhatsApp desde esta página. Definimos objetivos, formato, duración y alcance según las necesidades de tu organización.'
  }
];

// 3 posts aleatorios con tags "burnout" o "bienestar corporativo"
const bienestarPosts = (await getCollection('blog', ({ data, slug }) =>
  !data.draft && !slug.startsWith('en/') && (data.tags.includes('burnout') || data.tags.includes('bienestar corporativo'))
))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout title="Bienestar Corporativo en Medellín — Yoga y Mindfulness para Empresas | Marce Anahata" description="Programas de bienestar corporativo en Medellín: yoga, terapia de sonido y mindfulness para equipos. Reduce el estrés laboral y mejora el clima organizacional.">
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.marceanahata.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Bienestar Corporativo",
          "item": "https://www.marceanahata.com/bienestar-corporativo"
        }
      ]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Programa de Bienestar Corporativo en Medellín",
      "description": "Talleres de bienestar corporativo en Medellín con mindfulness, yoga y gestión emocional para reducir burnout y fortalecer equipos conscientes.",
      "serviceType": "Corporate Wellness Program",
      "provider": {
        "@type": "Person",
        "name": "Marce Anahata",
        "url": "https://www.marceanahata.com/sobre-mi"
      },
      "areaServed": {
        "@type": "City",
        "name": "Medellín"
      },
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      },
      "url": serviceUrl,
      "keywords": "bienestar corporativo Medellín, burnout laboral, mindfulness para empresas, pausas activas conscientes, liderazgo consciente"
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })}</script>
  </Fragment>
  
  <section class="relative h-[60vh] flex items-center justify-center overflow-hidden">

    <video 
      class="absolute inset-0 w-full h-full object-cover z-0 opacity-90"
      autoplay 
      loop 
      muted 
      playsinline
      preload="metadata"
      poster="/images/bienestar-corporativo-poster.webp"
    >
      <source src="/videos/bienestar-corporativo.mp4" type="video/mp4" />
    </video>
    
    <div class="absolute inset-0 bg-black opacity-30 z-10"></div>

    <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto mt-16">
      <span class="uppercase tracking-[0.2em] text-sm md:text-base mb-4 block text-[#6ed8d9] font-bold">Integración & Liderazgo Consciente</span>
      <h1 class="text-3xl md:text-6xl font-serif mb-6 leading-tight">{serviceInfo.title}</h1>
      <p class="text-lg md:text-xl font-light max-w-3xl mx-auto mb-8 opacity-95 text-stone-100">
        {serviceInfo.subtitle}
      </p>
      <a 
        href={whatsappLink}
        target="_blank"
        data-event="whatsapp_click"
        data-label="Corporate Wellness Hero CTA"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-8 py-4 rounded-full font-bold hover:bg-white transition-all duration-300 transform hover:-translate-y-1 shadow-lg"
      >
        Solicitar Propuesta para mi Empresa
      </a>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="order-2 md:order-1 relative">
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[#5d5a8c]/20 rounded-xl z-0"></div>
        <Image 
          src={bienestarCorporativoImg} 
          alt="Pausa activa consciente en el trabajo" 
          class="rounded-xl shadow-xl relative z-10 w-full h-[400px] object-cover"
          width={600}
          height={400}
          densities={[1.5, 2]}
        />
      </div>
      <div class="order-1 md:order-2">
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-6">Más allá de la "Pausa Activa" tradicional</h2>
        <p class="text-[#243c5a]/80 mb-6 leading-relaxed text-lg">
          El estrés laboral y la desconexión entre equipos son los mayores enemigos de la productividad. Mis talleres no son solo un momento de relajación, son entrenamientos prácticos para la vida.
        </p>
        <p class="text-[#243c5a]/80 mb-8 leading-relaxed text-lg">
          Llevamos la tecnología del <a href="/clases" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">Yoga</a>, la Respiración Consciente y la <a href="/terapia-sonido" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">Terapia de Sonido</a> al entorno corporativo para brindar a tus colaboradores herramientas reales que pueden usar en su escritorio para gestionar la ansiedad, mejorar el foco y comunicarse con empatía.
        </p>
        <p class="text-[#243c5a]/80 mb-6 leading-relaxed text-lg">
          Atendemos en <strong>mi centro de bienestar en Medellín - El Poblado</strong> o nos desplazamos en el área metropolitana y todos los alrededores.
        </p>
        
        <div class="grid grid-cols-2 gap-4">
            <div class="flex items-center gap-2 text-[#5d5a8c] font-medium">
                <span class="text-[#6ed8d9] text-xl">✓</span> Reducción de Burnout
            </div>
            <div class="flex items-center gap-2 text-[#5d5a8c] font-medium">
                <span class="text-[#6ed8d9] text-xl">✓</span> Cohesión de Equipo
            </div>
            <div class="flex items-center gap-2 text-[#5d5a8c] font-medium">
                <span class="text-[#6ed8d9] text-xl">✓</span> Comunicación Empática
            </div>
            <div class="flex items-center gap-2 text-[#5d5a8c] font-medium">
                <span class="text-[#6ed8d9] text-xl">✓</span> Foco Mental
            </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-24 bg-stone-50 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <span class="text-[#5d5a8c] font-bold tracking-widest uppercase text-sm">Experiencia Inmersiva</span>
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mt-2 mb-4">Ejemplo de Jornada: "Conexión y Vitalidad"</h2>
        <p class="text-[#243c5a]/70">
            Un modelo de integración de media jornada (4 horas) diseñado para reconectar al equipo desde la raíz.
            <br><em>*Las agendas se personalizan según las necesidades de cada empresa.</em>
        </p>
      </div>

      <div class="relative border-l-2 border-[#5d5a8c]/20 ml-4 md:ml-0 space-y-8 pl-8 md:pl-0">
        
        <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">08:00 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">15 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-[#6ed8d9] shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-white p-6 rounded-xl shadow-sm border border-stone-100 group-hover:shadow-md transition-shadow">
                <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">08:00 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">15 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Inicio Energético y Palabras de Valor</h3>
                <p class="text-[#243c5a]/80 text-sm">Rompehielos consciente y alineación del propósito con un mensaje de la gerencia sobre el valor humano del equipo.</p>
            </div>
        </div>

        <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">08:15 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">60 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-[#5d5a8c] shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-white p-6 rounded-xl shadow-sm border border-stone-100 group-hover:shadow-md transition-shadow">
                 <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">08:15 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">60 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Yoga Flow: Foco y Alegría</h3>
                <p class="text-[#243c5a]/80 text-sm">Secuencia dinámica pero accesible (sin necesidad de experiencia previa) para despertar la vitalidad, corregir la postura de oficina y oxigenar el cerebro.</p>
            </div>
        </div>

        <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">09:15 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">45 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-[#6ed8d9] shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-white p-6 rounded-xl shadow-sm border border-stone-100 group-hover:shadow-md transition-shadow">
                <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">09:15 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">45 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Soft Skills: Escucha Activa y Empatía</h3>
                <p class="text-[#243c5a]/80 text-sm">Dinámica de comunicación usando el sonido como ancla. Aprendemos a hacer "pausas conscientes" antes de reaccionar, mejorando la calidad de las relaciones laborales.</p>
            </div>
        </div>

         <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">10:00 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">15 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-amber-400 shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-amber-50 p-6 rounded-xl shadow-sm border border-amber-100">
                <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">10:00 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">15 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Pausa de Nutrición y Recarga</h3>
                <p class="text-[#243c5a]/80 text-sm">Snack saludable acompañado de ejercicios de respiración energizante (Respiración de Fuego) para volver al trabajo con la mente despejada.</p>
            </div>
        </div>

         <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">10:15 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">60 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-[#5d5a8c] shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-white p-6 rounded-xl shadow-sm border border-stone-100 group-hover:shadow-md transition-shadow relative overflow-hidden">
                <div class="absolute top-0 right-0 bg-[#6ed8d9] text-[#243c5a] text-xs font-bold px-3 py-1 rounded-bl-lg">¡Más solicitado!</div>
                <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">10:15 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">60 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Taller: Kit de Supervivencia Anti-Estrés</h3>
                <p class="text-[#243c5a]/80 text-sm mb-3">Entrega de 5 herramientas prácticas para el día a día:</p>
                <ul class="text-xs text-[#243c5a]/70 grid grid-cols-1 sm:grid-cols-2 gap-2">
                    <li class="flex gap-2">🔹 Micro-Meditación de escritorio.</li>
                    <li class="flex gap-2">🔹 3 Respiraciones de emergencia.</li>
                    <li class="flex gap-2">🔹 Yoga en silla para espalda.</li>
                    <li class="flex gap-2">🔹 Sound Healing express para ansiedad.</li>
                </ul>
            </div>
        </div>

        <div class="relative md:grid md:grid-cols-12 md:gap-8 items-start group">
            <div class="hidden md:block md:col-span-3 text-right">
                <span class="text-xl font-bold text-[#5d5a8c] block">11:15 AM</span>
                <span class="text-xs text-[#243c5a]/50 uppercase tracking-wide">45 Minutos</span>
            </div>
            <div class="absolute -left-[39px] md:left-[24.5%] top-1 w-5 h-5 rounded-full border-4 border-white bg-[#6ed8d9] shadow-sm z-10 group-hover:scale-125 transition-transform"></div>
            
            <div class="md:col-span-9 bg-white p-6 rounded-xl shadow-sm border border-stone-100 group-hover:shadow-md transition-shadow">
                <div class="md:hidden mb-2 flex items-baseline gap-2">
                    <span class="text-lg font-bold text-[#5d5a8c]">11:15 AM</span>
                    <span class="text-xs text-[#243c5a]/50 uppercase">45 Minutos</span>
                </div>
                <h3 class="text-lg font-bold text-[#243c5a] mb-2">Integración Sonora y Cierre</h3>
                <p class="text-[#243c5a]/80 text-sm">Meditación final de agradecimiento sostenida por cuencos de cristal para fijar intenciones. Cierre del espacio y entrega de recordatorios/regalos.</p>
            </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-20 bg-[#243c5a] text-white px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="text-3xl md:text-5xl font-serif mb-6">Invierte en el activo más valioso de tu empresa: Su Gente</h2>
      <p class="text-stone-300 text-lg mb-10 leading-relaxed max-w-2xl mx-auto">
        Diseñemos juntos una experiencia a la medida de los objetivos de tu organización (liderazgo, manejo del estrés, integración).
      </p>
      
      <div class="flex flex-col md:flex-row gap-4 justify-center">
          <a 
            href={whatsappLink}
            target="_blank"
            data-event="whatsapp_click"
            data-label="Corporate Wellness CTA Final"
            class="bg-[#6ed8d9] text-[#243c5a] px-8 py-4 rounded-full font-bold hover:bg-white transition-all duration-300 shadow-lg"
          >
            Cotizar Taller Corporativo
          </a>
      </div>
    </div>
  </section>

  {bienestarPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 bg-white">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-marce-base-3 mb-4">Artículos sobre Bienestar Corporativo</h2>
        <p class="text-stone-600 max-w-2xl mx-auto">Ideas y herramientas para prevenir el burnout y crear equipos más conscientes.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {bienestarPosts.map((post) => (
          <article class="bg-stone-50 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 flex flex-col">
            {post.data.image && (
              <div class="h-48 overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <time class="text-xs text-stone-500 mb-2 uppercase tracking-wider">
                {new Date(post.data.pubDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="text-xl font-semibold text-marce-base-3 mb-3 leading-tight">
                {post.data.title}
              </h3>
              <p class="text-stone-600 text-sm mb-4 flex-grow leading-relaxed">
                {post.data.description}
              </p>
              <a
                href={`/blog/${post.slug}`}
                class="text-marce-base-1 font-semibold text-sm hover:text-marce-base-2 transition-colors inline-flex items-center gap-1"
              >
                Leer más
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12">
        <div class="flex flex-col md:flex-row gap-3 justify-center">
          <a
            href="/blog/tag/burnout"
            class="inline-block px-6 py-3 border-2 border-marce-base-1 text-marce-base-1 rounded-lg hover:bg-marce-base-1 hover:text-white transition-all font-semibold"
          >
            Ver artículos sobre burnout
          </a>
          <a
            href="/blog/tag/bienestar%20corporativo"
            class="inline-block px-6 py-3 border-2 border-marce-base-1 text-marce-base-1 rounded-lg hover:bg-marce-base-1 hover:text-white transition-all font-semibold"
          >
            Ver artículos de bienestar corporativo
          </a>
        </div>
      </div>
    </section>
  )}

  <section class="py-20 bg-stone-50 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Preguntas frecuentes sobre Bienestar Corporativo</h2>
        <p class="text-[#243c5a]/70 max-w-2xl mx-auto">Respuestas clave para empresas que buscan programas de bienestar en Medellín.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {faqItems.map((item) => (
          <article class="bg-white p-6 rounded-xl border border-stone-100 shadow-sm">
            <h3 class="text-lg font-semibold text-[#243c5a] mb-3">{item.question}</h3>
            <p class="text-sm text-[#243c5a]/80 leading-relaxed">{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div style="background-color: #fcfcfc; border: 1px solid #e5e7eb; padding: 40px; max-width: 600px; margin: 0 auto; font-family: 'Georgia', serif; color: #243c5a; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-radius: 12px; position: relative; overflow: hidden;">
    
    <div style="position: absolute; top: 0; right: 0; width: 200px; height: 200px; background: radial-gradient(circle, rgba(110,216,217,0.2) 0%, rgba(255,255,255,0) 70%); border-radius: 50%;"></div>
    
    <div style="text-align: center; margin-bottom: 30px; position: relative; z-index: 10;">
        <h2 style="color: #243c5a; font-size: 24px; margin: 0 0 10px 0; text-transform: uppercase; letter-spacing: 2px;">Ficha de Rescate</h2>
