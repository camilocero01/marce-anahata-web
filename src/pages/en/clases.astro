                <p class="text-[#243c5a] font-semibold">Yoga Nidra</p>
                <p class="text-xs text-[#243c5a]/60">Conscious sleep yoga</p>
              </div>
              <div class="pb-4 border-b border-stone-100">
                <p class="text-sm font-medium text-[#5d5a8c] mb-1">8:30 AM</p>
                <div class="flex items-center gap-2 mb-0.5">
                  <p class="text-[#243c5a] font-semibold">Yogalates</p>
                  <span class="text-[10px] font-bold uppercase tracking-wide text-[#243c5a] bg-[#6ed8d9] px-1.5 py-0.5 rounded-full">New</span>
                </div>
                <p class="text-xs text-[#243c5a]/60">New fusion — Yoga + Pilates</p>
              </div>
              <div>
                <p class="text-sm font-medium text-[#5d5a8c] mb-1">5:30 PM</p>
                <p class="text-[#243c5a] font-semibold">Kundalini Yoga</p>
                <p class="text-xs text-[#243c5a]/60">Awakening and vital energy</p>
              </div>
            </div>
          </div>
        </div>

        {/* THURSDAY */}
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-[#5d5a8c] to-[#6ed8d9] rounded-2xl opacity-20 group-hover:opacity-100 transition duration-300 blur"></div>
          <div class="relative bg-white rounded-2xl p-6 border border-[#6ed8d9]/30 hover:border-[#6ed8d9] transition-all">
