            <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-2">
              <span class="text-2xl">📅</span>
              Monday
            </h3>
            <div class="space-y-4">
              <div class="pb-4 border-b border-stone-100">
                <p class="text-sm font-medium text-[#5d5a8c] mb-1">8:30 AM</p>
                <p class="text-[#243c5a] font-semibold">Yoga for Anxiety & Stress</p>
                <p class="text-xs text-[#243c5a]/60">Nervous system management</p>
              </div>
              <div class="pb-4 border-b border-stone-100">
                <p class="text-sm font-medium text-[#5d5a8c] mb-1">5:30 PM</p>
                <p class="text-[#243c5a] font-semibold">Yin Yoga & Pranayama</p>
                <p class="text-xs text-[#243c5a]/60">Breathwork and deep opening</p>
              </div>
              <div>
                <p class="text-sm font-medium text-[#5d5a8c] mb-1">7:00 PM</p>
                <p class="text-[#243c5a] font-semibold">Yogalates</p>
                <p class="text-xs text-[#243c5a]/60">Yoga + Pilates fusion · Core and breathwork</p>
              </div>
            </div>
          </div>
        </div>

        {/* TUESDAY */}
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-[#5d5a8c] to-[#6ed8d9] rounded-2xl opacity-20 group-hover:opacity-100 transition duration-300 blur"></div>
          <div class="relative bg-white rounded-2xl p-6 border border-[#6ed8d9]/30 hover:border-[#6ed8d9] transition-all">
            <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-2">
              <span class="text-2xl">🕯️</span>
              Tuesday
            </h3>
            <div class="space-y-4">
