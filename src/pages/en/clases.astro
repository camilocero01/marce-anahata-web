---
import Layout from '../../layouts/Layout.astro';
import ReviewsSection from '../../components/cards/ReviewsSection.astro';
import { Image } from 'astro:assets';
import claseYogaLandingImg from '../../assets/clase/clase-yoga-landing.webp';
import { getCollection } from 'astro:content';

// --- GENERAL DATA ---
const pageInfo = {
  title: "Kundalini Yoga Classes & Workshops in Envigado - La Frontera con El Poblado",
  subtitle: "Sacred technology to strengthen your body, calm the mind, and awaken vital energy in daily life.",
  whatsappMessageGeneral: "Hi Marce Anahata, I'm interested in your Kundalini Yoga classes. Could you share information about pricing and monthly packages?",
};

const whatsappLinkGeneral = `https://wa.me/573207329921?text=${encodeURIComponent(pageInfo.whatsappMessageGeneral)}`;
const serviceUrl = 'https://www.marceanahata.com/en/clases';

const faqItems = [
  {
    question: 'What is included in the Kundalini Yoga classes in Medellín?',
    answer:
      'Classes include kriyas, pranayamas, meditation, and mantra to strengthen the nervous system, improve focus, and elevate daily vitality.'
  },
  {
    question: 'Where are the Kundalini Yoga classes held?',
    answer:
      'Classes are held in Envigado y El Poblado, with online options available depending on schedule and format.'
  },
  {
    question: 'Do I need previous experience to begin?',
    answer:
      'No prior experience is required. Classes are adapted for both beginners and experienced practitioners.'
  },
  {
    question: 'What practice formats do you offer?',
    answer:
      'We offer regular group classes, private 1:1 sessions, and deep thematic workshops.'
  },
  {
    question: 'How can I reserve my class?',
    answer:
      'You can book directly via WhatsApp from this page to receive current schedules, monthly packs, and personalized options.'
  },
  {
    question: 'Do you offer Pilates classes near El Poblado or Envigado?',
    answer:
      'We don\'t offer traditional Pilates, but we do have Yogalates — a fusion combining Pilates principles with the depth of yoga — and Mobility & Stretching, a class focused on joint range of motion, flexibility, and posture. Many students choose them as a direct alternative to Pilates. Message us and we\'ll help you find the best fit for your goals.'
  },
  {
    question: 'What is the difference between Yogalates and traditional Pilates?',
    answer:
      'Traditional Pilates focuses mainly on core strength using specialized equipment or mat work. Yogalates combines those principles of central strength and posture with the breath work, mindfulness, and energy focus of yoga. The result is a practice that tones the body while also calming the nervous system — no machines or special equipment needed.'
  },
  {
    question: 'Are there yoga classes on Saturdays in Envigado or El Poblado?',
    answer:
      'Yes. On Saturdays at 9:00 AM we offer Kundalini Yoga at our Wellness Center (Cl. 23 Sur #42B-60, Envigado, La Frontera — El Poblado border). It\'s a great way to start the weekend with energy. We recommend confirming availability via WhatsApp before attending.'
  },
  {
    question: 'How much do yoga classes cost in Envigado or El Poblado?',
    answer:
      'We offer monthly packs with access to all weekly group classes. For current pricing, available packs, and personalized options, visit our pricing page or message us on WhatsApp — we reply quickly.'
  },
  {
    question: 'What is Mobility & Stretching and who is it for?',
    answer:
      'Mobility & Stretching is a class focused on recovering and expanding joint range of motion, releasing muscle tension, and improving posture. Ideal for people who sit for long hours, play other sports, or want to complement their yoga practice with deep flexibility work. Classes on Thursdays at 7:00 PM.'
  }
];

// 3 English posts tagged "yoga" or "meditación" (kept tag for compatibility)
// TEMPORARILY DISABLED FOR PRODUCTION
// const yogaPosts = (await getCollection('blog', ({ data, slug }) =>
//   slug.startsWith('en/') && !data.draft && (data.tags.includes('yoga') || data.tags.includes('meditación'))
// ))
//   .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
//   .slice(0, 3);
const yogaPosts: any[] = [];

// --- OFFERINGS (easy to edit) ---
const offerings = [
  {
    icon: "🧘‍♀️",
    title: "Regular Group Classes",
    description: "Your weekly energetic maintenance space. Open classes at our Wellness Center with fixed weekly schedules. Ideal for those seeking a consistent community practice.",
    details: ["At the Wellness Center", "Fixed weekly schedules", "Open group — no prior registration", "Monthly packs available"],
    scheduleLink: "/en/clases#horarios",
    cta: "Book Now",
    whatsappMsg: "Hi Marce Anahata, I want to reserve my spot in the regular group classes. How do I proceed?",
    tarifaLink: "/en/tarifas#clases-grupales"
  },
  {
    icon: "✨",
    title: "Private Sessions (1:1)",
    description: "Personalized support at our Wellness Center with a closed, exclusive group. The practice is designed around the group's specific needs: anxiety, purpose, vitality, and more.",
    details: ["At the Wellness Center", "Closed and personalized group", "Schedules agreed with the group", "Progress and follow-up"],
    cta: "Schedule Session",
    whatsappMsg: "Hi Marce Anahata, I'd like to schedule a personalized private yoga session. What's your availability?",
    tarifaLink: "/en/tarifas#clases-personalizadas"
  },
  {
    icon: "🔮",
    title: "Deep Thematic Workshops",
    description: "Longer immersions held outside the Wellness Center, in special spaces suited to each theme. Custom-designed for groups, companies, or communities with a specific intention.",
    details: ["Outside the Wellness Center", "Space adapted to each theme", "Custom design per group", "Themes: chakras, prosperity, healing & more"],
    cta: "Ask About Workshops",
    whatsappMsg: "Hi Marce Anahata, I'd like information about the upcoming thematic workshops available.",
    tarifaLink: "/en/tarifas#talleres"
  }
];
---

<Layout 
  title="Yoga Classes and Workshops | Marce Anahata"
  description="In-person and online Kundalini Yoga classes in Medellín. Learn conscious breathwork, meditation, and kriyas to awaken your vital energy."
  lang="en"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.marceanahata.com/en" },
        { "@type": "ListItem", "position": 2, "name": "Classes & Workshops", "item": "https://www.marceanahata.com/en/clases" }
      ]
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Kundalini Yoga Classes and Workshops in Medellín",
      "description": "Kundalini Yoga classes in Medellín to strengthen the body, calm the mind, and awaken vital energy through breathwork, meditation, and kriyas.",
      "serviceType": "Kundalini Yoga Classes",
      "provider": {
        "@type": "Person",
        "name": "Marce Anahata",
        "url": "https://www.marceanahata.com/en/sobre-mi"
      },
      "areaServed": {
        "@type": "City",
        "name": "Medellín"
      },
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      },
      "url": serviceUrl,
      "keywords": "yoga classes Envigado, yoga El Poblado, yoga La Frontera Envigado, Kundalini Yoga, Yin Yoga, Yogalates, Yoga Nidra, Restorative Yoga, Vinyasa Detox, Barre Balance, yoga classes Medellín, pranayama, meditation, holistic wellness, pilates Envigado, pilates El Poblado, pilates classes Envigado, pilates alternative Medellín, yoga and pilates Envigado"
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })}</script>
    <script is:inline type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "SportsActivityLocation"],
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Wellness Center",
      "description": "Wellness center in Envigado (La Frontera — El Poblado border) specializing in Kundalini Yoga, Yin Yoga, Yogalates, Barre Balance, Yoga Nidra, Vinyasa Detox, sound therapy, and sacred rituals.",
      "url": "https://www.marceanahata.com/en",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "image": "https://www.marceanahata.com/images/social-preview-wa.jpg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
        "addressLocality": "Envigado",
        "addressRegion": "Antioquia",
        "addressCountry": "CO"
      },
      "sameAs": [
        "https://www.instagram.com/marce_anahata/",
        "https://www.youtube.com/@marce_anahata",
        "https://www.tiktok.com/@marce_anahata"
      ],
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "08:30", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:30", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "07:30", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "08:30", "closes": "20:30" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "08:30", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "11:00" }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}</script>
    <meta property="og:locale" content="en_US" />
  </Fragment>
  
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">

