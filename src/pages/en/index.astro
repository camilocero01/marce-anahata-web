---
// src/pages/en/index.astro
import Layout from '../../layouts/Layout.astro';
import ReviewsSection from '../../components/cards/ReviewsSection.astro';
import UpcomingEventsGridEN from '../../components/UpcomingEventsGridEN.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import terapiaSonidoImg from '../../assets/terapia-sonido-2.webp';
import ritualesImg from '../../assets/ritual/rituales.webp';
import circuloMujeresImg from '../../assets/circulo-mujeres-conscientes-home.jpg';
import bienestarcorporativoImg from '../../assets/corporativo/bienestar-corporativo-3.webp';
import homeYogaImg from '../../assets/home-yoga.webp';
import masajesImg from '../../assets/marmaterapia/terapeuta-puntos-marma-ayurveda.png';
import heroBgImg from '../../assets/hero-bg.webp';
import marcePerfilImg from '../../assets/marce-perfil.webp';

// Get latest 3 blog posts in English
const allPosts = (await getCollection('blog', ({ data, slug }) => !data.draft && slug.startsWith('en/')))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// Page metadata
const pageTitle = "Kundalini Yoga and Sound Therapy in Medellín";
const pageDescription = "Wellness center in El Poblado offering Kundalini Yoga, sound therapy, sacred rituals, and corporate wellness programs.";

const homeFaqItems = [
  {
    question: 'What is a gong bath and what is it for?',
    answer: 'A gong bath is a sound therapy session where you lie down and receive the gong\'s frequencies directly into your body. It acts on the nervous system, reduces stress and anxiety, improves sleep, and releases accumulated tension. No prior experience needed — just arrive, lie down, and receive.'
  },
  {
    question: 'Where is the Marce Anahata Wellness Center located?',
    answer: 'We are in Envigado, in the La Frontera area near El Poblado (Calle 23 Sur #42B-60, Los Cristales). Just 2 minutes from El Poblado, with easy access from Medellín.'
  },
  {
    question: 'Do I need prior experience for yoga classes?',
    answer: 'No. All classes adapt to your level. We offer Kundalini Yoga, Yin, Restorative, Yogalates and Vinyasa — practices for beginners and advanced practitioners alike. All you need is comfortable clothing and an open mind.'
  },
  {
    question: 'What types of sacred rituals do you offer?',
    answer: 'We offer personalized rituals for different life moments: Birthday Solar Return Ritual, Couple Ritual, Baby Blessing, Conscious Bachelorette Ritual, and Closure & Opening Ritual. Each ceremony includes sound therapy and is designed around your personal intention.'
  },
  {
    question: 'How do I book a session or class?',
    answer: 'You can book directly via WhatsApp at +57 320 732 9921, or use the contact form on this site. For sacred rituals, a 50% deposit is required to hold your date.'
  }
];

const serviciosHome = [
  {
    titulo: "Sound Therapy",
    descripcion: "Restore your cellular harmony. Through the vibration of the Gong and singing bowls, we release energetic blockages and bring your nervous system to a state of deep peace that even deep sleep doesn't always achieve.",
    link: "/en/terapia-sonido",
    imagen: terapiaSonidoImg
  },
  {
    titulo: "Sacred Rituals",
    descripcion: "In life, every cycle that begins or ends deserves to be honored with presence and awareness. In our center, we create living altars and sacred atmospheres so you can celebrate life with meaning.",
    link: "/en/rituales", 
    imagen: ritualesImg
  },
  {
    titulo: "Women's Circle",
    descripcion: "Monthly gatherings to heal in community, awaken your inner voice, and strengthen your nervous system.",
    link: "/en/circulo-mujeres-conscientes", 
    imagen: circuloMujeresImg
  },
  {
    titulo: "Corporate Wellness",
    descripcion: "Bring balance to your team with conscious breaks and stress management workshops.",
    link: "/en/bienestar-corporativo", 
    imagen: bienestarcorporativoImg
  },
  {
    titulo: "Yoga Classes",
    descripcion: "Strengthen your mind, inhabit your body with awareness. Kundalini, Yin, Restorative, Yogalates, Vinyasa and more — practices for all levels that awaken your vitality and calm your nervous system.",
    link: "/en/clases",
    imagen: homeYogaImg
  },
  {
    titulo: "Ayurvedic Massages & Marma Points",
    descripcion: "Heal from the root. An ancient therapy that detoxifies your body and releases accumulated tension, restoring the flow of your vital energy.",
    link: "/en/ayurvedic-massage",
    imagen: masajesImg
  }
];
---

<Layout title={pageTitle} description={pageDescription} lang="en">
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "SportsActivityLocation"],
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Centro de Bienestar",
      "description": "Wellness center in Envigado (La Frontera area, near El Poblado, Medellín) specializing in sound therapy, gong baths, Kundalini Yoga, sacred rituals, women's conscious circles, and Ayurvedic massages.",
      "url": "https://www.marceanahata.com",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "image": "https://www.marceanahata.com/images/social-preview-wa.jpg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
        "addressLocality": "Envigado",
        "addressRegion": "Antioquia",
        "postalCode": "055420",
        "addressCountry": "CO"
      },
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "14:00" }
      ],
      "sameAs": ["https://www.instagram.com/marce_anahata/", "https://www.youtube.com/@marce_anahata", "https://www.tiktok.com/@marce_anahata"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      },
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Wellness Services",
        "itemListElement": [
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sound Therapy", "url": "https://www.marceanahata.com/en/terapia-sonido" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Gong Bath", "url": "https://www.marceanahata.com/en/bano-de-gong" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Kundalini Yoga & Classes", "url": "https://www.marceanahata.com/en/clases" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Sacred Rituals", "url": "https://www.marceanahata.com/en/rituales" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Women's Conscious Circle", "url": "https://www.marceanahata.com/en/circulo-mujeres-conscientes" } },
          { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Ayurvedic Massages & Marma Points", "url": "https://www.marceanahata.com/en/ayurvedic-massage" } }
        ]
      }
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "@id": "https://www.marceanahata.com/#person",
      "name": "Marce Anahata",
      "jobTitle": "Holistic Wellness Facilitator, Kundalini Yoga Teacher",
      "url": "https://www.marceanahata.com/en/sobre-mi",
      "worksFor": { "@id": "https://www.marceanahata.com/#business" },
      "sameAs": ["https://www.instagram.com/marce_anahata/", "https://www.youtube.com/@marce_anahata", "https://www.tiktok.com/@marce_anahata"]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://www.marceanahata.com/#website",
      "name": "Marce Anahata",
      "url": "https://www.marceanahata.com",
      "description": "Official website of Marce Anahata — Wellness center in Envigado, La Frontera near El Poblado, Medellín.",
      "publisher": { "@id": "https://www.marceanahata.com/#business" },
      "inLanguage": ["es", "en"]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": homeFaqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer }
      }))
    })}</script>
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content="https://www.marceanahata.com/images/social-preview-wa.jpg" />
  </Fragment>
  
  <section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden">

    <div class="absolute inset-0 z-0">
      <video 
        autoplay 
        muted 
        loop 
        playsinline
        preload="auto"
        poster="/images/hero-bg.webp"
        class="w-full h-full object-cover opacity-60"
      >
        <source src="/videos/hero-bg.mp4" type="video/mp4" />
        <Image 
          src={heroBgImg} 
          alt="Meditation background" 
          class="w-full h-full object-cover"
          width={1920}
          densities={[1.5, 2]}
        />
      </video>
      <div class="absolute inset-0 bg-gradient-to-b from-stone-100/30 to-stone-100/90 z-10"></div>
    </div>

    <div class="relative z-20 text-center px-6 max-w-4xl mx-auto mt-10">
      <span class="block text-marce-base-1 uppercase tracking-[0.3em] text-sm mb-4 animate-fade-in-up font-bold">Holistic Wellness</span>
      <h1 class="text-5xl md:text-7xl text-marce-base-3 mb-6 leading-tight font-serif">
        From stillness <br/> <span class="italic text-marce-base-1">comes your power.</span>
      </h1>
      <p class="text-xl text-marce-base-3/80 mb-10 max-w-2xl mx-auto font-light">
        In a world full of noise, we offer you a sacred refuge to quiet the mind, heal the body, and elevate your vibration. We accompany your integral transformation journey through the technology of yoga, sound, and conscious well-being.
      </p>
      
      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <a href="/en/rituales" class="btn-claro">
          View Rituals
        </a>
        
        <a href="#servicios" class="px-8 py-3 rounded-lg border border-marce-base-1 text-marce-base-1 hover:bg-marce-base-2 hover:text-white hover:border-marce-base-2 transition duration-300 font-semibold">
          Explore Services
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 px-6 bg-white">
    <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center gap-16">
      <div class="md:w-1/2">
        <div class="aspect-[4/5] bg-stone-100 rounded-2xl overflow-hidden relative shadow-xl border border-marce-base-2/30">
           <Image 
             src={marcePerfilImg} 
             alt="Marce Anahata" 
             class="object-cover h-full w-full"
             width={634}
             height={1135}
             densities={[1.5, 2]}
           />
        </div>
      </div>
      <div class="md:w-1/2">
        <h2 class="text-4xl text-marce-base-3 mb-6 font-serif">Your bridge to inner wisdom.</h2>
        <p class="text-lg text-marce-base-3/80 mb-6 leading-relaxed">
          Hi, I'm Marce Anahata. My path didn't begin as a profession — it began as a deep search for purpose. Today, I understand well-being not as a luxury, but as a fundamental need.
        </p>
        <p class="text-lg text-marce-base-3/80 mb-8 leading-relaxed">
          I'm not a guru; I'm a facilitator who puts scientific and ancestral tools at your disposal so that you yourself become your own master. In our center, there are no labels of age, gender, or physical condition — only human beings seeking to return home, to their own heart.
        </p>
        <div class="flex gap-8 text-marce-base-1 font-serif italic text-lg border-t border-marce-base-2/50 pt-6">
          <span>Kundalini Yoga</span>
          <span>•</span>
          <span>Sound Healing</span>
          <span>•</span>
          <span>Rituals</span>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="py-24 px-6 bg-stone-50">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl text-marce-base-1 mb-4 font-serif">My Services</h2>
        <p class="text-marce-base-3/70 max-w-xl mx-auto">Pathways designed for your physical, mental, and spiritual well-being.</p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {serviciosHome.map((servicio) => (
          <a href={servicio.link} class="group block bg-white p-6 shadow-sm hover:shadow-xl transition-all duration-300 rounded-2xl border border-transparent hover:border-marce-base-2/30 flex flex-col">
            <div class="h-48 bg-stone-200 mb-6 overflow-hidden rounded-xl shrink-0">
              <Image 
                src={servicio.imagen} 
                alt={servicio.titulo} 
                class="w-full h-full object-cover group-hover:scale-110 transition duration-700"
                width={550}
                height={357}
                densities={[1.5, 2]}
              />
            </div>
            <h3 class="text-xl text-marce-base-3 mb-3 font-serif group-hover:text-marce-base-1 transition-colors">{servicio.titulo}</h3>
            <p class="text-marce-base-3/70 leading-relaxed mb-4 font-light text-sm flex-grow">{servicio.descripcion}</p>
            <span class="text-sm font-semibold text-marce-base-1 group-hover:text-marce-base-2 transition-colors mt-auto block">Learn more &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="events" class="scroll-mt-24">
    <UpcomingEventsGridEN />
  </section>

  <ReviewsSection lang="en" />

  <!-- Blog Section - Latest Posts -->
  {allPosts.length > 0 && (
    <section class="py-24 px-6 bg-white">
      <div class="max-w-6xl mx-auto">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-4xl text-marce-base-1 mb-4 font-serif">Recent Articles</h2>
          <p class="text-marce-base-3/70 max-w-xl mx-auto mb-8">Tips and reflections on wellness, yoga, and personal transformation.</p>
          <a href="/en/blog" class="inline-flex items-center gap-2 text-marce-base-1 hover:text-marce-base-2 font-semibold transition-colors">
            View all articles
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <div class="grid md:grid-cols-3 gap-8">
          {allPosts.map(post => (
            <article class="bg-stone-50 rounded-2xl shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden border border-stone-200 hover:border-marce-base-2/30 flex flex-col group">
              {post.data.image && (
                <a href={`/en/blog/${post.slug.replace(/^en\//, '')}`} class="overflow-hidden h-48">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </a>
              )}
              <div class="p-6 flex flex-col flex-grow">
                <div class="text-sm text-marce-base-3/80 mb-3">
                  {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
                <h3 class="text-xl text-marce-base-3 mb-3 font-serif group-hover:text-marce-base-1 transition-colors leading-tight">
                  <a href={`/en/blog/${post.slug.replace(/^en\//, '')}`}>{post.data.title}</a>
                </h3>
                <p class="text-marce-base-3/70 text-sm leading-relaxed mb-4 flex-grow">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.slice(0, 2).map(tag => (
                      <span class="text-xs bg-marce-base-2/10 text-marce-base-1 px-2 py-1 rounded-full">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
                <a href={`/en/blog/${post.slug.replace(/^en\//, '')}`} class="text-marce-base-1 font-semibold text-sm group-hover:text-marce-base-2 transition-colors inline-flex items-center gap-1 mt-auto">
                  Read more
                  <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 text-center">
          <a href="/en/blog" class="inline-block px-6 py-3 border-2 border-marce-base-1 text-marce-base-1 rounded-lg hover:bg-marce-base-1 hover:text-white transition-all font-semibold">
            Explore All Articles
          </a>
        </div>
      </div>
    </section>
  )}

  <!-- FAQ Section -->
  <section class="py-20 px-6 bg-gradient-to-b from-stone-50 to-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif font-bold text-[#243c5a] mb-4">
          Frequently asked questions
        </h2>
        <p class="text-stone-600 max-w-2xl mx-auto">
          Everything you need to know before your first session.
        </p>
      </div>

      <div class="space-y-3">
        {homeFaqItems.map((item) => (
          <details class="group bg-white rounded-xl border border-stone-100 shadow-sm hover:border-[#6ed8d9]/40 transition-colors">
            <summary class="flex items-center justify-between gap-4 px-6 py-5 cursor-pointer list-none">
              <h3 class="text-base font-semibold text-[#243c5a]">{item.question}</h3>
              <svg class="w-5 h-5 text-[#5d5a8c] shrink-0 transition-transform duration-300 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </summary>
            <p class="px-6 pb-5 text-[#243c5a]/75 leading-relaxed text-sm border-t border-stone-100 pt-4">{item.answer}</p>
          </details>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/en/faq"
          class="inline-block px-8 py-3 border-2 border-[#243c5a] text-[#243c5a] rounded-full font-semibold hover:bg-[#243c5a] hover:text-white transition-all"
        >
          View all frequently asked questions
        </a>
      </div>
    </div>
  </section>

</Layout>
