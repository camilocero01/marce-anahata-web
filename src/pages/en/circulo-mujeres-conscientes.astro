---
// src/pages/en/circulo-mujeres-conscientes.astro
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import ritualesImg from '../../assets/ritual/circulo-mujeres-conciente-medellin.jpg';

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent("Hi Marce, I’m interested in the Women’s Circle. When is the next gathering?")}`;
---

<Layout 
  title="Women's Circle in Medellín | Marce Anahata" 
  description="A sacred space where women gather to remember, heal, and be reborn together. Monthly circles in Medellín with ritual, sound, and sisterhood."
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://www.marceanahata.com/en' },
        { '@type': 'ListItem', position: 2, name: "Women's Circle", item: 'https://www.marceanahata.com/en/circulo-mujeres-conscientes' },
      ],
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: "Women's Conscious Circle — Marce Anahata",
      description: "Monthly women's gathering in Envigado (El Poblado border) for sacred rituals, sound therapy, meditation, and sisterhood. A safe space where women meet to heal, remember, and be reborn together.",
      eventSchedule: {
        '@type': 'Schedule',
        repeatFrequency: 'P1M',
        byDay: 'Saturday',
        startTime: '19:00',
        endTime: '22:00'
      },
      location: {
        '@type': 'Place',
        name: 'Marce Anahata Wellness Center',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Cl. 23 Sur #42B-60, Los Cristales',
          addressLocality: 'Envigado',
          addressRegion: 'Antioquia',
          postalCode: '055420',
          addressCountry: 'CO'
        }
      },
      organizer: {
        '@type': 'Person',
        name: 'Marce Anahata',
        url: 'https://www.marceanahata.com/en',
        telephone: '+573207329921',
        email: 'info@marceanahata.com',
        sameAs: ['https://www.instagram.com/marce_anahata/']
      },
      audience: {
        '@type': 'Audience',
        audienceType: 'Women seeking connection, feminine healing, and self-knowledge',
        geographicArea: { '@type': 'City', name: 'Medellín' }
      },
      keywords: "women's circle, conscious women, Medellín, feminine rituals, full moon, new moon, sisterhood, feminine healing, sound therapy for women, women gatherings, sacred femininity, Envigado, El Poblado",
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        reviewCount: '11',
        bestRating: '5',
        worstRating: '1'
      }
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': ['HealthAndBeautyBusiness', 'SportsActivityLocation'],
      '@id': 'https://www.marceanahata.com/#business',
      name: 'Marce Anahata Wellness Center',
      description: 'Wellness center in Envigado (La Frontera — El Poblado border) specializing in Kundalini Yoga, Yogalates, Barre Balance, sound therapy, women circles, and sacred rituals.',
      url: 'https://www.marceanahata.com/en',
      telephone: '+573207329921',
      email: 'info@marceanahata.com',
      image: 'https://www.marceanahata.com/images/social-preview-wa.jpg',
      priceRange: '$$',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Cl. 23 Sur #42B-60, Los Cristales',
        addressLocality: 'Envigado',
        addressRegion: 'Antioquia',
        addressCountry: 'CO'
      },
      sameAs: [
        'https://www.instagram.com/marce_anahata/',
        'https://www.youtube.com/@marce_anahata',
        'https://www.tiktok.com/@marce_anahata'
      ],
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        reviewCount: '11',
        bestRating: '5',
        worstRating: '1'
      }
    })}</script>
    <meta property="og:locale" content="en_US" />
  </Fragment>

  <!-- Hero with layered text -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={ritualesImg}
        alt="Women in a sacred circle"
        class="w-full h-full object-cover"
        width={1920}
        densities={[1.5, 2]}
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#243c5a]/60 via-[#5d5a8c]/50 to-[#243c5a]/70"></div>
    </div>

    <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto">
      <div class="mb-8">
        <svg class="w-16 h-16 mx-auto mb-6 text-[#6ed8d9] opacity-80" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
        </svg>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-serif mb-8 leading-tight">
        The circle is medicine <br/>
        <span class="text-[#6ed8d9] italic">when we are no longer alone</span>
      </h1>
      
      <p class="text-xl md:text-2xl font-light max-w-3xl mx-auto mb-4 leading-relaxed text-stone-100">
        A space where your voice matters, your process is honored, and your energy transforms into community.
      </p>
      
      <p class="text-lg text-stone-200/90 mb-12 max-w-2xl mx-auto">
        We gather once a month to ritualize, move, sing, and remember that we heal better together.
      </p>

      <a 
        href={whatsappLink} 
        target="_blank"
        rel="noopener noreferrer"
        data-event="whatsapp_click" 
        data-label="EN Women Circle Hero CTA"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-10 py-5 rounded-full text-lg font-bold hover:bg-white transition-all duration-300 transform hover:scale-105 shadow-2xl"
      >
        I want to join
      </a>
      <div class="mt-6">
        <a
          href="/en/#events"
          class="text-sm font-semibold text-white/90 hover:text-white underline underline-offset-4 decoration-white/60 transition-colors"
        >
          See upcoming events
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10">
      <div class="animate-bounce">
        <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Narrative section: Why the circle -->
  <section class="py-24 bg-gradient-to-b from-stone-50 to-white px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">The Call</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Why do we sit in a circle?
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="prose prose-lg max-w-none text-[#243c5a]/80 space-y-6 leading-relaxed">
          <p class="text-xl font-light text-[#243c5a] italic border-l-4 border-[#6ed8d9] pl-6">
            Because for centuries, women have sat together: around the fire, beneath the moon, in moments of celebration and in times of grief.
          </p>
          
          <p>
            In the circle there are no hierarchies. No one knows more or less. There are eyes that hold each other, voices that listen, and hearts that beat together. It is a space where <strong>your story matters</strong> and where simply being present is already medicine.
          </p>

          <p>
            We don’t come here to fix ourselves or become something else. We come to <strong>remember</strong> what we’ve always been: <em>powerful, sensitive, capable of transforming pain into wisdom.</em>
          </p>

          <div class="bg-[#5d5a8c]/5 p-8 rounded-2xl my-12 border-l-4 border-[#5d5a8c]">
            <p class="text-lg text-[#243c5a] mb-0">
              <strong>The circle is a reminder:</strong> You are not alone in what you feel. You are not broken. And you deserve a space where you can drop the masks and simply <em>be</em>.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-[#6ed8d9]/20 to-[#5d5a8c]/20 rounded-3xl blur-2xl"></div>
          <div class="relative overflow-hidden rounded-3xl border border-stone-200/80 shadow-xl">
            <Image
              src={ritualesImg}
              alt="Women connecting in a circle"
              class="w-full h-full object-cover"
              width={960}
              height={720}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: What we experience together -->
  <section class="py-24 bg-white px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#6ed8d9]/10 rounded-full filter blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#5d5a8c]/10 rounded-full filter blur-[100px]"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">The Experience</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          What we experience together
        </h2>
        <p class="text-lg text-[#243c5a]/70 max-w-2xl mx-auto">
          Each gathering is a ceremony. A living experience that honors the body, the voice, and presence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#6ed8d9]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#6ed8d9]/30 transition-colors">
            <svg class="w-7 h-7 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Somatic Movement</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            Gentle movements that regulate the nervous system, release tension, and reconnect you with the body’s sensations. No steps to memorize—just inner listening.
          </p>
        </div>

        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#5d5a8c]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#5d5a8c]/30 transition-colors">
            <svg class="w-7 h-7 text-[#5d5a8c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Voice & Mantra</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            We use the voice as a healing instrument. We sing together, let sound vibrate in the chest, and awaken genuine expression without fear of judgment.
          </p>
        </div>

        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#6ed8d9]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#6ed8d9]/30 transition-colors">
            <svg class="w-7 h-7 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Ritual & Journaling</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            We ritualize intentions and processes. We write, release, and plant. We honor transitions with awareness and loving presence.
          </p>
        </div>

        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#5d5a8c]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#5d5a8c]/30 transition-colors">
            <svg class="w-7 h-7 text-[#5d5a8c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Listening & Sharing</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            We listen without interrupting, advising, or fixing. We simply hold space so each woman feels seen and honored in her truth.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Section: Who it's for -->
  <section class="py-24 bg-gradient-to-b from-[#243c5a] to-[#5d5a8c] text-white px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/hero-bg.webp')] opacity-5"></div>
    
    <div class="max-w-5xl mx-auto relative z-10">
      <div class="text-center mb-16">
        <span class="text-[#6ed8d9] uppercase tracking-[0.3em] text-sm font-semibold">See Yourself Here</span>
        <h2 class="text-4xl md:text-5xl font-serif mt-4 mb-6">
          This circle is for you if...
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center">
          <div class="text-5xl mb-4">🌙</div>
          <p class="text-white/90 leading-relaxed">
            You feel disconnected from yourself and want to return to your center with real tools.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-5xl mb-4">💫</div>
          <p class="text-white/90 leading-relaxed">
            You want a safe space where your voice and your process are honored without judgment.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-5xl mb-4">🌸</div>
          <p class="text-white/90 leading-relaxed">
            You’re seeking a community of conscious women walking the path of remembrance.
          </p>
        </div>
      </div>

      <div class="bg-white/10 backdrop-blur-sm p-10 rounded-3xl border border-white/20 text-center">
        <p class="text-2xl font-light mb-6 leading-relaxed">
          “You don’t need to be ‘ready’ or ‘okay.’ <br/>
          You only need <strong>the willingness to be present</strong>.”
        </p>
        <p class="text-[#6ed8d9] font-serif text-lg">— Marce Anahata</p>
      </div>
    </div>
  </section>

  <!-- Practical details -->
  <section class="py-24 bg-stone-50 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">Logistics</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Practical information
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Frequency
          </h3>
          <p class="text-[#243c5a]/70 mb-4">
            We meet <strong>once a month</strong>, usually on weekends.
            <a href="/en/#events" class="ml-2 text-[#5d5a8c] font-semibold hover:text-[#243c5a] underline underline-offset-4">
              See upcoming events
            </a>
          </p>
          <p class="text-sm text-[#243c5a]/60">Dates are announced two weeks in advance via WhatsApp to registered women.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Duration
          </h3>
          <p class="text-[#243c5a]/70 mb-4">Each circle lasts <strong>2 to 3 hours</strong>.</p>
          <p class="text-sm text-[#243c5a]/60">We recommend keeping your schedule clear afterward to integrate the experience with ease.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Location
          </h3>
          <p class="text-[#243c5a]/70 mb-4"><strong>Envigado y El Poblado</strong></p>
          <p class="text-sm text-[#243c5a]/60">A warm, private space prepared for the gathering. The exact address is shared when you confirm your spot.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Capacity
          </h3>
          <p class="text-[#243c5a]/70 mb-4"><strong>Maximum 12 women</strong> per circle.</p>
          <p class="text-sm text-[#243c5a]/60">Spots are limited to preserve intimacy and the quality of the shared space.</p>
        </div>
      </div>

      <div class="mt-12 bg-gradient-to-r from-[#5d5a8c] to-[#6ed8d9] p-8 rounded-2xl text-white text-center">
        <h3 class="text-2xl font-serif mb-4">What to bring</h3>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <span class="bg-white/20 px-4 py-2 rounded-full">Comfortable clothing</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">Personal journal (optional)</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">Water bottle</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">An open heart</span>
        </div>
        <p class="mt-6 text-sm text-white/80">*Mats, blankets, and ritual elements are included.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-24 bg-stone-50 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">FAQ</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Everything you need to know
        </h2>
        <p class="text-lg text-[#243c5a]/70">
          Clear answers so you arrive at the circle with confidence.
        </p>
      </div>

      <div class="space-y-6">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4">What is the Women's Conscious Circle by Marce Anahata?</h3>
          <p class="text-[#243c5a]/80 leading-relaxed">It's a monthly gathering in Medellín / Envigado where women come together in a sacred space to connect with themselves and with each other through rituals, sound therapy, meditation, and a sharing circle. It's not group therapy or a workshop — it's a sisterhood space where each woman can be heard without judgment, and where we heal better together.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4">When and where does the Women's Circle take place?</h3>
          <div class="text-[#243c5a]/80 leading-relaxed space-y-3">
            <p><strong>When:</strong> Generally the first Saturday of each month, from 5:00 PM to 8:00 PM. Exact dates are published in our events section.</p>
            <p><strong>Where:</strong> Our Wellness Center in Envigado, La Frontera — El Poblado border (Cl. 23 Sur #42B-60, Los Cristales, Envigado). The exact address is shared when you confirm your spot to preserve the intimacy of the space.</p>
          </div>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4">What does each Women's Circle gathering include?</h3>
          <div class="text-[#243c5a]/80 leading-relaxed">
            <p class="mb-3">Each circle includes:</p>
            <ul class="list-disc list-inside space-y-2 mb-4">
              <li><strong>Opening ritual</strong> with gong bath and crystal singing bowls</li>
              <li><strong>Guided meditation</strong> and conscious breathing techniques</li>
              <li><strong>Sharing circle</strong> — a deep listening space where every voice matters</li>
              <li><strong>Intuitive movement</strong> or sacred dance to release stagnant energy</li>
              <li><strong>Closing ritual</strong> aligned with the lunar phase</li>
