---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  // Solo obtener posts en español (no comienzan con 'en/')
  const posts = await getCollection('blog', ({ data, slug }) => !data.draft && !slug.startsWith('en/'));
  return posts.map((post) => {
    return {
      params: { slug: post.slug },
      props: { post, lang: 'es' }
    };
  });
}

const { post, lang } = Astro.props;
const { data } = post;
const { Content } = await post.render();
const title = data.title;
const pageTitle = data.seoTitle || data.title;
const description = data.description;
const siteOrigin = 'https://www.marceanahata.com';
const image = data.ogImage || data.image || '/images/social-preview-wa.jpg';
const absoluteImage = image.startsWith('http') ? image : `${siteOrigin}${image}`;
const url = new URL(Astro.url);
let canonical = data.canonical || url.toString();
// Ensure trailing slash for consistency with Astro's trailing slash behavior
if (!canonical.endsWith('/')) {
  canonical = canonical + '/';
}
const publishedTime = new Date(data.pubDate).toISOString();
const modifiedTime = data.updatedDate ? new Date(data.updatedDate).toISOString() : undefined;

const breadcrumbItems = [
  { name: 'Home', url: lang === 'en' ? 'https://www.marceanahata.com/en' : 'https://www.marceanahata.com' },
  { name: 'Blog', url: lang === 'en' ? 'https://www.marceanahata.com/en/blog' : 'https://www.marceanahata.com/blog' },
  { name: title, url: canonical }
];

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbItems.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url
  }))
};

const isEvent = data.isEvent === true;
const eventDateIso = isEvent && data.eventDate ? new Date(data.eventDate).toISOString() : null;

const jsonLd = isEvent ? {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: title,
  description,
  image: absoluteImage,
  url: canonical,
  startDate: eventDateIso || publishedTime,
  endDate: eventDateIso || publishedTime,
  eventStatus: 'https://schema.org/EventScheduled',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  location: {
    '@type': 'Place',
    name: 'Marce Anahata Centro de Bienestar',
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Cl. 23 Sur #42B-60',
      addressLocality: 'Envigado',
      addressRegion: 'Antioquia',
      addressCountry: 'CO'
    }
  },
  organizer: {
    '@type': 'Person',
    name: 'Marce Anahata',
    url: 'https://www.marceanahata.com'
  },
  offers: {
    '@type': 'Offer',
    price: data.eventPrice || '120000',
    priceCurrency: 'COP',
    availability: 'https://schema.org/InStock',
    url: canonical
  },
  keywords: (data.tags || []).join(', '),
} : {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: absoluteImage,
  author: {
    '@type': 'Person',
    name: data.author || 'Marce Anahata',
    url: 'https://www.marceanahata.com/sobre-mi',
    sameAs: [
      'https://www.instagram.com/marce_anahata',
      'https://www.youtube.com/@marce_anahata'
    ]
  },
  datePublished: publishedTime,
  dateModified: modifiedTime || publishedTime,
  mainEntityOfPage: canonical,
  keywords: (data.tags || []).join(', '),
};

// Related posts: last 3 from same primary tag
const primaryTag = data.tags?.[0];
let relatedPosts = primaryTag
  ? (await getCollection('blog', ({ data: d, slug }) => !d.draft && !slug.startsWith('en/') && (d.tags || []).includes(primaryTag)))
      .filter((p) => p.slug !== post.slug)
      .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
      .slice(0, 3)
  : [];

// If less than 3 related posts, add cross-silo recommendations
if (relatedPosts.length < 3) {
  const crossSiloTags: Record<string, string[]> = {
    'yoga': ['terapia de sonido', 'meditación', 'bienestar'],
    'terapia de sonido': ['yoga', 'meditación', 'rituales', 'baño de gong'],
    'bienestar corporativo': ['yoga', 'terapia de sonido', 'burnout'],
    'meditación': ['yoga', 'terapia de sonido', 'conciencia', 'baño de gong'],
    'baño de gong': ['terapia de sonido', 'meditación', 'rituales', 'sanación vibracional'],
    'sanación vibracional': ['baño de gong', 'terapia de sonido', 'meditación'],
    'viaje 450 vibraciones': ['baño de gong', 'terapia de sonido', 'meditación']
  };
  
  const additionalTags: string[] = (primaryTag && crossSiloTags[primaryTag]) || [];
  const additionalPosts = (await getCollection('blog', ({ data: d, slug }) => 
    !d.draft && !slug.startsWith('en/') && 
    additionalTags.some((tag) => (d.tags || []).includes(tag))
  ))
    .filter((p) => p.slug !== post.slug && !relatedPosts.find(rp => rp.slug === p.slug))
    .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
    .slice(0, 3 - relatedPosts.length);
  
  relatedPosts = [...relatedPosts, ...additionalPosts];
}

// FAQPage schema para posts de eventos con baño de gong
const eventFaqSchema = isEvent && (data.tags || []).includes('baño de gong') ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Qué es un baño de gong?',
      acceptedAnswer: { '@type': 'Answer', text: 'Un baño de gong es una experiencia terapéutica de sonido en la que las personas se recuestan cómodamente mientras reciben una inmersión de vibraciones creadas por el gong. El sonido actúa sobre el sistema nervioso favoreciendo la relajación profunda, la liberación emocional y la regulación del estrés.' }
    },
    {
      '@type': 'Question',
      name: '¿Necesito experiencia previa para asistir a un baño de gong?',
      acceptedAnswer: { '@type': 'Answer', text: 'No. Solo necesitas llegar con ropa cómoda y disposición a recibir. El gong hace el resto. No se requiere experiencia previa en meditación ni en terapia de sonido.' }
    },
    {
      '@type': 'Question',
      name: '¿Cuánto cuesta el baño de gong en Marce Anahata?',
      acceptedAnswer: { '@type': 'Answer', text: 'El precio es de $120.000 COP por persona. Si vienes con alguien (dúo), el valor es de $90.000 COP por persona. Se requiere el 50% de anticipo para reservar el cupo.' }
    },
    {
      '@type': 'Question',
      name: '¿Dónde se realiza el baño de gong?',
      acceptedAnswer: { '@type': 'Answer', text: 'En Marce Anahata Centro de Bienestar, Cl. 23 Sur #42B-60, Los Cristales, Envigado, Antioquia. Las sesiones son presenciales.' }
    },
    {
      '@type': 'Question',
      name: '¿Qué debo llevar al baño de gong?',
      acceptedAnswer: { '@type': 'Answer', text: 'Colchoneta o manta, botella de agua y algo abrigador. Se recomienda llegar 10-15 minutos antes para acomodarse con calma.' }
    },
    {
      '@type': 'Question',
      name: '¿Cuánto dura una sesión de baño de gong?',
      acceptedAnswer: { '@type': 'Answer', text: 'Cada sesión dura aproximadamente 60 minutos, incluyendo el tiempo de sonido y el cierre de integración.' }
    }
  ]
} : null;

// Determine service CTA based on primary tag
const serviceCTA = {
  'yoga': { url: '/clases', text: 'Explora nuestras clases de Kundalini Yoga' },
  'terapia de sonido': { url: '/terapia-sonido', text: 'Descubre la Terapia de Sonido' },
  'bienestar corporativo': { url: '/bienestar-corporativo', text: 'Conoce nuestros programas corporativos' },
  'burnout': { url: '/bienestar-corporativo', text: 'Programas de bienestar para empresas' },
  'meditación': { url: '/clases', text: 'Aprende meditación con Kundalini Yoga' },
  'rituales': { url: '/rituales', text: 'Explora nuestros rituales sagrados' },
  'baño de gong': { url: '/viaje-450-vibraciones', text: 'Reserva tu lugar en el Viaje de las 450 Vibraciones' },
  'sanación vibracional': { url: '/viaje-450-vibraciones', text: 'Reserva tu lugar en el Viaje de las 450 Vibraciones' },
  'viaje 450 vibraciones': { url: '/viaje-450-vibraciones', text: 'Ver todos los baños de gong 2026' }
}[primaryTag];
---
<Layout title={pageTitle} description={description} image={image} lang={lang} includeAlternates={false}>
  <Fragment slot="head">
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta property="article:published_time" content={publishedTime} />
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_CO'} />
    <meta property="og:image:alt" content={title} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <meta name="twitter:image:alt" content={title} />
    <meta name="author" content={data.author || 'Marce Anahata'} />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {eventFaqSchema && <script type="application/ld+json" set:html={JSON.stringify(eventFaqSchema)} />}
  </Fragment>
  <main class="max-w-3xl mx-auto px-4 py-16">
    <a href={lang === 'en' ? '/en/blog' : '/blog'} class="text-sm text-[#243c5a] hover:underline">← {lang === 'en' ? 'Back to blog' : 'Volver al blog'}</a>
    <article class="mt-6">
      <header class="mb-6">
        <h1 class="text-4xl font-serif text-[#243c5a] mb-2">{title}</h1>
        <p class="text-stone-600">{description}</p>
        <div class="mt-2 text-xs text-stone-500">
          <time datetime={publishedTime}>{new Date(data.pubDate).toLocaleDateString(lang === 'en' ? 'en-US' : 'es-CO', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          {data.tags?.length ? (
            <span>
              {' '}
              •{' '}
              {data.tags.map((t, i) => (
                <Fragment>
                  {i ? ' · ' : ''}
                  <a href={lang === 'en' ? `/en/blog/tag/${encodeURIComponent(t)}` : `/blog/tag/${encodeURIComponent(t)}`} class="text-[#243c5a] hover:text-[#6ed8d9]">#{t}</a>
                </Fragment>
              ))}
            </span>
          ) : null}
        </div>
      </header>
      {image && <img src={image} alt={title} width="1200" height="630" class="w-full h-64 object-cover rounded-xl mb-8" loading="eager" />}
      <div class="article-content">
        <Content />
      </div>
    </article>
    {relatedPosts.length > 0 && (
      <section class="mt-16">
        <h2 class="text-2xl md:text-3xl font-serif text-[#243c5a] mb-6">También te podría interesar…</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {relatedPosts.map((rp) => (
            <article class="bg-stone-50 rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 flex flex-col">
              {rp.data.image && (
                <div class="h-40 overflow-hidden">
                  <img
                    src={rp.data.image}
                    alt={rp.data.title}
                    width="400"
                    height="300"
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-5 flex flex-col flex-grow">
                <time class="text-xs text-stone-500 mb-2 uppercase tracking-wider">
                  {new Date(rp.data.pubDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <h3 class="text-lg font-semibold text-[#243c5a] mb-2 leading-tight">
                  {rp.data.title}
                </h3>
                <p class="text-stone-600 text-sm mb-4 flex-grow leading-relaxed">
                  {rp.data.description}
                </p>
                <a href={`/blog/${rp.slug}`} class="text-[#243c5a] font-semibold text-sm hover:text-[#6ed8d9] transition-colors inline-flex items-center gap-1">
                  Leer más
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>
            </article>
          ))}
        </div>
        <div class="text-center mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
          <a
            href={`/blog/tag/${encodeURIComponent(primaryTag)}`}
            class="inline-block px-6 py-3 border-2 border-[#243c5a] text-[#243c5a] rounded-lg hover:bg-[#243c5a] hover:text-white transition-all font-semibold"
          >
            Ver más de {primaryTag}
          </a>
          {serviceCTA && (
            <a
              href={serviceCTA.url}
              class="inline-block px-6 py-3 bg-[#6ed8d9] text-[#243c5a] rounded-lg hover:bg-[#5d5a8c] hover:text-white transition-all font-semibold shadow-sm"
            >
              {serviceCTA.text}
            </a>
          )}
        </div>
      </section>
    )}
  </main>
</Layout>

<style>
  .article-content {
    color: #57534e;
    line-height: 1.75;
  }

  .article-content :global(h2) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.875rem;
    font-weight: 600;
    color: #243c5a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .article-content :global(h3) {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem;
    font-weight: 600;
    color: #243c5a;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article-content :global(p) {
    margin-bottom: 1.5rem;
    font-size: 1rem;
    line-height: 1.75;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    margin-left: 1.5rem;
  }

  .article-content :global(ul) {
    list-style-type: disc;
  }

  .article-content :global(ol) {
    list-style-type: decimal;
  }

  .article-content :global(li) {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }

  .article-content :global(strong) {
    font-weight: 700;
    color: #243c5a;
  }

  .article-content :global(a) {
    color: #5d5a8c;
    text-decoration: underline;
    transition: color 0.2s;
  }

  .article-content :global(a:hover) {
    color: #6ed8d9;
  }

  .article-content :global(a.btn-whatsapp) {
    color: #243c5a;
    text-decoration: none;
    background-color: #6ed8d9;
  }

  .article-content :global(a.btn-whatsapp:hover) {
    color: white;
    background-color: #243c5a;
  }

  .article-content :global(a.btn-whatsapp-dark) {
    color: white;
    text-decoration: none;
    background-color: #243c5a;
  }

  .article-content :global(a.btn-whatsapp-dark:hover) {
    color: #243c5a;
    background-color: #6ed8d9;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid #6ed8d9;
    padding-left: 1rem;
    font-style: italic;
    color: #78716c;
    margin: 1.5rem 0;
  }

  .article-content :global(code) {
    background-color: #f5f5f4;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: monospace;
    color: #243c5a;
  }

  .article-content :global(pre) {
    background-color: #f5f5f4;
    padding: 1rem;
    border-radius: 0.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .article-content :global(pre code) {
    background-color: transparent;
    padding: 0;
  }
</style>
