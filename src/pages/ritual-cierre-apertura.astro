---
// src/pages/cierre-apertura.astro
import Layout from '../layouts/Layout.astro';
import ReviewsSection from '../components/cards/ReviewsSection.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ritualCierreImg from '../assets/ritual/ritual-cierre.webp';

// --- DATOS DEL SERVICIO ---
const serviceInfo = {
  title: "Ritual de Cierre y Apertura: Transforma tu Realidad",
  subtitle: "Limpieza energética profunda para soltar el peso de lo viejo y manifestar propósitos claros para tu nuevo ciclo.",
  price: "$230.000 COP", // PON TU PRECIO REAL AQUÍ
  duration: "1.5 Horas",
  whatsappMessage: "Hola Marce Anahata, siento que necesito un cambio. Quiero agendar el Ritual de Cierre y Apertura para iniciar un nuevo ciclo con claridad."
};

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent(serviceInfo.whatsappMessage)}`; // CAMBIA EL NÚMERO
const serviceUrl = `https://marceanahata.com${Astro.url.pathname}`;
const faqItems = [
  {
    question: `¿En qué consiste ${serviceInfo.title}?`,
    answer: `Es una experiencia ritual personalizada para honrar tu proceso, elevar tu energía y crear un momento sagrado de transformación en Medellín.`
  },
  {
    question: '¿Dónde se realiza este ritual en Medellín?',
    answer: 'Se realiza en El Poblado, Medellín. Los detalles de la ubicación se comparten al confirmar la reserva por WhatsApp.'
  },
  {
    question: '¿Cuánto dura el ritual y cómo se reserva?',
    answer: `La duración aproximada es ${serviceInfo.duration}. Puedes reservar directamente por WhatsApp desde esta página.`
  },
  {
    question: '¿El ritual se adapta a mi intención personal?',
    answer: 'Sí. Cada ritual se diseña de forma personalizada según tu momento de vida, intención y necesidades energéticas.'
  }
];

// 3 posts aleatorios con tag "rituales"
const ritualesPosts = (await getCollection('blog', ({ data, slug }) =>
  !data.draft && !slug.startsWith('en/') && data.tags.includes('rituales')
))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout title="Ritual de Cierre y Apertura | Marce Anahata" description="Ritual de cierre y apertura en Medellín: limpieza energética profunda para soltar lo viejo y manifestar un nuevo ciclo de transformación y claridad.">
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": serviceInfo.title,
      "description": "Ritual de cierre y apertura en Medellín: limpieza energética profunda para soltar lo viejo y manifestar con claridad un nuevo ciclo de vida. Ceremonia personalizada en El Poblado.",
      "serviceType": "Ritual de Cierre y Apertura",
      "provider": {
        "@type": "Person",
        "name": "Marce Anahata",
        "url": "https://marceanahata.com/sobre-mi"
      },
      "areaServed": { "@type": "City", "name": "Medellín" },
      "offers": {
        "@type": "Offer",
        "price": "230000",
        "priceCurrency": "COP",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      },
      "url": serviceUrl,
      "keywords": "ritual de cierre y apertura Medellín, limpieza energética Medellín, ritual nuevo ciclo, soltar y manifestar El Poblado"
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": { "@type": "Answer", "text": item.answer }
      }))
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://marceanahata.com" },
        { "@type": "ListItem", "position": 2, "name": "Rituales Sagrados", "item": "https://marceanahata.com/rituales" },
        { "@type": "ListItem", "position": 3, "name": "Ritual de Cierre y Apertura", "item": serviceUrl }
      ]
    })}</script>
    <meta property="og:locale" content="es_CO" />
  </Fragment>
  
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image 
        src={ritualCierreImg} 
        alt="Mujer en ritual de limpieza energética con humo" 
        class="w-full h-full object-cover opacity-90"
        width={1920}
        densities={[1.5, 2]}
      />
      <div class="absolute inset-0 bg-[#5d5a8c]/40 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-orange-100/10 mix-blend-overlay"></div>
    </div>

    <div class="relative z-10 text-center text-white px-6 max-w-4xl mx-auto mt-20">
      <span class="uppercase tracking-[0.2em] text-sm md:text-base mb-4 block text-[#6ed8d9]">Renovación Energética</span>
      <h1 class="text-4xl md:text-6xl font-serif mb-6 leading-tight">{serviceInfo.title}</h1>
      <p class="text-lg md:text-xl font-light max-w-2xl mx-auto mb-8 opacity-95 text-stone-100">
        {serviceInfo.subtitle}
      </p>
      <a 
        href={whatsappLink}
        target="_blank"
        data-event="whatsapp_click"
        data-label="Closure & Opening Hero CTA"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-8 py-4 rounded-full font-medium hover:bg-white transition-all duration-300 transform hover:-translate-y-1 shadow-lg"
      >
        Iniciar mi Transformación
      </a>
    </div>
  </section>

  <section class="py-20 bg-stone-50 px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="relative">
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-[#5d5a8c]/20 rounded-xl z-0 rotate-2"></div>
        <img 
          src="https://images.unsplash.com/photo-1515549832467-8783363e19b6?q=80&w=1000&aspect_ratio=1:1&auto=format&fit=crop" 
          alt="Escribiendo intenciones y soltando el pasado" 
          class="rounded-xl shadow-xl relative z-10 w-full h-[500px] object-cover -rotate-2 hover:rotate-0 transition-transform duration-500"
        />
      </div>
      <div>
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-6">Para que entre lo nuevo, primero debe salir lo viejo</h2>
        <p class="text-[#243c5a]/80 mb-6 leading-relaxed">
          A menudo intentamos construir nuevos hábitos o atraer nuevas oportunidades sobre cimientos cargados de miedos, dudas y energía estancada del pasado. Es como intentar sembrar en un terreno lleno de maleza.
        </p>
        <p class="text-[#243c5a]/80 mb-8 leading-relaxed">
          Este ritual es una pausa consciente y potente. Utilizamos herramientas ancestrales para transmutar lo que te pesa y crear el espacio fértil necesario para que tus verdaderos deseos florezcan.
        </p>
        <ul class="space-y-4">
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">🌬️</span> Ligereza mental y emocional
          </li>
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">🔥</span> Transmutación de bloqueos
          </li>
          <li class="flex items-center gap-3 text-[#5d5a8c]">
            <span class="text-xl">🎯</span> Claridad láser en tus metas
          </li>
        </ul>
      </div>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">El Proceso de Transformación</h2>
      <p class="text-[#243c5a]/60">Tres fases diseñadas para resetear tu energía.</p>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-stone-50 p-8 rounded-xl text-center hover:shadow-md transition-shadow group border-b-4 border-[#5d5a8c]/20 hover:border-[#6ed8d9]">
        <div class="w-16 h-16 bg-[#5d5a8c]/10 group-hover:bg-[#6ed8d9]/20 transition-colors rounded-full flex items-center justify-center mx-auto mb-6 text-2xl">🪵</div>
        <h3 class="text-xl font-serif text-[#243c5a] mb-3">La Limpieza (El Fuego)</h3>
        <p class="text-sm text-[#243c5a]/70">Reconocemos y escribimos lo que ya no sirve. Usamos el fuego sagrado (real o simbólico) y el sahumerio para transmutar esa energía densa.</p>
      </div>
      <div class="bg-stone-50 p-8 rounded-xl text-center hover:shadow-md transition-shadow group border-b-4 border-[#5d5a8c]/20 hover:border-[#6ed8d9]">
        <div class="w-16 h-16 bg-[#5d5a8c]/10 group-hover:bg-[#6ed8d9]/20 transition-colors rounded-full flex items-center justify-center mx-auto mb-6 text-2xl">🧘</div>
        <h3 class="text-xl font-serif text-[#243c5a] mb-3">El Centro (El Vacío)</h3>
        <p class="text-sm text-[#243c5a]/70">A través de Kundalini Yoga y respiración, reseteamos el sistema nervioso y habitamos el espacio del "vacío fértil", donde todo es posible.</p>
      </div>
      <div class="bg-stone-50 p-8 rounded-xl text-center hover:shadow-md transition-shadow group border-b-4 border-[#5d5a8c]/20 hover:border-[#6ed8d9]">
        <div class="w-16 h-16 bg-[#5d5a8c]/10 group-hover:bg-[#6ed8d9]/20 transition-colors rounded-full flex items-center justify-center mx-auto mb-6 text-2xl">📝</div>
        <h3 class="text-xl font-serif text-[#243c5a] mb-3">La Siembra (La Visión)</h3>
        <p class="text-sm text-[#243c5a]/70">Desde la claridad, intencionamos el futuro. Visualización creativa y escritura de propósitos para anclar la nueva realidad.</p>
      </div>
    </div>
  </section>

  <section class="py-20 bg-[#243c5a] text-white px-6 relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-5"></div>
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-[#5d5a8c] rounded-full filter blur-[150px] opacity-30 mix-blend-screen"></div>
    <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-[#6ed8d9] rounded-full filter blur-[150px] opacity-20 mix-blend-screen"></div>

    <div class="max-w-4xl mx-auto text-center relative z-10">
      <h2 class="text-3xl md:text-5xl font-serif mb-8">Tu próximo capítulo comienza hoy</h2>
      
      <div class="bg-white/5 backdrop-blur-sm border border-white/10 rounded-2xl p-8 md:p-12 inline-block max-w-2xl w-full">
        <div class="flex flex-col md:flex-row justify-between items-center mb-8 gap-6 border-b border-white/10 pb-8">
            <div class="text-center md:text-left">
                <p class="text-[#6ed8d9] uppercase text-xs tracking-widest mb-1">Duración Aproximada</p>
                <p class="text-xl">{serviceInfo.duration}</p>
            </div>
            <div class="text-center md:text-right">
                <p class="text-[#6ed8d9] uppercase text-xs tracking-widest mb-1">Inversión del Ritual</p>
                <p class="text-3xl font-serif">{serviceInfo.price}</p>
            </div>
        </div>

        <p class="mb-8 text-white/90 font-light italic">
          "La claridad no llega pensando más, sino soltando lo que nubla tu visión."
        </p>

        <div class="flex flex-col gap-3">
          <a 
            href="/tarifas#rituales"            data-event="pricing_click"
            data-label="Cycle Closure Ritual - Pricing Link"            class="w-full block bg-white text-[#243c5a] py-4 rounded-xl font-bold hover:bg-[#6ed8d9] transition-colors"
          >
            Ver Precios
          </a>
          <a 
            href={whatsappLink}
            target="_blank"
            data-event="whatsapp_click"
            data-label="Closure & Opening CTA Final"
            class="w-full block bg-white/20 text-white py-4 rounded-xl font-bold hover:bg-white/40 transition-colors shadow-lg backdrop-blur-sm"
          >
            Agendar mi sesión de claridad
          </a>
        </div>
        <p class="mt-4 text-xs text-white/40">*Disponible en formato individual, de pareja o para grupos pequeños (consultar precios). Se requiere reserva previa con el 50% para separar fecha</p>
      </div>
    </div>
  </section>

  {ritualesPosts.length > 0 && (
    <section class="max-w-7xl mx-auto px-6 py-20 bg-stone-50">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-marce-base-3 mb-4">Artículos sobre Rituales</h2>
        <p class="text-stone-600 max-w-2xl mx-auto">Profundiza en el arte de los rituales y descubre cómo pueden transformar tu vida.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {ritualesPosts.map((post) => (
          <article class="bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300 border border-stone-100 flex flex-col">
            {post.data.image && (
              <div class="h-48 overflow-hidden">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                  loading="lazy"
                />
              </div>
            )}
            <div class="p-6 flex flex-col flex-grow">
              <time class="text-xs text-stone-500 mb-2 uppercase tracking-wider">
                {new Date(post.data.pubDate).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}
              </time>
              <h3 class="text-xl font-semibold text-marce-base-3 mb-3 leading-tight">
                {post.data.title}
              </h3>
              <p class="text-stone-600 text-sm mb-4 flex-grow leading-relaxed">
                {post.data.description}
              </p>
              <a
                href={`/blog/${post.slug}`}
                class="text-marce-base-1 font-semibold text-sm hover:text-marce-base-2 transition-colors inline-flex items-center gap-1"
              >
                Leer más
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </div>
          </article>
        ))}
      </div>

      <div class="text-center mt-12">
        <a
          href="/blog/tag/rituales"
          class="inline-block px-6 py-3 border-2 border-marce-base-1 text-marce-base-1 rounded-lg hover:bg-marce-base-1 hover:text-white transition-all font-semibold"
        >
          Ver todos los artículos sobre rituales
        </a>
      </div>
    </section>
  )}

  <section class="py-20 bg-white px-6">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Preguntas frecuentes sobre este ritual</h2>
        <p class="text-[#243c5a]/70 max-w-2xl mx-auto">Respuestas rápidas para ayudarte a reservar con claridad y confianza.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {faqItems.map((item) => (
          <article class="bg-stone-50 p-6 rounded-xl border border-stone-100 shadow-sm">
            <h3 class="text-lg font-semibold text-[#243c5a] mb-3">{item.question}</h3>
            <p class="text-sm text-[#243c5a]/80 leading-relaxed">{item.answer}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <div class="bg-stone-50">
  <!-- ══ También te puede interesar ══ -->
  <section class="py-16 bg-stone-50 px-6">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-2xl font-serif text-[#243c5a] mb-8 text-center">También te puede interesar</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <a href="/ritual-cumpleanos" class="group block bg-white rounded-xl p-5 border border-stone-100 hover:border-[#6ed8d9] hover:shadow-md transition-all">
          <span class="text-2xl block mb-2">🎂</span>
          <h3 class="font-semibold text-[#243c5a] text-sm group-hover:text-[#5d5a8c] transition-colors">Ritual de Cumpleaños</h3>
          <p class="text-xs text-stone-500 mt-1">Vuelta al sol consciente</p>
        </a>
        <a href="/ritual-pareja" class="group block bg-white rounded-xl p-5 border border-stone-100 hover:border-[#6ed8d9] hover:shadow-md transition-all">
          <span class="text-2xl block mb-2">💑</span>
          <h3 class="font-semibold text-[#243c5a] text-sm group-hover:text-[#5d5a8c] transition-colors">Ritual de Pareja</h3>
          <p class="text-xs text-stone-500 mt-1">Reconecta y sana el vínculo</p>
        </a>
        <a href="/ritual-baby-blessing" class="group block bg-white rounded-xl p-5 border border-stone-100 hover:border-[#6ed8d9] hover:shadow-md transition-all">
          <span class="text-2xl block mb-2">🌸</span>
          <h3 class="font-semibold text-[#243c5a] text-sm group-hover:text-[#5d5a8c] transition-colors">Baby Blessing</h3>
          <p class="text-xs text-stone-500 mt-1">Bienvenida sagrada al bebé</p>
        </a>
        <a href="/ritual-despedida-soltera" class="group block bg-white rounded-xl p-5 border border-stone-100 hover:border-[#6ed8d9] hover:shadow-md transition-all">
          <span class="text-2xl block mb-2">✨</span>
          <h3 class="font-semibold text-[#243c5a] text-sm group-hover:text-[#5d5a8c] transition-colors">Despedida de Soltera</h3>
          <p class="text-xs text-stone-500 mt-1">Círculo consciente para la novia</p>
        </a>
      </div>
    </div>
  </section>

    <ReviewsSection />
  </div>

</Layout>