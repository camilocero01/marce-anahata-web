---
// src/pages/circulo-mujeres-conscientes-v2.astro
// PROPUESTA ALTERNATIVA - Enfoque narrativo y emocional
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import ritualesImg from '../assets/ritual/circulo-mujeres-conciente-medellin.jpg';

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent('Hola Marce, me interesa el Círculo de Mujeres. ¿Cuándo es el próximo encuentro?')}`;

// Posts relacionados con círculo de mujeres o cacao
const relatedPosts = (await getCollection('blog', ({ data, slug }) =>
  !data.draft && !slug.startsWith('en/') && (
    data.tags.includes('círculo de mujeres') || data.tags.includes('cacao') || data.tags.includes('ritual')
  )
))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout 
  title="Círculo de Mujeres Conscientes en Medellín | Marce Anahata"
  description="Encuentros mensuales de mujeres en El Poblado, Medellín. Un espacio sagrado de ritual, sonido y hermandad para reconectar, sanar y renacer juntas."
>
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://marceanahata.com' },
        { '@type': 'ListItem', position: 2, name: 'Círculo de Mujeres', item: 'https://marceanahata.com/circulo-mujeres-conscientes' },
      ],
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Event',
      name: 'Círculo de Mujeres Conscientes',
      description: 'Encuentro mensual de mujeres en Medellín para rituales de conexión femenina, terapia de sonido, meditación y hermandad. Un espacio sagrado donde las mujeres se reúnen para sanar, recordar y renacer juntas.',
      eventSchedule: {
        '@type': 'Schedule',
        repeatFrequency: 'P1M',
        byDay: 'Saturday',
        startTime: '19:00',
        endTime: '22:00'
      },
      location: {
        '@type': 'Place',
        name: 'Marce Anahata Centro de Bienestar',
        address: {
          '@type': 'PostalAddress',
          streetAddress: 'Cl. 11A Sur #46-12',
          addressLocality: 'Medellín',
          addressRegion: 'Antioquia',
          postalCode: '050012',
          addressCountry: 'CO'
        },
        geo: {
          '@type': 'GeoCoordinates',
          latitude: 6.2092,
          longitude: -75.5697
        }
      },
      organizer: {
        '@type': 'Person',
        name: 'Marce Anahata',
        url: 'https://marceanahata.com/sobre-mi',
        sameAs: ['https://www.instagram.com/marceanahata/']
      },
      audience: {
        '@type': 'Audience',
        audienceType: 'Mujeres buscando conexión, sanación femenina y autoconocimiento',
        geographicArea: {
          '@type': 'City',
          name: 'Medellín'
        }
      },
      keywords: 'círculo de mujeres, mujeres conscientes, Medellín, rituales femeninos, luna llena, luna nueva, sororidad, hermandad femenina, sanación femenina, terapia de sonido para mujeres, encuentros de mujeres, medicina femenina, ciclo menstrual, feminidad sagrada',
      aggregateRating: {
        '@type': 'AggregateRating',
        ratingValue: '5.0',
        reviewCount: '11',
        bestRating: '5',
        worstRating: '1'
      }
    })}</script>
  </Fragment>

  <!-- Hero con texto superpuesto fluido -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={ritualesImg}
        alt="Mujeres en círculo sagrado"
        class="w-full h-full object-cover"
        width={960}
        densities={[1.5]}
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-[#243c5a]/60 via-[#5d5a8c]/50 to-[#243c5a]/70"></div>
    </div>

    <div class="relative z-10 text-center text-white px-6 max-w-5xl mx-auto">
      <div class="mb-8">
        <svg class="w-16 h-16 mx-auto mb-6 text-[#6ed8d9] opacity-80" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-1-13h2v6h-2zm0 8h2v2h-2z"/>
        </svg>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-serif mb-8 leading-tight">
        El círculo es medicina <br/>
        <span class="text-[#6ed8d9] italic">cuando dejamos de estar solas</span>
      </h1>
      
      <p class="text-xl md:text-2xl font-light max-w-3xl mx-auto mb-4 leading-relaxed text-stone-100">
        Un espacio donde tu voz importa, tu proceso es honrado y tu energía se transforma en comunidad.
      </p>
      
      <p class="text-lg text-stone-200/90 mb-12 max-w-2xl mx-auto">
        Nos encontramos una vez al mes para ritualizar, movernos, cantar y recordar que sanamos mejor juntas.
      </p>

      <a 
        href={whatsappLink} 
        target="_blank"
        data-event="whatsapp_click" 
        data-label="Women Circle V2 Hero CTA"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-10 py-5 rounded-full text-lg font-bold hover:bg-white transition-all duration-300 transform hover:scale-105 shadow-2xl"
      >
        Quiero formar parte
      </a>
      <div class="mt-6">
        <a
          href="/#eventos"
          class="text-sm font-semibold text-white/90 hover:text-white underline underline-offset-4 decoration-white/60 transition-colors"
        >
          Ver próximos eventos
        </a>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 z-10">
      <div class="animate-bounce">
        <svg class="w-6 h-6 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </div>
    </div>
  </section>

  <!-- Sección narrativa: Por qué el círculo -->
  <section class="py-24 bg-gradient-to-b from-stone-50 to-white px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">El llamado</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          ¿Por qué nos sentamos en círculo?
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="prose prose-lg max-w-none text-[#243c5a]/80 space-y-6 leading-relaxed">
          <p class="text-xl font-light text-[#243c5a] italic border-l-4 border-[#6ed8d9] pl-6">
            Porque durante siglos, las mujeres nos hemos sentado juntas: alrededor del fuego, bajo la luna, en los momentos de celebración y en los de quebranto.
          </p>
          
          <p>
            En el círculo no hay jerarquías. No hay quien sabe más o menos. Hay miradas que se sostienen, voces que se escuchan y corazones que laten juntos. Es un espacio donde <strong>tu historia importa</strong> y donde el simple hecho de estar presente ya es medicina.
          </p>

          <p>
            Aquí no venimos a arreglarnos ni a convertirnos en otra cosa. Venimos a <strong>recordar</strong> lo que siempre hemos sido: <em>poderosas, sensibles, capaces de transformar el dolor en sabiduría.</em>
          </p>

          <div class="bg-[#5d5a8c]/5 p-8 rounded-2xl my-12 border-l-4 border-[#5d5a8c]">
            <p class="text-lg text-[#243c5a] mb-0">
              <strong>El círculo es un recordatorio:</strong> No estás sola en lo que sientes. No estás rota. Y mereces un espacio donde puedas bajar las máscaras y simplemente <em>ser</em>.
            </p>
          </div>
        </div>

        <div class="relative">
          <div class="absolute -inset-4 bg-gradient-to-br from-[#6ed8d9]/20 to-[#5d5a8c]/20 rounded-3xl blur-2xl"></div>
          <div class="relative overflow-hidden rounded-3xl border border-stone-200/80 shadow-xl">
            <Image
              src={ritualesImg}
              alt="Círculo de mujeres en conexión"
              class="w-full h-full object-cover"
              width={640}
              height={480}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección: Qué vivimos juntas -->
  <section class="py-24 bg-white px-6 relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-[#6ed8d9]/10 rounded-full filter blur-[100px]"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-[#5d5a8c]/10 rounded-full filter blur-[100px]"></div>

    <div class="max-w-6xl mx-auto relative z-10">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">La experiencia</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Qué vivimos juntas
        </h2>
        <p class="text-lg text-[#243c5a]/70 max-w-2xl mx-auto">
          Cada encuentro es una ceremonia. Una experiencia viva que honra el cuerpo, la voz y la presencia.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <!-- Práctica 1 -->
        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#6ed8d9]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#6ed8d9]/30 transition-colors">
            <svg class="w-7 h-7 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Movimiento Somático</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            Movimientos suaves que regulan el sistema nervioso, liberan tensiones y te reconectan con las sensaciones del cuerpo. Sin pasos que memorizar, solo escucha interna.
          </p>
        </div>

        <!-- Práctica 2 -->
        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#5d5a8c]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#5d5a8c]/30 transition-colors">
            <svg class="w-7 h-7 text-[#5d5a8c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11a7 7 0 01-7 7m0 0a7 7 0 01-7-7m7 7v4m0 0H8m4 0h4m-4-8a3 3 0 01-3-3V5a3 3 0 116 0v6a3 3 0 01-3 3z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Voz y Mantra</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            Usamos la voz como instrumento de sanación. Cantamos juntas, dejamos que el sonido vibre en el pecho y activamos la expresión genuina sin miedo al juicio.
          </p>
        </div>

        <!-- Práctica 3 -->
        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#6ed8d9]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#6ed8d9]/30 transition-colors">
            <svg class="w-7 h-7 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Ritual y Journaling</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            Ritualizamos nuestras intenciones y procesos. Escribimos, soltamos, sembramos. Honramos las transiciones con consciencia y presencia amorosa.
          </p>
        </div>

        <!-- Práctica 4 -->
        <div class="group bg-gradient-to-br from-stone-50 to-white p-8 rounded-3xl border border-stone-100 hover:shadow-xl transition-all duration-300">
          <div class="w-14 h-14 bg-[#5d5a8c]/20 rounded-full flex items-center justify-center mb-6 group-hover:bg-[#5d5a8c]/30 transition-colors">
            <svg class="w-7 h-7 text-[#5d5a8c]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">Escucha y Compartir</h3>
          <p class="text-[#243c5a]/70 leading-relaxed">
            Nos escuchamos sin interrumpir, sin aconsejar, sin arreglar. Solo sosteniendo el espacio para que cada mujer se sienta vista y honrada en su verdad.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Sección: Para quién es -->
  <section class="py-24 bg-gradient-to-b from-[#243c5a] to-[#5d5a8c] text-white px-6 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('/images/hero-bg.webp')] opacity-5"></div>
    
    <div class="max-w-5xl mx-auto relative z-10">
      <div class="text-center mb-16">
        <span class="text-[#6ed8d9] uppercase tracking-[0.3em] text-sm font-semibold">Reconócete</span>
        <h2 class="text-4xl md:text-5xl font-serif mt-4 mb-6">
          Este círculo es para ti si...
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
        <div class="text-center">
          <div class="text-5xl mb-4">🌙</div>
          <p class="text-white/90 leading-relaxed">
            Te sientes desconectada de ti misma y buscas volver al centro con herramientas reales.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-5xl mb-4">💫</div>
          <p class="text-white/90 leading-relaxed">
            Quieres un espacio seguro donde tu voz y tu proceso sean honrados sin juicio.
          </p>
        </div>
        
        <div class="text-center">
          <div class="text-5xl mb-4">🌸</div>
          <p class="text-white/90 leading-relaxed">
            Buscas comunidad de mujeres conscientes que también están en el camino de recordar.
          </p>
        </div>
      </div>

      <div class="bg-white/10 backdrop-blur-sm p-10 rounded-3xl border border-white/20 text-center">
        <p class="text-2xl font-light mb-6 leading-relaxed">
          "No necesitas estar 'lista' ni 'bien'. <br/>
          Solo necesitas <strong>querer estar presente</strong>."
        </p>
        <p class="text-[#6ed8d9] font-serif text-lg">— Marce Anahata</p>
      </div>
    </div>
  </section>

  <!-- Sección: Detalles prácticos -->
  <section class="py-24 bg-stone-50 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">Logística</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Información práctica
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
            </svg>
            Frecuencia
          </h3>
          <p class="text-[#243c5a]/70 mb-4">
            Nos encontramos <strong>una vez al mes</strong>, generalmente los fines de semana.
            <a href="/#eventos" class="ml-2 text-[#5d5a8c] font-semibold hover:text-[#243c5a] underline underline-offset-4">
              Ver próximos eventos
            </a>
          </p>
          <p class="text-sm text-[#243c5a]/60">Las fechas se anuncian con 2 semanas de anticipación vía WhatsApp a las mujeres inscritas.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            Duración
          </h3>
          <p class="text-[#243c5a]/70 mb-4">Cada círculo dura <strong>2 a 3 horas</strong>.</p>
          <p class="text-sm text-[#243c5a]/60">Te recomendamos no tener compromisos después para que puedas integrar la experiencia con calma.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            Ubicación
          </h3>
          <p class="text-[#243c5a]/70 mb-4"><strong>El Poblado, Medellín</strong></p>
          <p class="text-sm text-[#243c5a]/60">Espacio cálido, privado y preparado para el encuentro. La dirección exacta se comparte al confirmar cupo.</p>
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-3">
            <svg class="w-6 h-6 text-[#6ed8d9]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/>
            </svg>
            Cupos
          </h3>
          <p class="text-[#243c5a]/70 mb-4"><strong>Máximo 12 mujeres</strong> por círculo.</p>
          <p class="text-sm text-[#243c5a]/60">Los cupos son limitados para mantener la intimidad y la calidad del espacio compartido.</p>
        </div>
      </div>

      <div class="mt-12 bg-gradient-to-r from-[#5d5a8c] to-[#6ed8d9] p-8 rounded-2xl text-white text-center">
        <h3 class="text-2xl font-serif mb-4">¿Qué llevar?</h3>
        <div class="flex flex-wrap justify-center gap-4 text-sm">
          <span class="bg-white/20 px-4 py-2 rounded-full">Ropa cómoda</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">Diario personal (opcional)</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">Botella de agua</span>
          <span class="bg-white/20 px-4 py-2 rounded-full">Corazón abierto</span>
        </div>
        <p class="mt-6 text-sm text-white/80">*Colchonetas, mantas y elementos del ritual están incluidos.</p>
      </div>
    </div>
  </section>

  <!-- FAQ Section with Schema.org -->
  <section class="py-24 bg-stone-50 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-16">
        <span class="text-[#5d5a8c] uppercase tracking-[0.3em] text-sm font-semibold">Preguntas Frecuentes</span>
        <h2 class="text-4xl md:text-5xl font-serif text-[#243c5a] mt-4 mb-6">
          Todo lo que necesitas saber
        </h2>
        <p class="text-lg text-[#243c5a]/70">
          Respuestas claras para que llegues al círculo con confianza y claridad.
        </p>
      </div>

      <div class="space-y-6">
        <!-- FAQ 1 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100" itemscope itemtype="https://schema.org/Question">
          <h3 class="text-xl font-serif text-[#243c5a] mb-4" itemprop="name">
            ¿Qué es el Círculo de Mujeres Conscientes de Marce Anahata?
          </h3>
          <div itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
            <div itemprop="text" class="text-[#243c5a]/80 leading-relaxed">
              <p class="mb-4">Es un encuentro mensual en Medellín donde mujeres se reúnen en un espacio sagrado para conectar consigo mismas y con otras a través de rituales, terapia de sonido, meditación y círculo de palabra.</p>
              <p>No es terapia grupal ni un taller. Es un espacio de hermandad donde cada mujer puede ser escuchada sin juicios y donde sanamos mejor juntas.</p>
            </div>
          </div>
        </div>

        <!-- FAQ 2 -->
        <div class="bg-white p-8 rounded-2xl shadow-sm border border-stone-100" itemscope itemtype="https://schema.org/Question">
