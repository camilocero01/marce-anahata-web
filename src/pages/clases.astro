---
// src/pages/clases.astro
import Layout from '../layouts/Layout.astro';
import ReviewsSection from '../components/cards/ReviewsSection.astro';
import { Image } from 'astro:assets';
import claseYogaLandingImg from '../assets/clase/clase-yoga-landing.webp';
import { getCollection } from 'astro:content';

// --- DATOS GENERALES ---
const pageInfo = {
  title: "Clases y Talleres de Kundalini Yoga en Envigado - La Frontera con El Poblado",
  subtitle: "Tecnología sagrada para fortalecer tu cuerpo, calmar la mente y despertar tu energía vital en el día a día.",
  whatsappMessageGeneral: "Hola Marce Anahata, estoy interesad@ en tus clases de Kundalini Yoga. ¿Podrías compartirme información sobre precios y packs mensuales?",
};

const whatsappLinkGeneral = `https://wa.me/573207329921?text=${encodeURIComponent(pageInfo.whatsappMessageGeneral)}`; // CAMBIA TU NÚMERO AQUÍ
const serviceUrl = 'https://www.marceanahata.com/clases';

const faqItems = [
  {
    question: '¿Qué incluyen las clases de Kundalini Yoga en Medellín?',
    answer:
      'Incluyen kriyas, pranayamas, meditación y mantras para fortalecer sistema nervioso, mejorar enfoque y elevar la energía vital en la vida diaria.'
  },
  {
    question: '¿Dónde se dictan las clases de yoga?',
    answer:
      'Las clases se realizan en nuestro Centro de Bienestar en Envigado, zona La Frontera con El Poblado (Cl. 23 Sur #42B-60). Estamos a 2 minutos de El Poblado, fácil acceso desde Medellín y Envigado.'
  },
  {
    question: '¿Necesito experiencia previa para empezar?',
    answer:
      'No necesitas experiencia previa. Las clases están adaptadas para personas principiantes y practicantes con experiencia.'
  },
  {
    question: '¿Qué modalidades de práctica ofrecen?',
    answer:
      'Ofrecemos clases grupales regulares, sesiones privadas 1:1 y talleres temáticos profundos.'
  },
  {
    question: '¿Cómo puedo reservar mi clase?',
    answer:
      'Puedes reservar por WhatsApp desde esta página para conocer horarios vigentes, packs mensuales y opciones personalizadas.'
  },
  {
    question: '¿Ofrecen clases de Pilates cerca de El Poblado o Envigado?',
    answer:
      'No dictamos Pilates tradicional, pero contamos con Yogalates —una fusión que combina los principios de Pilates con la profundidad del yoga— y Barre Balance, que trabaja fuerza, equilibrio y postura con técnica de barra. Muchos estudiantes los eligen como alternativa directa al Pilates. Escríbenos y te contamos cuál se adapta mejor a tu objetivo.'
  },
  {
    question: '¿Cuál es la diferencia entre Yogalates y Pilates tradicional?',
    answer:
      'El Pilates tradicional trabaja principalmente el core con equipos especializados o en mat. Yogalates fusiona esos principios de fuerza central y postura con el trabajo de respiración, mindfulness y energía del yoga. El resultado es una práctica que tonifica y al mismo tiempo calma el sistema nervioso — sin necesitar máquinas ni equipos especiales.'
  },
  {
    question: '¿Hay clases de yoga los sábados en Envigado?',
    answer:
      'Sí. Los sábados a las 9:00 AM dictamos Kundalini Yoga en nuestro Centro de Bienestar (Cl. 23 Sur #42B-60, Envigado, zona La Frontera con El Poblado). Es una clase ideal para arrancar el fin de semana con energía. Se recomienda confirmar disponibilidad por WhatsApp.'
  },
  {
    question: '¿Cuánto cuestan las clases de yoga en Envigado y El Poblado?',
    answer:
      'Manejamos packs mensuales con acceso a todas las clases grupales de la semana. Para conocer precios actualizados, packs disponibles y opciones personalizadas, visita nuestra página de tarifas o escríbenos por WhatsApp y te respondemos al momento.'
  },
  {
    question: '¿Qué es Barre Balance y para quién es?',
    answer:
      'Barre Balance es una práctica que combina técnica de barra de ballet con ejercicios funcionales de fuerza, equilibrio y postura. No necesitas experiencia en danza. Es especialmente útil para quienes buscan tonificar sin impacto articular, mejorar la postura o encontrar una alternativa dinámica al Pilates o al yoga más pasivo. Clases los jueves a las 7:00 PM.'
  }
];

// 3 posts aleatorios con tags "yoga" o "meditación"
const yogaPosts = (await getCollection('blog', ({ data, slug }) =>
  !data.draft && !slug.startsWith('en/') && (data.tags.includes('yoga') || data.tags.includes('meditación'))
))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

// --- DEFINICIÓN DE LAS OFERTAS (Puedes editar esto fácilmente) ---
const offerings = [
  {
    icon: "🧘‍♀️",
    title: "Clases Regulares (Grupales)",
    description: "Tu espacio semanal de mantenimiento energético. Clases abiertas al público en nuestro Centro de Bienestar, con horarios fijos cada semana. Ideal para quienes buscan una práctica constante en comunidad.",
    details: ["En el Centro de Bienestar", "Horarios fijos semanales", "Grupo abierto — sin inscripción previa", "Packs mensuales disponibles"],
    scheduleLink: "/clases#horarios",
    cta: "Reservar Ahora",
    whatsappMsg: "Hola Marce Anahata, quiero reservar mi lugar en las clases grupales regulares. ¿Cómo procedo?",
    tarifaLink: "/tarifas#clases-grupales"
  },
  {
    icon: "✨",
    title: "Sesiones Privadas (1 a 1)",
    description: "Acompañamiento personalizado en nuestro Centro de Bienestar con un grupo cerrado y exclusivo. La práctica se diseña según las necesidades específicas del grupo: ansiedad, propósito, vitalidad, etc.",
    details: ["En el Centro de Bienestar", "Grupo cerrado y personalizado", "Horarios acordados con el grupo", "Seguimiento y progresión"],
    cta: "Agendar Sesión",
    whatsappMsg: "Hola Marce Anahata, quiero agendar una sesión privada de yoga personalizada. ¿Qué disponibilidad tienes?",
    tarifaLink: "/tarifas#clases-personalizadas"
  },
  {
    icon: "🔮",
    title: "Talleres Temáticos Profundos",
    description: "Inmersiones de mayor duración realizadas por fuera del Centro de Bienestar, en espacios especiales según la temática. Diseñadas a medida para grupos, empresas o comunidades con un propósito concreto.",
    details: ["Fuera del Centro de Bienestar", "Espacio adaptado a la temática", "Diseño personalizado por grupo", "Temáticas: chakras, prosperidad, sanación y más"],
    cta: "Consultar Talleres",
    whatsappMsg: "Hola Marce Anahata, quisiera información sobre los próximos talleres temáticos disponibles.",
    tarifaLink: "/tarifas#talleres"
  }
];
---

<Layout title="Clases de Yoga en Envigado — La Frontera con El Poblado | Marce Anahata" description="Clases de yoga en Envigado a 2 minutos de El Poblado. Kundalini Yoga, Yin Yoga, Yogalates, Yoga Nidra, Vinyasa Detox, Barre Balance y más. Grupos abiertos y sesiones privadas en La Frontera.">
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://www.marceanahata.com"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Clases y Talleres",
          "item": "https://www.marceanahata.com/clases"
        }
      ]
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Service",
      "name": "Clases de Yoga en Envigado — La Frontera con El Poblado",
      "description": "Clases de yoga presenciales en Envigado, a 2 minutos de El Poblado. Kundalini Yoga, Yin Yoga, Yogalates, Yoga Nidra, Yoga Restaurativo, Vinyasa Detox, Barre Balance y más. Grupos abiertos con horarios fijos y sesiones privadas personalizadas.",
      "serviceType": "Yoga Classes",
      "provider": {
        "@type": "Person",
        "name": "Marce Anahata",
        "url": "https://www.marceanahata.com/sobre-mi"
      },
      "areaServed": [
        { "@type": "City", "name": "Envigado" },
        { "@type": "Neighborhood", "name": "El Poblado" },
        { "@type": "Neighborhood", "name": "La Frontera" },
        { "@type": "City", "name": "Medellín" }
      ],
      "offers": {
        "@type": "Offer",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      },
      "url": serviceUrl,
      "keywords": "clases de yoga Envigado, yoga El Poblado, yoga La Frontera Envigado, Kundalini Yoga, Yin Yoga, Yogalates, Yoga Nidra, Yoga Restaurativo, Vinyasa Detox, Barre Balance, clases de yoga Medellín, pranayama, meditación, bienestar integral, pilates Envigado, pilates El Poblado, pilates La Frontera, alternativa pilates Medellín, clases pilates Envigado, pilates y yoga Envigado",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Course",
      "name": "Clases de Yoga en Envigado — La Frontera con El Poblado",
      "description": "Clases de yoga presenciales en Envigado, zona La Frontera con El Poblado. Kundalini Yoga, Yin Yoga y Pranayama, Yogalates, Yoga Nidra, Yoga Restaurativo, Vinyasa Detox, Barre Balance y más. Horarios de lunes a sábado. Aptas para principiantes y practicantes con experiencia.",
      "url": serviceUrl,
      "inLanguage": "es",
      "teaches": ["Kundalini Yoga", "Yin Yoga", "Pranayama", "Yoga Nidra", "Yoga Restaurativo", "Yogalates", "Vinyasa Detox", "Barre Balance", "Yoga para la Ansiedad", "Meditación", "Kriyas", "Mantras"],
      "educationalLevel": "Principiante a avanzado",
      "provider": {
        "@type": "Person",
        "@id": "https://www.marceanahata.com/#person",
        "name": "Marce Anahata",
        "url": "https://www.marceanahata.com/sobre-mi"
      },
      "hasCourseInstance": [
        {
          "@type": "CourseInstance",
          "name": "Clases Regulares de Kundalini Yoga — Grupales",
          "courseMode": ["ONSITE", "ONLINE"],
          "courseSchedule": {
            "@type": "Schedule",
            "repeatFrequency": "P1W",
            "scheduleTimezone": "America/Bogota"
          },
          "location": {
            "@type": "Place",
            "name": "Marce Anahata Centro de Bienestar — La Frontera con El Poblado",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
              "addressLocality": "Envigado",
              "addressRegion": "Antioquia",
              "addressCountry": "CO"
            }
          }
        },
        {
          "@type": "CourseInstance",
          "name": "Sesión Privada de Kundalini Yoga 1 a 1",
          "courseMode": "ONSITE",
          "description": "Acompañamiento personalizado diseñado según necesidades específicas: ansiedad, propósito, vitalidad."
        },
        {
          "@type": "CourseInstance",
          "name": "Taller Temático Profundo de Kundalini Yoga",
          "courseMode": "ONSITE",
          "description": "Inmersiones de mayor duración sobre temas como Prosperidad, Relaciones, Sanación de Linaje y Chakras."
        }
      ],
      "offers": {
        "@type": "Offer",
        "priceCurrency": "COP",
        "availability": "https://schema.org/InStock",
        "url": serviceUrl
      }
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": faqItems.map((item) => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": item.answer
        }
      }))
    })}</script>
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": ["HealthAndBeautyBusiness", "SportsActivityLocation"],
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Centro de Bienestar",
      "description": "Centro de bienestar en Envigado (La Frontera con El Poblado) especializado en Kundalini Yoga, Yin Yoga, Yogalates, Barre Balance, Yoga Nidra, Vinyasa Detox, terapia de sonido y rituales sagrados.",
      "url": "https://www.marceanahata.com",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "image": "https://www.marceanahata.com/images/social-preview-wa.jpg",
      "priceRange": "$$",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 23 Sur #42B-60, Los Cristales",
        "addressLocality": "Envigado",
        "addressRegion": "Antioquia",
        "addressCountry": "CO"
      },
      "sameAs": [
        "https://www.instagram.com/marce_anahata/",
        "https://www.youtube.com/@marce_anahata",
        "https://www.tiktok.com/@marce_anahata"
      ],
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "08:30", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:30", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "07:30", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "08:30", "closes": "20:30" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "08:30", "closes": "18:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "09:00", "closes": "11:00" }
      ],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "5.0",
        "reviewCount": "11",
        "bestRating": "5",
        "worstRating": "1"
      }
    })}</script>
  </Fragment>
  
  <section class="relative h-[70vh] flex items-center justify-center overflow-hidden">

    <video
      class="absolute inset-0 w-full h-full object-cover z-0 opacity-60"
      autoplay
      loop
      muted
      playsinline
      preload="metadata"
      poster="/images/clases-yoga-poster.webp"
    >
      <source src="/videos/clases-yoga.mp4" type="video/mp4" />
    </video>

    <div class="absolute inset-0 bg-white opacity-30 z-10"></div>

    <div class="relative z-20 text-center text-[#243c5a] px-6 max-w-4xl mx-auto mt-20">
      <span class="uppercase tracking-[0.2em] text-sm md:text-base mb-4 block text-[#5d5a8c] font-bold">Tu Práctica Diaria</span>
      <h1 class="text-4xl md:text-6xl font-serif mb-6 leading-tight">{pageInfo.title}</h1>
      <p class="text-lg md:text-xl font-light max-w-2xl mx-auto mb-8 opacity-90 text-[#243c5a]">
        {pageInfo.subtitle}
      </p>
      <a
        href={whatsappLinkGeneral}
        target="_blank"
        data-event="whatsapp_click"
        data-label="Kundalini Classes Hero CTA"
        class="inline-block bg-[#6ed8d9] text-[#243c5a] px-8 py-4 rounded-full font-medium hover:bg-[#243c5a] hover:text-white transition-all duration-300 transform hover:-translate-y-1 shadow-lg"
      >
        Empezar a Practicar
      </a>
    </div>
  </section>

  <section class="py-20 bg-white px-6">
    <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="relative order-2 md:order-1">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[110%] h-[110%] bg-[#5d5a8c]/5 rounded-full z-0"></div>
        <Image 
          src={claseYogaLandingImg} 
          alt="Maestra de yoga meditando" 
          class="rounded-lg shadow-xl relative z-10 w-full h-[500px] object-cover grayscale hover:grayscale-0 transition-all duration-700"
          width={600}
          height={500}
          densities={[1.5, 2]}
        />
      </div>
      <div class="order-1 md:order-2">
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-6">Yoga para la vida real, no solo para el mat</h2>
        <p class="text-[#243c5a]/80 mb-6 leading-relaxed text-lg">
          Vivimos tiempos rápidos y exigentes. Kundalini Yoga (el Yoga de la Conciencia) es una herramienta potente diseñada precisamente para esto. No se trata de ser flexible físicamente, sino de tener una <strong>mente flexible y un sistema nervioso resiliente</strong>.
        </p>
        <p class="text-[#243c5a]/80 mb-8 leading-relaxed text-lg">
          A través de la combinación precisa de movimiento, respiración (pranayama), sonido (mantra) y enfoque, logramos cambios rápidos en nuestra química interna, pasando del estrés a la vitalidad en minutos. Para profundizar aún más en el trabajo con frecuencias y vibración, muchos estudiantes complementan su práctica con <a href="/terapia-sonido" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">sesiones de terapia de sonido</a>, creando una sinergia poderosa entre ambas disciplinas.
        </p>
        <div class="flex gap-4 flex-wrap font-medium text-[#5d5a8c]">
            <span class="bg-[#5d5a8c]/10 px-4 py-2 rounded-full">Calma Mental</span>
            <span class="bg-[#5d5a8c]/10 px-4 py-2 rounded-full">Vitalidad Física</span>
            <span class="bg-[#5d5a8c]/10 px-4 py-2 rounded-full">Conexión Espiritual</span>
        </div>
        <p class="text-[#243c5a]/70 mt-4 text-sm">
          📍 Estamos en <strong class="text-[#243c5a]">Envigado, zona La Frontera con El Poblado</strong> — a 2 minutos de El Poblado, con clases de lunes a sábado.
        </p>
        <p class="text-[#243c5a]/70 mt-3 text-sm italic">
          ¿Tu empresa busca herramientas para el manejo del estrés? Conoce nuestros <a href="/bienestar-corporativo" class="text-[#5d5a8c] font-medium hover:text-[#6ed8d9] transition-colors underline decoration-[#6ed8d9]/50">talleres de bienestar corporativo personalizados</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-stone-50 px-6" id="modalidades">
    <div class="max-w-4xl mx-auto text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Modalidades de Práctica</h2>
      <p class="text-[#243c5a]/70 text-lg">Encuentra el formato que mejor se adapta a tu momento actual.</p>
    </div>

    <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-3 gap-8">
      {offerings.map((offer) => {
        const whatsappLinkOffer = `https://wa.me/573207329921?text=${encodeURIComponent(offer.whatsappMsg)}`; // CAMBIA TU NÚMERO AQUÍ
        return (
        <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 group border border-stone-100 flex flex-col relative overflow-hidden">
          <div class="absolute top-0 left-0 w-full h-1 bg-[#6ed8d9] transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left"></div>
          
          <div class="text-5xl mb-6 filter drop-shadow-sm">{offer.icon}</div>
          <h3 class="text-2xl font-serif text-[#243c5a] mb-4">{offer.title}</h3>
          <p class="text-[#243c5a]/70 mb-8 leading-relaxed flex-grow">{offer.description}</p>
          
          <ul class="mb-4 space-y-3">
            {offer.details.map((detail) => (
                <li class="flex items-center gap-2 text-sm text-[#5d5a8c] font-medium">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="w-5 h-5 text-[#6ed8d9]">
                      <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd" />
                    </svg>
                    {detail}
                </li>
            ))}
          </ul>

          {'scheduleLink' in offer && (
            <a
              href={offer.scheduleLink}
              class="inline-flex items-center gap-1.5 text-sm text-[#243c5a] font-medium hover:text-[#5d5a8c] transition-colors mb-6"
            >
              <svg class="w-4 h-4 text-[#6ed8d9]" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
              </svg>
              Ver horarios disponibles →
            </a>
          )}

          <div class="flex flex-col gap-3">
            <a 
              href={offer.tarifaLink}
              class="text-center w-full py-3 rounded-lg bg-[#6ed8d9] text-[#243c5a] font-semibold hover:bg-[#5d5a8c] hover:text-white transition-colors shadow-sm"
            >
              Ver Precios
            </a>
            <a 
              href={whatsappLinkOffer}
              target="_blank"
              rel="noopener noreferrer"
              data-event="whatsapp_click"
              data-label="Kundalini Classes Offer Card CTA"
              class="text-center w-full py-3 rounded-lg border-2 border-[#243c5a] text-[#243c5a] font-semibold hover:bg-[#243c5a] hover:text-white transition-colors"
            >
              {offer.cta}
            </a>
          </div>
        </div>
      )})}
    </div>
  </section>

  <section class="py-24 bg-white px-6" id="horarios">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <span class="uppercase tracking-[0.2em] text-sm mb-4 block text-[#6ed8d9] font-medium">Nuestro Calendario</span>
        <h2 class="text-3xl md:text-4xl font-serif text-[#243c5a] mb-4">Horarios Vigentes</h2>
        <p class="text-[#243c5a]/70 text-lg max-w-2xl mx-auto">Elige el horario que mejor se adapte a tu rutina. Todas nuestras clases combaten el estrés y despiertan tu vitalidad.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">

        {/* LUNES */}
        <div class="group relative">
          <div class="absolute -inset-0.5 bg-gradient-to-r from-[#5d5a8c] to-[#6ed8d9] rounded-2xl opacity-20 group-hover:opacity-100 transition duration-300 blur"></div>
          <div class="relative bg-white rounded-2xl p-6 border border-[#6ed8d9]/30 hover:border-[#6ed8d9] transition-all">
            <h3 class="text-xl font-serif text-[#243c5a] mb-4 flex items-center gap-2">
              <span class="text-2xl">📅</span>
              Lunes
            </h3>
            <div class="space-y-4">
