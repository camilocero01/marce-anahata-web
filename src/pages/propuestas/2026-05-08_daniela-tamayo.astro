---
import Layout from '../../layouts/Layout.astro';
---

<Layout
  title="Ritual Sagrado de Cumpleaños · Daniela Tamayo · Marce Anahata"
  description="Propuesta personalizada de Ritual Sagrado de Cumpleaños para Daniela Tamayo — 11 de mayo de 2026."
  lang="es"
  includeAlternates={false}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow" />
  </Fragment>

  <!-- ═══════════════════════════════════════════════════
       HERO
  ════════════════════════════════════════════════════ -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">

    <div
      class="absolute inset-0 z-0"
      style="background: linear-gradient(145deg, #1a2d45 0%, #243c5a 45%, #3d3a6e 100%)"
    ></div>

    <!-- Orbs decorativos -->
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-10 blur-3xl z-0" style="background: #6ed8d9"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full opacity-10 blur-3xl z-0" style="background: #5d5a8c"></div>

    <div class="relative z-10 text-center px-6 max-w-3xl mx-auto py-20">
      <span class="uppercase tracking-[0.3em] text-xs md:text-sm font-bold text-[#6ed8d9] mb-6 block">
        Propuesta exclusiva · Mayo 2026
      </span>
      <h1 class="font-serif text-4xl md:text-6xl text-white leading-tight mb-4">
        Ritual Sagrado<br />de Cumpleaños
      </h1>
      <p class="font-serif text-2xl md:text-3xl text-[#6ed8d9] italic mb-6">
        Cumpleaños Cósmico
      </p>
      <p class="text-stone-200 text-lg font-light tracking-wide">
        Para <strong class="text-white font-semibold">Daniela Tamayo</strong>
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       INTRODUCCIÓN
  ════════════════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <div class="bg-[#243c5a]/5 rounded-2xl p-8 md:p-12 border border-[#6ed8d9]/20 text-center">
      <div class="w-12 h-0.5 bg-[#6ed8d9] mx-auto mb-8"></div>
      <p class="font-serif text-xl md:text-2xl text-[#243c5a] leading-relaxed mb-6">
        Daniela, qué hermosa intención celebrar tu cumpleaños desde lo sagrado.
      </p>
      <p class="text-stone-600 text-base md:text-lg leading-relaxed">
        Hemos preparado para ti y tus invitadas un ritual diseñado para honrar
        este nuevo ciclo de vida — un espacio íntimo donde podrás soltar lo que
        ya cumplió su propósito y recibir conscientemente la energía del año
        que comienza.
      </p>
      <div class="w-12 h-0.5 bg-[#6ed8d9] mx-auto mt-8"></div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       DATOS DEL RITUAL
  ════════════════════════════════════════════════════ -->
  <section class="max-w-4xl mx-auto px-6 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 text-center">
        <div class="text-3xl mb-3">📅</div>
        <p class="text-xs uppercase tracking-widest text-stone-400 font-bold mb-2">Fecha</p>
        <p class="text-[#243c5a] font-semibold text-base leading-snug">Lunes 11 de mayo<br />2026</p>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 text-center">
        <div class="text-3xl mb-3">⏱️</div>
        <p class="text-xs uppercase tracking-widest text-stone-400 font-bold mb-2">Duración</p>
        <p class="text-[#243c5a] font-semibold text-base">2 horas</p>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 text-center">
        <div class="text-3xl mb-3">🌸</div>
        <p class="text-xs uppercase tracking-widest text-stone-400 font-bold mb-2">Asistentes</p>
        <p class="text-[#243c5a] font-semibold text-base">7 personas</p>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       GALERÍA — RITUALES REALES
  ════════════════════════════════════════════════════ -->
  <section class="max-w-5xl mx-auto px-6 pb-16">
    <p class="text-center text-xs font-bold uppercase tracking-widest text-stone-400 mb-8">
      Así se viven nuestros rituales
    </p>

    <!-- Grid principal: 3 columnas desktop, 2 tablet, 1 mobile -->
    <div class="grid grid-cols-2 md:grid-cols-3 gap-3">

      <!-- Fila 1: paisaje ancho ocupa 2 columnas + retrato -->
      <div class="col-span-2 md:col-span-2 rounded-2xl overflow-hidden aspect-[16/9]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczPp0dI2JJ66kfv9O3jwzgtXoU5swyyugQ1InqEAe0vQoZLNnCnkVaAsJi5vtwN_eQa0Kcf69isQ86GaeDJaHECweSw8rcqwQ75un75CoCYmJ-HuuJ9IAu92R_UJoDLgPeHaYI5vJ3pZjdMWutllLLxe0w=w1216-h913-s-no-gm?authuser=0"
          alt="Ritual sagrado de cumpleaños — espacio decorado"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="rounded-2xl overflow-hidden aspect-[3/4]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczPFDL5-ugIsOofSfc7OsocquEr4gURoMqqpCRVdHUF1qPHMk8-jS7PxJ1_B96IoqzKay6AaadZWhLCTF4fSvTU_y7-UwqH4Hoth1mqeUs5VbdyN7q4p79WPqADekb3Mgk_oZzD3xFYERywZXLhI3WaOVQ=w685-h913-s-no-gm?authuser=0"
          alt="Ritual femenino — círculo sagrado"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>

      <!-- Fila 2: retrato + retrato + paisaje ancho -->
      <div class="rounded-2xl overflow-hidden aspect-[3/4]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczMfjbyfU4WQCeMi_QWzRH4EsBQk3tfz8XFIsEjEPiZDKf0i3xSQQkcbxRdp7MIg_14PB_OD2pvrdbDtKfQRdwSudZlfdvjAfDGW6Jjgf7Z8OHDbr7QH4yql-RmBXlVLCSub5O4tHzVe6kNog2Ua8ZL2Ig=w514-h913-s-no-gm?authuser=0"
          alt="Detalle del ritual — decoración y flores"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="rounded-2xl overflow-hidden aspect-[3/4]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczNRbyzSr_Ge4Uis0aG7tSzfFV7GSrZOb35hVpxlAfPEPhE1kxmmjPaiMLYjDdcz8mx2NH-x6viAcJgtwxu7xJHdHiRXpNzyMHfVOZxwUP79VyfpKAK9NHfAAuiybmOQGinGq5lCN8sq9S0oxFfyJGEMOQ=w685-h913-s-no-gm?authuser=0"
          alt="Ritual sagrado — momento de celebración"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>
      <div class="col-span-2 md:col-span-1 rounded-2xl overflow-hidden aspect-[16/9] md:aspect-[3/4]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczO8F_5YuS5-qWBm_Z9LFSP636d_wtFL8m2PcDdCz-7UZxOiJFJ_p--gLvhi1OTvhogJcuGGbbGaqLKMgykH4Rz2OnyAiGQIIolnZi8EbNFDAFYuP6gD0KsFkN1ag-BZ025X508suXX-t4SsvUXBmuTQ=w1216-h913-s-no-gm?authuser=0"
          alt="Ritual femenino — brunch consciente y celebración"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>

      <!-- Fila 3: imagen panorámica completa -->
      <div class="col-span-2 md:col-span-3 rounded-2xl overflow-hidden aspect-[21/9]">
        <img
          src="https://lh3.googleusercontent.com/pw/AP1GczNDpRLRtkuV3Nsqncg6ikv5YVsG0MLC44ZTW3PMNyp5sLjUiLi6uVVmmXz-a5--mvRLvsJbgBLzw4_UiICowTBfCHYCnRwcmQYgJ2UNyqhysLv-EZhq3x4jWmUhNlH_te5W87JYfKZGsy-XgdJyWWJ4jw=w1216-h913-s-no-gm?authuser=0"
          alt="Ritual sagrado de cumpleaños en Medellín — Marce Anahata"
          class="w-full h-full object-cover object-top hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       DESGLOSE DE INVERSIÓN
  ════════════════════════════════════════════════════ -->
  <section class="max-w-2xl mx-auto px-6 py-12">
    <h2 class="font-serif text-3xl md:text-4xl text-[#243c5a] text-center mb-10">
      Tu inversión
    </h2>

    <div class="rounded-2xl overflow-hidden shadow-md border border-stone-200">

      <!-- Ritual base -->
      <div class="bg-[#243c5a]/5 px-6 py-2">
        <span class="text-xs font-bold uppercase tracking-widest text-[#243c5a]/50">Ritual</span>
      </div>
      <div class="bg-white border-b border-stone-100 flex items-center justify-between px-6 py-4">
        <span class="text-[#243c5a] font-medium">Anfitriona del ritual (Daniela)</span>
        <span class="text-[#5d5a8c] font-bold text-lg">$230.000</span>
      </div>
      <div class="bg-stone-50 border-b border-stone-200 flex items-start justify-between px-6 py-4">
        <span class="text-[#243c5a] font-medium">
          6 acompañantes
          <span class="block text-xs text-stone-400 font-normal mt-0.5">Tarifa 5+ personas · $105.000 c/u</span>
        </span>
        <span class="text-[#5d5a8c] font-bold text-lg">$630.000</span>
      </div>

      <!-- Subtotal ritual -->
      <div class="bg-white border-b border-stone-200 flex items-center justify-between px-6 py-4">
        <span class="text-stone-500 text-sm font-medium">Subtotal ritual</span>
        <span class="text-stone-500 font-semibold">$860.000</span>
      </div>

      <!-- Brunch -->
      <div class="bg-[#243c5a]/5 px-6 py-2">
        <span class="text-xs font-bold uppercase tracking-widest text-[#243c5a]/50">Adicionales</span>
      </div>
      <div class="bg-white border-b border-stone-200 flex items-start justify-between px-6 py-4">
        <span class="text-[#243c5a] font-medium">
          Brunch consciente
          <span class="block text-xs text-stone-400 font-normal mt-0.5">7 personas × $45.000</span>
        </span>
        <span class="text-[#5d5a8c] font-bold text-lg">$315.000</span>
      </div>

      <!-- Total -->
      <div class="bg-[#243c5a] flex items-center justify-between px-6 py-5">
        <span class="text-white font-bold text-base uppercase tracking-wide">Inversión total</span>
        <span class="text-[#6ed8d9] font-bold text-2xl">$1.175.000 COP</span>
      </div>

    </div>

    <!-- Pago -->
    <div class="mt-6 bg-[#6ed8d9]/10 border border-[#6ed8d9]/30 rounded-xl px-6 py-5">
      <p class="text-[#243c5a] text-sm font-semibold mb-1">Forma de pago</p>
      <p class="text-stone-600 text-sm leading-relaxed">
        Para reservar la fecha se cancela el <strong class="text-[#243c5a]">50% ($587.500)</strong>.
        El saldo restante se paga el día del ritual.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       QUÉ INCLUYE
  ════════════════════════════════════════════════════ -->
  <section class="bg-[#243c5a]/3 py-20 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-serif text-3xl md:text-4xl text-[#243c5a] text-center mb-4">
        Qué incluye tu ritual
      </h2>
      <p class="text-stone-500 text-center mb-12 text-sm">Cada elemento fue elegido para ti</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🌸</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Decoración temática personalizada</p>
            <p class="text-stone-500 text-sm leading-relaxed">Acondicionamiento completo del espacio acorde al propósito de tu ritual.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🍵</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Bebida de bienvenida</p>
            <p class="text-stone-500 text-sm leading-relaxed">Para abrir el círculo desde la calma y la presencia.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🔮</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Lectura de oráculo grupal</p>
            <p class="text-stone-500 text-sm leading-relaxed">Mensajes para tu nuevo ciclo y el de cada una de tus invitadas.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🔥</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Ritual de fuego y del agua</p>
            <p class="text-stone-500 text-sm leading-relaxed">Ceremonia simbólica de liberación y purificación.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🧠</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Reprogramación del subconsciente</p>
            <p class="text-stone-500 text-sm leading-relaxed">Práctica para liberar anclas y patrones repetitivos, abriendo paso a la nueva energía de manifestación.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🎵</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Baño sonoro de cierre</p>
            <p class="text-stone-500 text-sm leading-relaxed">Cuencos de cristal de cuarzo y gong para integrar la nueva vibración.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🎁</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Souvenir para cada asistente</p>
            <p class="text-stone-500 text-sm leading-relaxed">Un recordatorio tangible del ritual vivido.</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl border border-stone-200 shadow-sm p-6 flex gap-4">
          <div class="text-2xl flex-shrink-0">🥗</div>
          <div>
            <p class="font-semibold text-[#243c5a] mb-1">Brunch consciente</p>
            <p class="text-stone-500 text-sm leading-relaxed">Porción de ceviche sin proteína animal, dips, torta y bebida.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       FASES DEL RITUAL
  ════════════════════════════════════════════════════ -->
  <section class="max-w-3xl mx-auto px-6 py-20">
    <h2 class="font-serif text-3xl md:text-4xl text-[#243c5a] text-center mb-4">
      El recorrido de tu ceremonia
    </h2>
    <p class="text-stone-500 text-center mb-14 text-sm">Cinco momentos diseñados para ti</p>

    <div class="space-y-5">

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden flex">
        <div class="w-20 flex-shrink-0 bg-[#6ed8d9]/15 flex flex-col items-center justify-center py-6 gap-1">
          <span class="font-serif text-3xl font-bold text-[#6ed8d9] leading-none">1</span>
          <span class="text-[8px] font-bold uppercase tracking-widest text-[#6ed8d9]/70">fase</span>
        </div>
        <div class="p-6 flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#6ed8d9] mb-1">Apertura Sagrada</p>
          <p class="text-[#243c5a] font-semibold mb-2">Bienvenida al círculo</p>
          <p class="text-stone-500 text-sm leading-relaxed">Bienvenida, conexión y activación del círculo femenino. Bebida ceremonial y apertura del espacio sagrado.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden flex">
        <div class="w-20 flex-shrink-0 bg-[#5d5a8c]/10 flex flex-col items-center justify-center py-6 gap-1">
          <span class="font-serif text-3xl font-bold text-[#5d5a8c] leading-none">2</span>
          <span class="text-[8px] font-bold uppercase tracking-widest text-[#5d5a8c]/70">fase</span>
        </div>
        <div class="p-6 flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#5d5a8c] mb-1">Tu Lugar en el Cosmos</p>
          <p class="text-[#243c5a] font-semibold mb-2">Reconocimiento y oráculo</p>
          <p class="text-stone-500 text-sm leading-relaxed">Reconocimiento de tu poder, tu energía y el momento cósmico que estás transitando. Lectura de oráculo grupal con mensajes para el nuevo ciclo de vida.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden flex">
        <div class="w-20 flex-shrink-0 bg-[#6ed8d9]/15 flex flex-col items-center justify-center py-6 gap-1">
          <span class="font-serif text-3xl font-bold text-[#6ed8d9] leading-none">3</span>
          <span class="text-[8px] font-bold uppercase tracking-widest text-[#6ed8d9]/70">fase</span>
        </div>
        <div class="p-6 flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#6ed8d9] mb-1">Liberación y Renacer</p>
          <p class="text-[#243c5a] font-semibold mb-2">Fuego, agua y reprogramación</p>
          <p class="text-stone-500 text-sm leading-relaxed">Ritual de fuego y agua. Reprogramación de patrones del subconsciente, soltando anclas y abriendo espacio para la manifestación consciente del nuevo año de vida.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden flex">
        <div class="w-20 flex-shrink-0 bg-[#5d5a8c]/10 flex flex-col items-center justify-center py-6 gap-1">
          <span class="font-serif text-3xl font-bold text-[#5d5a8c] leading-none">4</span>
          <span class="text-[8px] font-bold uppercase tracking-widest text-[#5d5a8c]/70">fase</span>
        </div>
        <div class="p-6 flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#5d5a8c] mb-1">Baño Sonoro de Integración</p>
          <p class="text-[#243c5a] font-semibold mb-2">Cuencos y gong</p>
          <p class="text-stone-500 text-sm leading-relaxed">Cuencos de cristal de cuarzo y gong para anclar la nueva vibración en cuerpo, mente y espíritu.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl border border-stone-200 shadow-sm overflow-hidden flex">
        <div class="w-20 flex-shrink-0 bg-[#243c5a] flex flex-col items-center justify-center py-6 gap-1">
          <span class="font-serif text-3xl font-bold text-[#6ed8d9] leading-none">5</span>
          <span class="text-[8px] font-bold uppercase tracking-widest text-[#6ed8d9]/70">fase</span>
        </div>
        <div class="p-6 flex-1">
          <p class="text-xs font-bold uppercase tracking-widest text-[#243c5a] mb-1">Brunch y Celebración</p>
          <p class="text-[#243c5a] font-semibold mb-2">Cierre y hermandad</p>
          <p class="text-stone-500 text-sm leading-relaxed">Cierre con brunch consciente, brindis y entrega de souvenirs. Espacio para compartir y honrar la hermandad.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════
       CTA FINAL
  ════════════════════════════════════════════════════ -->
  <section class="bg-[#243c5a] py-20 px-6 text-center relative overflow-hidden">
    <div class="absolute top-0 left-1/3 w-64 h-64 rounded-full opacity-5 blur-3xl" style="background: #6ed8d9"></div>
    <div class="absolute bottom-0 right-1/3 w-64 h-64 rounded-full opacity-5 blur-3xl" style="background: #5d5a8c"></div>

    <div class="relative z-10 max-w-xl mx-auto">
      <p class="font-serif text-3xl md:text-4xl text-white mb-4">
        Estoy aquí para ti
      </p>
      <p class="text-stone-300 text-base leading-relaxed mb-10">
        Si tienes dudas o quieres ajustar algún detalle del ritual,<br />
        escríbeme y lo conversamos con todo el corazón.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="https://wa.me/573207329921?text=Hola%20Marce%2C%20quiero%20reservar%20mi%20Ritual%20Sagrado%20de%20Cumplea%C3%B1os%20del%2011%20de%20mayo"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block bg-[#6ed8d9] text-[#243c5a] font-bold px-8 py-4 rounded-xl hover:bg-white transition-colors shadow-lg text-base"
        >
          Reservar por WhatsApp
        </a>
        <a
          href="https://wa.me/573207329921?text=Hola%20Marce%2C%20me%20gustar%C3%ADa%20conversar%20sobre%20el%20Ritual%20de%20Cumplea%C3%B1os"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block border-2 border-white/40 text-white font-semibold px-8 py-4 rounded-xl hover:border-[#6ed8d9] hover:text-[#6ed8d9] transition-colors text-base"
