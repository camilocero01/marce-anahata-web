---
// src/pages/contacto.astro
import Layout from '../layouts/Layout.astro';

// --- DATOS DE CONTACTO ---
const contactInfo = {
  phone: "+57 320 732 9921", // TU NÚMERO REAL
  email: "info@marceanahata.com",
  address: "Cl. 11A Sur #46-12, Barrio La Aguacatala, El Poblado, Medellín, Antioquia", // TU DIRECCIÓN EXACTA
  instagram: "@marce_anahata",
  linkedin: "marceanahata",
  youtube: "@marce_anahata",
  tiktok: "@marce_anahata",
  whatsappMessage: "Hola Marce Anahata, visité tu sitio web y me gustaría ponerme en contacto contigo para..."
};

const whatsappLink = `https://wa.me/573207329921?text=${encodeURIComponent(contactInfo.whatsappMessage)}`;
---

<Layout title="Contacto — Marce Anahata Centro de Bienestar en El Poblado, Medellín" description="Agenda tu sesión de yoga, baño de gong o terapia de sonido en Marce Anahata, El Poblado, Medellín. Contacto por WhatsApp, teléfono y formulario.">
  <Fragment slot="head">
    <script type="application/ld+json">{JSON.stringify({
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://www.marceanahata.com/#business",
      "name": "Marce Anahata Centro de Bienestar",
      "url": "https://www.marceanahata.com",
      "telephone": "+573207329921",
      "email": "info@marceanahata.com",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Cl. 11A Sur #46-12, Barrio La Aguacatala",
        "addressLocality": "El Poblado, Medellín",
        "addressRegion": "Antioquia",
        "postalCode": "050012",
        "addressCountry": "CO"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 6.1955152,
        "longitude": -75.5779584
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
          "opens": "09:00",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "09:00",
          "closes": "18:00"
        }
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "contactType": "reservations",
          "telephone": "+573207329921",
          "contactOption": "TollFree",
          "availableLanguage": ["Spanish", "English"]
        },
        {
          "@type": "ContactPoint",
          "contactType": "customer support",
          "email": "info@marceanahata.com",
          "availableLanguage": ["Spanish", "English"]
        }
      ],
      "sameAs": [
        "https://www.instagram.com/marce_anahata",
        "https://www.youtube.com/@marce_anahata",
        "https://www.tiktok.com/@marce_anahata",
        "https://www.linkedin.com/company/marceanahata",
        "https://wa.me/573207329921"
      ]
    })}</script>
    <meta property="og:locale" content="es_CO" />
  </Fragment>

  <section class="relative h-[40vh] flex items-center justify-center overflow-hidden bg-[#243c5a]">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
    <div class="absolute -bottom-20 -right-20 w-96 h-96 bg-[#6ed8d9] rounded-full filter blur-[150px] opacity-20"></div>
    
    <div class="relative z-10 text-center text-white px-6">
      <span class="uppercase tracking-[0.2em] text-sm font-bold text-[#6ed8d9] mb-4 block">Estamos cerca de ti</span>
      <h1 class="text-4xl md:text-6xl font-serif">Hablemos</h1>
    </div>
  </section>

  <section class="py-20 bg-stone-50 px-6">
    <div class="max-w-6xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-stone-100">
      <div class="grid grid-cols-1 lg:grid-cols-2">
        
        <div class="p-10 md:p-16 flex flex-col justify-center">
          <h2 class="text-3xl font-serif text-[#243c5a] mb-6">Visita mi Centro de Bienestar</h2>
          <p class="text-[#243c5a]/70 mb-4 leading-relaxed">
            Cada proceso inicia con una conversación. Ya sea que busques una clase de yoga, un ritual profundo o una terapia de sonido, estoy aquí para escucharte y guiarte hacia la mejor opción para ti.
          </p>

          <div class="space-y-8">
            
            <a href={whatsappLink} target="_blank" data-event="whatsapp_click" data-label="Contact Page - Direct WhatsApp" class="flex items-start gap-4 group p-4 rounded-xl hover:bg-stone-50 transition-colors border border-transparent hover:border-stone-100">
              <div class="w-12 h-12 bg-green-100 text-green-600 rounded-full flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform">
                📱
              </div>
              <div>
                <p class="text-sm text-[#5d5a8c] font-bold uppercase tracking-wider">WhatsApp Directo</p>
                <p class="text-lg text-[#243c5a] group-hover:text-green-600 transition-colors font-medium">Escríbeme para agendar</p>
                <span class="text-xs text-stone-400 mt-1 block">Respuesta rápida</span>
              </div>
            </a>

            <div class="flex items-start gap-4 p-4">
              <div class="w-12 h-12 bg-[#6ed8d9]/20 text-[#243c5a] rounded-full flex items-center justify-center text-2xl shrink-0">
                📍
              </div>
              <div>
                <p class="text-sm text-[#5d5a8c] font-bold uppercase tracking-wider">Ubicación</p>
                <p class="text-lg text-[#243c5a]">{contactInfo.address}</p>
                <p class="text-sm text-stone-500">El Poblado, Antioquia</p>
              </div>
            </div>

            <a href={`mailto:${contactInfo.email}`} class="flex items-start gap-4 group p-4 rounded-xl hover:bg-stone-50 transition-colors border border-transparent hover:border-stone-100">
              <div class="w-12 h-12 bg-[#5d5a8c]/10 text-[#5d5a8c] rounded-full flex items-center justify-center text-2xl shrink-0 group-hover:scale-110 transition-transform">
                ✉️
              </div>
              <div>
                <p class="text-sm text-[#5d5a8c] font-bold uppercase tracking-wider">Correo Electrónico</p>
                <p class="text-lg text-[#243c5a] group-hover:text-[#5d5a8c] transition-colors">{contactInfo.email}</p>
              </div>
            </a>

          </div>

            <div class="mt-12 pt-8 border-t border-stone-100 flex flex-col sm:flex-row items-center justify-between gap-4">
            
            <div class="text-center sm:text-left">
                <p class="text-xs text-[#5d5a8c] font-bold uppercase tracking-widest mb-1">Comunidad</p>
                <p class="text-sm font-serif italic text-[#243c5a]/70">Inspiración y tips diarios para ti</p>
            </div>

            <div class="flex flex-wrap items-center justify-center sm:justify-end gap-3">
              <a 
                href="https://instagram.com/marce_anahata" 
                target="_blank"
                rel="noopener noreferrer"
                data-event="external_link"
                data-label="Instagram"
                data-link-type="social_media"
                class="group flex items-center gap-2 pl-1 pr-4 py-1 bg-stone-50 hover:bg-[#243c5a] rounded-full transition-all duration-300 border border-stone-100 hover:border-[#243c5a] shadow-sm hover:shadow-md"
              >
                <div class="w-9 h-9 bg-white text-[#243c5a] border border-stone-100 group-hover:border-transparent group-hover:bg-[#6ed8d9] group-hover:text-[#243c5a] rounded-full flex items-center justify-center transition-all duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
                </div>
                <span class="text-sm font-medium text-[#243c5a] group-hover:text-white transition-colors">{contactInfo.instagram}</span>
              </a>

              <a 
                href="https://www.linkedin.com/company/marceanahata" 
                target="_blank"
                rel="noopener noreferrer"
                data-event="external_link"
                data-label="LinkedIn"
                data-link-type="social_media"
                class="group flex items-center gap-2 pl-1 pr-4 py-1 bg-stone-50 hover:bg-[#243c5a] rounded-full transition-all duration-300 border border-stone-100 hover:border-[#243c5a] shadow-sm hover:shadow-md"
              >
                <div class="w-9 h-9 bg-white text-[#243c5a] border border-stone-100 group-hover:border-transparent group-hover:bg-[#6ed8d9] group-hover:text-[#243c5a] rounded-full flex items-center justify-center transition-all duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M6.94 8.5a1.56 1.56 0 1 1 0-3.12 1.56 1.56 0 0 1 0 3.12ZM8.5 10.06H5.38V20h3.12v-9.94ZM13.5 10.06h-2.99V20h3.12v-4.92c0-1.3.25-2.57 1.87-2.57 1.6 0 1.62 1.5 1.62 2.66V20h3.13v-5.46c0-2.68-.58-4.74-3.72-4.74-1.5 0-2.5.83-2.9 1.6h-.04v-1.34Z"/></svg>
                </div>
                <span class="text-sm font-medium text-[#243c5a] group-hover:text-white transition-colors">{contactInfo.linkedin}</span>
              </a>

              <a 
                href="https://www.youtube.com/@marce_anahata" 
                target="_blank"
                rel="noopener noreferrer"
                data-event="external_link"
                data-label="YouTube"
                data-link-type="social_media"
                class="group flex items-center gap-2 pl-1 pr-4 py-1 bg-stone-50 hover:bg-[#243c5a] rounded-full transition-all duration-300 border border-stone-100 hover:border-[#243c5a] shadow-sm hover:shadow-md"
              >
                <div class="w-9 h-9 bg-white text-[#243c5a] border border-stone-100 group-hover:border-transparent group-hover:bg-[#6ed8d9] group-hover:text-[#243c5a] rounded-full flex items-center justify-center transition-all duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2a2.9 2.9 0 0 0-2-2.05C19.7 3.6 12 3.6 12 3.6s-7.7 0-9.5.55a2.9 2.9 0 0 0-2 2.05A30.2 30.2 0 0 0 0 12a30.2 30.2 0 0 0 .5 5.8 2.9 2.9 0 0 0 2 2.05c1.8.55 9.5.55 9.5.55s7.7 0 9.5-.55a2.9 2.9 0 0 0 2-2.05A30.2 30.2 0 0 0 24 12a30.2 30.2 0 0 0-.5-5.8ZM9.6 15.5V8.5l6.2 3.5-6.2 3.5Z"/></svg>
                </div>
                <span class="text-sm font-medium text-[#243c5a] group-hover:text-white transition-colors">{contactInfo.youtube}</span>
              </a>

              <a 
                href="https://www.tiktok.com/@marce_anahata" 
                target="_blank"
                rel="noopener noreferrer"
                data-event="external_link"
                data-label="TikTok"
                data-link-type="social_media"
                class="group flex items-center gap-2 pl-1 pr-4 py-1 bg-stone-50 hover:bg-[#243c5a] rounded-full transition-all duration-300 border border-stone-100 hover:border-[#243c5a] shadow-sm hover:shadow-md"
              >
                <div class="w-9 h-9 bg-white text-[#243c5a] border border-stone-100 group-hover:border-transparent group-hover:bg-[#6ed8d9] group-hover:text-[#243c5a] rounded-full flex items-center justify-center transition-all duration-300 shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.6 8.2a6.7 6.7 0 0 1-3.9-1.3v6.5a6.1 6.1 0 1 1-5.3-6.1v3.1a3 3 0 1 0 2.2 2.9V0h3a4.1 4.1 0 0 0 4 4.1v4.1Z"/></svg>
                </div>
                <span class="text-sm font-medium text-[#243c5a] group-hover:text-white transition-colors">{contactInfo.tiktok}</span>
              </a>
            </div>

            </div>
        </div>

        <div class="relative h-[400px] lg:h-auto bg-stone-200 min-h-[400px]">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d4266.069997331585!2d-75.58053332468845!3d6.195515193792174!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e4683c25bb42ec3%3A0xa60a29f7c10d5171!2sMarce%20Anahata%20-%20Centro%20de%20bienestar!5e1!3m2!1ses!2sco!4v1766407801302!5m2!1ses!2sco" 
            class="absolute inset-0 w-full h-full border-0  transition-all duration-500"
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade">
          </iframe>
        </div>
      </div>
    </div>
  </section>

</Layout>