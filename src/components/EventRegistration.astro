---
export interface Props {
  eventTitle?: string;
  eventDate?: string;
  eventDescription?: string;
  paymentLabel?: string;
  experienceName?: string;
}

const {
  eventTitle = "Inscripción al Evento",
  eventDate = "",
  eventDescription = "Completa el formulario para reservar tu lugar",
  paymentLabel = "La inversión del evento será de <strong>$120.000 COP</strong>. Entiendo que llenar este formulario es una pre-inscripción, mi cupo se reserva con el pago del 50% del total correspondinete a <strong>$60.000 COP</strong> a la cuenta de ahorros No. <strong>935-972725-35</strong> del Bancolombia a nombre de <strong>Marcela Zuleta cc 32297153</strong>. Una vez realizado el pago, enviar comprobante por <a href=\"https://wa.me/573207329921?text=Hola%20Marce%20Anahata%2C%20envio%20comprobante%20de%20pago%20para%20confirmar%20mi%20reserva.\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-[#6ed8d9] hover:text-[#5ac5c6] font-semibold underline\">👉acá</a> para confirmar. El valor restante debe ser pagado 2 días antes del evento.",
  experienceName = "baño de gong",
} = Astro.props;
---

<div class="event-registration-section">
  <div class="max-w-2xl mx-auto">
    <h3 class="font-serif font-bold text-[#243c5a] mb-2 text-2xl md:text-3xl">
      {eventTitle}
    </h3>
    {eventDate && (
      <p class="text-sm text-[#6ed8d9] font-semibold mb-4">
        📅 {eventDate}
      </p>
    )}
    {eventDescription && (
      <p class="text-stone-600 mb-6">
        {eventDescription}
      </p>
    )}
    
    <!-- Estado de éxito (oculto por defecto) -->
    <div id="success-state" class="hidden text-center py-12 px-6">
      <div class="text-5xl mb-4">🙏</div>
      <h3 class="font-serif text-2xl text-[#243c5a] mb-3">¡Tu inscripción fue recibida!</h3>
      <p class="text-stone-600 mb-2">Pronto recibirás un correo de confirmación con todos los detalles.</p>
      <p class="text-stone-500 text-sm">Si tienes dudas, escríbenos por <a href="https://wa.me/573207329921" target="_blank" class="text-[#6ed8d9] underline font-semibold">WhatsApp</a>. ✨</p>
    </div>

    <form
      id="event-registration-form"
      class="space-y-4 mb-6"
      aria-label="Formulario de inscripción al evento"
      novalidate
    >
      <!-- Campo oculto: nombre del evento -->
      <input type="hidden" name="evento" value={eventTitle} />

      <!-- Sesión del Viaje de las 450 Vibraciones -->
      <div>
        <label for="session" class="block text-sm font-medium text-[#243c5a] mb-2">
          ¿A qué sesión deseas asistir? *
        </label>
        <select
          id="session"
          name="session"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none transition-colors bg-white"
        >
          <option value="">-- Selecciona una sesión --</option>
          <option value="abril-24">🌱 Abril 24 — La Semilla y el Silencio (Tierra)</option>
          <option value="mayo-22">💧 Mayo 22 — Limpieza de Aguas (Agua)</option>
          <option value="junio-26">🔥 Junio 26 — El Solsticio y el Fuego Interno (Fuego)</option>
          <option value="julio">🌬️ Julio — El Viento y la Palabra (Aire)</option>
          <option value="agosto">🌌 Agosto — La Caverna Interior (Éter)</option>
          <option value="septiembre">⚖️ Septiembre — El Equinoccio y el Puente (Equilibrio)</option>
          <option value="octubre">🌑 Octubre — La Sombra y el Tesoro (Profundidad)</option>
          <option value="noviembre">🍂 Noviembre — El Retorno (Memoria)</option>
          <option value="diciembre-5-6">✨ Diciembre 5-6 — Retiro de Cierre: La Gran Puja (Totalidad)</option>
        </select>
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="session">Por favor selecciona una sesión.</span>
      </div>

      <!-- Nombre completo -->
      <div>
        <label for="full-name" class="block text-sm font-medium text-[#243c5a] mb-2">
          Nombre completo *
        </label>
        <input
          type="text"
          id="full-name"
          name="full_name"
          placeholder="Tu nombre"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors"
        />
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="full-name">Por favor ingresa tu nombre completo.</span>
      </div>

      <!-- Correo electrónico -->
      <div>
        <label for="email" class="block text-sm font-medium text-[#243c5a] mb-2">
          Correo electrónico *
        </label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="tu@email.com"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors"
        />
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="email">Por favor ingresa un correo electrónico válido.</span>
      </div>

      <!-- País -->
      <div>
        <label for="country" class="block text-sm font-medium text-[#243c5a] mb-2">
          País *
        </label>
        <input
          type="text"
          id="country"
          name="country"
          placeholder="Colombia"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors"
        />
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="country">Por favor ingresa tu país.</span>
      </div>

      <!-- Teléfono/WhatsApp -->
      <div>
        <label for="phone" class="block text-sm font-medium text-[#243c5a] mb-2">
          Teléfono/WhatsApp *
        </label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="+57 300 123 4567"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors"
        />
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="phone">Por favor ingresa tu teléfono o WhatsApp.</span>
      </div>

      <!-- ¿Cómo te enteraste del evento? -->
      <div>
        <label for="source" class="block text-sm font-medium text-[#243c5a] mb-2">
          ¿Cómo te enteraste del evento? *
        </label>
        <select
          id="source"
          name="source"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none transition-colors bg-white"
        >
          <option value="">-- Selecciona una opción --</option>
          <option value="instagram">Instagram</option>
          <option value="recomendacion">Recomendación</option>
          <option value="marce-anahata">Directamente por Marce Anahata</option>
          <option value="buscadores">Buscador como google, bing, otros</option>
          <option value="otro">Otro</option>
        </select>
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="source">Por favor selecciona cómo te enteraste.</span>
      </div>

      <!-- Separador: BIENESTAR Y CUIDADO -->
      <div class="pt-4 pb-2">
        <h4 class="font-serif font-semibold text-[#243c5a] text-lg border-b-2 border-[#6ed8d9]/30 pb-2">
          💛 Bienestar y Cuidado
        </h4>
      </div>

      <!-- Primera vez en la experiencia -->
      <div>
        <label for="first-time" class="block text-sm font-medium text-[#243c5a] mb-2">
          ¿Has participado antes en un {experienceName}? *
        </label>
        <select
          id="first-time"
          name="first_time"
          required
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none transition-colors bg-white"
        >
          <option value="">-- Selecciona una opción --</option>
          <option value="no">Sí, he participado antes</option>
          <option value="yes">No, es mi primera vez</option>
        </select>
        <span class="field-error hidden text-xs text-red-500 mt-1 block" data-for="first-time">Por favor indica si es tu primera vez.</span>
      </div>

      <!-- Condiciones de salud -->
      <div>
        <label for="medical-conditions" class="block text-sm font-medium text-[#243c5a] mb-2">
          ¿Tienes alguna condición de salud que debamos tener en cuenta?
          <span class="text-stone-500 text-xs block mt-1">(Ej: embarazo, marcapasos, epilepsia, ansiedad severa, migrañas, etc.) - Información confidencial</span>
        </label>
        <textarea 
          id="medical-conditions"
          name="medical_conditions"
          placeholder="Describe brevemente cualquier condición relevante..."
          rows="3"
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors resize-none"
          aria-label="Condiciones de salud"
        ></textarea>
      </div>

      <!-- Algo que compartir -->
      <div>
        <label for="share-info" class="block text-sm font-medium text-[#243c5a] mb-2">
          ¿Hay algo que quieras compartir para acompañarte mejor durante la sesión?
          <span class="text-stone-500 text-xs block mt-1">(Intención, estado emocional, expectativas – opcional)</span>
        </label>
        <textarea 
          id="share-info"
          name="share_info"
          placeholder="Comparte lo que sientas necesario..."
          rows="3"
          class="w-full px-4 py-3 rounded-lg border-2 border-stone-200 focus:border-[#6ed8d9] focus:outline-none placeholder:text-stone-400 transition-colors resize-none"
          aria-label="Información adicional"
        ></textarea>
      </div>

      <!-- Info: pago -->
      <div class="bg-amber-50 p-4 rounded-lg border border-amber-200 text-sm text-stone-700 leading-relaxed" set:html={paymentLabel} />

      <!-- Info: consentimiento -->
      <div class="bg-blue-50 border-l-4 border-blue-400 p-4 rounded text-xs text-blue-800 leading-relaxed">
        <strong class="block mb-1">⚕️ Experiencia complementaria de bienestar</strong>
        {experienceName} no es un tratamiento médico ni psicológico y no reemplaza ningún tratamiento prescrito por profesionales de la salud. Si estás bajo cuidado médico, continúa con tu tratamiento.
      </div>

      <!-- Botón de envío -->
      <button
        type="submit"
        id="registration-btn"
        class="w-full px-6 py-3 bg-[#6ed8d9] text-[#243c5a] rounded-lg font-semibold hover:bg-[#5ac5c6] transition-all shadow-md hover:shadow-lg"
      >
        Reservar mi lugar
      </button>

      <p class="text-xs text-stone-400 text-center">
        Al enviar este formulario aceptas participar voluntariamente y entiendes lo indicado anteriormente.
      </p>
    </form>

    <div id="form-message" class="text-sm text-stone-500" role="status" aria-live="polite"></div>

    <p class="text-xs text-stone-400 mt-4">
      Recibirás una confirmación por email y WhatsApp con los detalles de asistencia.
    </p>
  </div>
</div>

<style>
  .event-registration-section {
    padding: 2.5rem 2rem;
    background: linear-gradient(135deg, rgba(110, 216, 217, 0.08) 0%, rgba(93, 90, 140, 0.05) 100%);
    border-radius: 1rem;
    border: 2px solid rgba(110, 216, 217, 0.2);
    margin: 2rem 0;
  }

  input[type="checkbox"] {
    cursor: pointer;
  }

  input[type="checkbox"]:checked {
    background-color: #6ed8d9;
    border-color: #6ed8d9;
  }
</style>

<script>
  const form = document.getElementById('event-registration-form');
  const messageDiv = document.getElementById('form-message');
  const submitBtn = document.getElementById('registration-btn');

  const REQUIRED = ['session', 'full-name', 'email', 'country', 'phone', 'source', 'first-time'];

  function showError(id) {
    const el = document.getElementById(id);
    const span = form.querySelector(`[data-for="${id}"]`);
    if (el) el.classList.replace('border-stone-200', 'border-red-400');
    if (span) span.classList.remove('hidden');
  }

  function clearError(id) {
    const el = document.getElementById(id);
    const span = form.querySelector(`[data-for="${id}"]`);
    if (el) el.classList.replace('border-red-400', 'border-stone-200');
    if (span) span.classList.add('hidden');
  }

  function validate() {
    let firstInvalid = null;
    REQUIRED.forEach(id => {
      const el = document.getElementById(id);
      if (!el) return;
      const bad = el.type === 'email'
        ? !el.value.trim() || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(el.value.trim())
        : !el.value.trim();
      if (bad) {
        showError(id);
        if (!firstInvalid) firstInvalid = el;
      } else {
        clearError(id);
      }
    });
    return firstInvalid;
  }

  if (form) {
    REQUIRED.forEach(id => {
      const el = document.getElementById(id);
      if (el) el.addEventListener(el.tagName === 'SELECT' ? 'change' : 'input', () => clearError(id));
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const firstInvalid = validate();
      if (firstInvalid) {
        firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
        firstInvalid.focus();
        return;
      }

      const formData = new FormData(form);
      const originalText = submitBtn?.textContent || 'Reservar mi lugar';

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Reservando...'; }

      try {
        const response = await fetch('/api/registro', {
          method: 'POST',
          body: formData,
        });

        const data = await response.json();

        if (data.ok) {
          form.classList.add('hidden');
          document.getElementById('success-state')?.classList.remove('hidden');
        } else {
          throw new Error('Error al procesar');
        }
      } catch (error) {
        if (messageDiv) {
          messageDiv.innerHTML = '✗ Hubo un error. Verifica tus datos e intenta de nuevo, o escríbenos por <a href="https://wa.me/573207329921" class="underline font-semibold">WhatsApp</a>.';
          messageDiv.className = 'text-sm text-red-600 font-semibold mt-4 p-3 bg-red-50 rounded-lg';
        }
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = originalText; }
      }
    });
  }
</script>
