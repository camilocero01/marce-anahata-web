---
interface Props {
  idCita: string;
  appUrl?: string;
}
const {
  idCita,
  appUrl = 'https://app.marceanahata.com/kiosco',
} = Astro.props;
const uid = Math.random().toString(36).slice(2, 8);
---

<div class="my-10 bg-[#f8f7f5] rounded-2xl p-8 border border-stone-200">
  <h3 class="text-xl font-serif text-[#243c5a] mb-2 text-center">Reserva tu lugar</h3>
  <p class="text-sm text-[#243c5a]/60 text-center mb-6">
    Ingresa tu número de cédula y accede directamente a la reserva.
  </p>
  <form id={`form-kiosco-${uid}`} class="max-w-sm mx-auto">
    <div class="mb-4">
      <label for={`kiosco-cedula-${uid}`} class="block text-sm font-semibold text-[#243c5a] mb-1">
        Número de cédula <span class="text-red-400">*</span>
      </label>
      <input
        type="text"
        id={`kiosco-cedula-${uid}`}
        required
        inputmode="numeric"
        class="w-full border border-stone-300 rounded-lg px-4 py-3 text-sm bg-white focus:outline-none focus:border-[#6ed8d9] tracking-wider"
        placeholder="Tu número de cédula"
      />
    </div>
    <button
      type="submit"
      class="w-full bg-[#243c5a] hover:bg-[#5d5a8c] text-white font-bold py-4 rounded-full text-sm transition-colors cursor-pointer"
    >
      Reservar →
    </button>
  </form>
  <p class="text-xs text-[#243c5a]/40 text-center mt-4">
    Si aún no tienes cuenta en la app, el sistema te pedirá crear una.
  </p>
</div>

<script is:inline define:vars={{ uid, idCita, appUrl }}>
  (function () {
    var form = document.getElementById('form-kiosco-' + uid);
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var cedula = document.getElementById('kiosco-cedula-' + uid).value.trim();
      window.open(appUrl + '?cita=' + idCita + '&cedula=' + encodeURIComponent(cedula), '_blank');
    });
  })();
</script>
